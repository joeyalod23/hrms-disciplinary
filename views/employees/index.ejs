<div class="container-fluid px-4 py-4">  <div class="d-flex justify-content-between align-items-center mb-4">    <h4 class="fw-bold"><i class="bi bi-people"></i> Employee Records</h4>    <a href="/employees/add" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Add Employee</a>  </div>  <div class="row g-2 mb-3">    <div class="col-md-2">      <a href="/employees?status=Active<%= search ? '&search=' + search : '' %>" class="text-decoration-none">        <div class="card border-0 shadow-sm text-white text-center py-2 <%= currentStatus === 'Active' ? 'bg-success' : 'bg-success bg-opacity-50' %>">          <small><strong><%= statusCounts.active %></strong> Active</small>        </div>      </a>    </div>    <div class="col-md-2">      <a href="/employees?status=Inactive<%= search ? '&search=' + search : '' %>" class="text-decoration-none">        <div class="card border-0 shadow-sm text-white text-center py-2 <%= currentStatus === 'Inactive' ? 'bg-secondary' : 'bg-secondary bg-opacity-50' %>">          <small><strong><%= statusCounts.inactive %></strong> Inactive</small>        </div>      </a>    </div>    <div class="col-md-2">      <a href="/employees?status=Resigned<%= search ? '&search=' + search : '' %>" class="text-decoration-none">        <div class="card border-0 shadow-sm text-white text-center py-2 <%= currentStatus === 'Resigned' ? 'bg-warning' : 'bg-warning bg-opacity-50' %>">          <small><strong><%= statusCounts.resigned %></strong> Resigned</small>        </div>      </a>    </div>    <div class="col-md-2">      <a href="/employees?status=Terminated<%= search ? '&search=' + search : '' %>" class="text-decoration-none">        <div class="card border-0 shadow-sm text-white text-center py-2 <%= currentStatus === 'Terminated' ? 'bg-danger' : 'bg-danger bg-opacity-50' %>">          <small><strong><%= statusCounts.terminated %></strong> Terminated</small>        </div>      </a>    </div>    <div class="col-md-2">      <a href="/employees<%= search ? '?search=' + search : '' %>" class="text-decoration-none">        <div class="card border-0 shadow-sm text-white text-center py-2 <%= !currentStatus || currentStatus === 'all' ? 'bg-info' : 'bg-info bg-opacity-50' %>">          <small><strong><%= statusCounts.active + statusCounts.inactive + statusCounts.resigned + statusCounts.terminated %></strong> Total</small>        </div>      </a>    </div>  </div>  <div class="card border-0 shadow-sm">    <div class="card-body">      <form method="GET" class="row g-2 mb-3">        <% if (currentStatus) { %><input type="hidden" name="status" value="<%= currentStatus %>"><% } %>        <div class="col-md-4">          <input type="text" name="search" class="form-control" placeholder="Search by name, ID, department, position..." value="<%= search %>">        </div>        <div class="col-md-2">          <button type="submit" class="btn btn-outline-primary w-100"><i class="bi bi-search"></i> Search</button>        </div>      </form>      <div class="table-responsive">        <table class="table table-hover">          <thead class="table-dark">            <tr><th>ID</th><th>Name</th><th>Trade</th><th>Department</th><th>Position</th><th>Contract</th><th>Status</th><th>Actions</th></tr>          </thead>          <tbody>            <% if (employees.length === 0) { %>              <tr><td colspan="8" class="text-center text-muted py-4">No employees found</td></tr>            <% } else { %>              <% employees.forEach(e => { %>              <tr>                <td><%= e.employee_id %></td>                <td><a href="/employees/view/<%= e.id %>" class="text-decoration-none fw-medium"><%= e.full_name %></a></td>                <td><%= e.trade || '—' %></td>                <td><%= e.department %></td>                <td><%= e.position %></td>                <td><% if (!e.contract_id) { %><span class="badge bg-danger">No Contract</span><% } else if (e.contract_status === 'Active' && e.contract_end_date && new Date(e.contract_end_date) < new Date()) { %><span class="badge bg-danger">Expired</span><% } else if (e.contract_status === 'Active' && e.contract_end_date && new Date(e.contract_end_date) <= new Date(Date.now() + 30*24*60*60*1000)) { %><span class="badge bg-warning">Expiring</span><% } else { %><span class="badge bg-success"><%= e.contract_type_name || e.contract_status %></span><% } %></td>                <td><span class="badge bg-<%= e.status === 'Active' ? 'success' : e.status === 'Resigned' ? 'warning' : e.status === 'Terminated' ? 'danger' : 'secondary' %>"><%= e.status %></span></td>                <td>                  <a href="/employees/view/<%= e.id %>" class="btn btn-sm btn-outline-info" title="View"><i class="bi bi-eye"></i></a>                  <a href="/employees/edit/<%= e.id %>" class="btn btn-sm btn-outline-warning" title="Edit"><i class="bi bi-pencil"></i></a>                </td>              </tr>              <% }) %>            <% } %>          </tbody>        </table>      </div>      <% if (pages > 1) { %>      <nav><ul class="pagination pagination-sm justify-content-center">        <% for (var i = 1; i <= pages; i++) { %>          <li class="page-item <%= i === page ? 'active' : '' %>"><a class="page-link" href="?page=<%= i %><%= search ? '&search=' + search : '' %><%= currentStatus ? '&status=' + currentStatus : '' %>"><%= i %></a></li>        <% } %>      </ul></nav>      <% } %>    </div>  </div></div>