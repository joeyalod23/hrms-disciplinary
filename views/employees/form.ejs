<div class="container-fluid px-4 py-4">  <div class="d-flex justify-content-between align-items-center mb-4">    <h4 class="fw-bold"><i class="bi bi-<%= employee ? 'pencil' : 'plus' %>-square"></i> <%= employee ? 'Edit Employee' : 'Add Employee' %></h4>    <a href="/employees" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>  </div>  <div class="card border-0 shadow-sm">    <div class="card-body">      <% if (typeof error !== 'undefined' && error) { %><div class="alert alert-danger"><%= error %></div><% } %>      <form method="POST" action="<%= employee ? '/employees/edit/' + employee.id : '/employees/add' %>">        <div class="row g-3">          <div class="col-12"><hr><h6 class="fw-bold text-primary"><i class="bi bi-person-badge"></i> Employee Information</h6></div>          <div class="col-md-4">            <label class="form-label">Employee ID *</label>            <input type="text" name="employee_id" class="form-control" value="<%= employee ? employee.employee_id : '' %>" <%= employee ? 'readonly' : 'required' %>>          </div>          <div class="col-md-4">            <label class="form-label">Last Name *</label>            <input type="text" name="last_name" class="form-control" value="<%= employee ? employee.last_name || '' : '' %>" required oninput="computeFullName()">          </div>          <div class="col-md-4">            <label class="form-label">First Name *</label>            <input type="text" name="first_name" class="form-control" value="<%= employee ? employee.first_name || '' : '' %>" required oninput="computeFullName()">          </div>          <div class="col-md-4">            <label class="form-label">Middle Name</label>            <input type="text" name="middle_name" class="form-control" value="<%= employee ? employee.middle_name || '' : '' %>" oninput="computeFullName()">          </div>          <div class="col-md-8">            <label class="form-label">Full Name</label>            <input type="text" name="full_name" class="form-control" value="<%= employee ? employee.full_name : '' %>" readonly style="background:#f8f9fa">          </div>          <div class="col-md-4">            <label class="form-label">Position *</label>            <input type="text" name="position" class="form-control" value="<%= employee ? employee.position : '' %>" required>          </div>          <div class="col-md-4">            <label class="form-label">Trade</label>            <input type="text" name="trade" class="form-control" value="<%= employee ? employee.trade || '' : '' %>">          </div>          <div class="col-md-4">            <label class="form-label">Department *</label>            <input type="text" name="department" class="form-control" value="<%= employee ? employee.department : '' %>" list="deptList" required>            <datalist id="deptList">              <% departments.forEach(d => { %><option value="<%= d %>"><% }) %>            </datalist>          </div>          <div class="col-md-4">            <label class="form-label">Project Site</label>            <input type="text" name="project_site" class="form-control" value="<%= employee ? employee.project_site || 'Vail Land Development' : 'Vail Land Development' %>">          </div>          <div class="col-md-4">            <label class="form-label">Classification</label>            <select name="classification" class="form-select">              <option value="Project-Based" <%= employee && employee.classification === 'Project-Based' ? 'selected' : '' %>>Project-Based</option>              <option value="Regular" <%= employee && employee.classification === 'Regular' ? 'selected' : '' %>>Regular</option>              <option value="Seasonal" <%= employee && employee.classification === 'Seasonal' ? 'selected' : '' %>>Seasonal</option>              <option value="Provisionary" <%= employee && employee.classification === 'Provisionary' ? 'selected' : '' %>>Provisionary</option>            </select>          </div>          <div class="col-md-4">            <label class="form-label">Branch / Site</label>            <select name="branch_id" class="form-select">              <option value="">Select Branch</option>              <% (typeof branches !== 'undefined' ? branches : []).forEach(b => { %>              <option value="<%= b.id %>" <%= employee && employee.branch_id == b.id ? 'selected' : '' %>><%= b.name %> (<%= b.code %>)</option>              <% }) %>            </select>          </div>          <div class="col-md-2">            <label class="form-label">Date Hired</label>            <input type="date" name="date_hired" class="form-control" value="<%= employee ? employee.date_hired : '' %>">          </div>          <div class="col-md-2">            <label class="form-label">Date Ended</label>            <input type="date" name="date_ended" class="form-control" value="<%= employee ? employee.date_ended || '' : '' %>">          </div>          <% if (employee) { %>          <div class="col-md-2">            <label class="form-label">Status</label>            <select name="status" class="form-select">              <option value="Active" <%= employee.status === 'Active' ? 'selected' : '' %>>Active</option>              <option value="Inactive" <%= employee.status === 'Inactive' ? 'selected' : '' %>>Inactive</option>              <option value="Resigned" <%= employee.status === 'Resigned' ? 'selected' : '' %>>Resigned</option>              <option value="Terminated" <%= employee.status === 'Terminated' ? 'selected' : '' %>>Terminated</option>            </select>          </div>          <% } %>          <div class="col-12"><hr><h6 class="fw-bold text-primary"><i class="bi bi-person-lines-fill"></i> Personal Information</h6></div>          <div class="col-md-3">            <label class="form-label">Gender</label>            <select name="gender" class="form-select">              <option value="">-- Select --</option>              <option value="Male" <%= employee && employee.gender === 'Male' ? 'selected' : '' %>>Male</option>              <option value="Female" <%= employee && employee.gender === 'Female' ? 'selected' : '' %>>Female</option>            </select>          </div>          <div class="col-md-3">            <label class="form-label">Birth Date</label>            <input type="date" name="birth_date" class="form-control" value="<%= employee ? employee.birth_date || '' : '' %>">          </div>          <div class="col-md-3">            <label class="form-label">Nationality</label>            <input type="text" name="nationality" class="form-control" value="<%= employee ? employee.nationality || 'Filipino' : 'Filipino' %>">          </div>          <div class="col-md-3">            <label class="form-label">Civil Status</label>            <select name="civil_status" class="form-select">              <option value="">-- Select --</option>              <option value="Single" <%= employee && employee.civil_status === 'Single' ? 'selected' : '' %>>Single</option>              <option value="Married" <%= employee && employee.civil_status === 'Married' ? 'selected' : '' %>>Married</option>              <option value="Divorced" <%= employee && employee.civil_status === 'Divorced' ? 'selected' : '' %>>Divorced</option>              <option value="Widowed" <%= employee && employee.civil_status === 'Widowed' ? 'selected' : '' %>>Widowed</option>            </select>          </div>          <div class="col-md-3">            <label class="form-label">Religion</label>            <input type="text" name="religion" class="form-control" value="<%= employee ? employee.religion || '' : '' %>">          </div>          <div class="col-md-2">            <label class="form-label">Blood Type</label>            <input type="text" name="blood_type" class="form-control" value="<%= employee ? employee.blood_type || '' : '' %>" placeholder="e.g. O+">          </div>          <div class="col-md-2">            <label class="form-label">Height</label>            <input type="text" name="height" class="form-control" value="<%= employee ? employee.height || '' : '' %>" placeholder="e.g. 5'6">          </div>          <div class="col-md-2">            <label class="form-label">Weight</label>            <input type="text" name="weight" class="form-control" value="<%= employee ? employee.weight || '' : '' %>" placeholder="e.g. 65kg">          </div>          <div class="col-12"><hr><h6 class="fw-bold text-primary"><i class="bi bi-telephone"></i> Contact Information</h6></div>          <div class="col-md-4">            <label class="form-label">Contact Number</label>            <input type="text" name="contact_number" class="form-control" value="<%= employee ? employee.contact_number || '' : '' %>">          </div>          <div class="col-md-4">            <label class="form-label">Email Address</label>            <input type="email" name="email" class="form-control" value="<%= employee ? employee.email || '' : '' %>" placeholder="employee@company.com">          </div>          <div class="col-md-8">            <label class="form-label">Address</label>            <input type="text" name="address" class="form-control" value="<%= employee ? employee.address || '' : '' %>">          </div>          <div class="col-12"><hr><h6 class="fw-bold text-primary"><i class="bi bi-credit-card"></i> Government Numbers</h6></div>          <div class="col-md-4">            <label class="form-label">SSS No.</label>            <input type="text" name="sss_no" class="form-control" value="<%= employee ? employee.sss_no || '' : '' %>">          </div>          <div class="col-md-4">            <label class="form-label">Pag-IBIG No.</label>            <input type="text" name="pagibig_no" class="form-control" value="<%= employee ? employee.pagibig_no || '' : '' %>">          </div>          <div class="col-md-4">            <label class="form-label">PhilHealth No.</label>            <input type="text" name="philhealth_no" class="form-control" value="<%= employee ? employee.philhealth_no || '' : '' %>">          </div>          <div class="col-12"><hr><h6 class="fw-bold text-primary"><i class="bi bi-cash-stack"></i> Compensation</h6></div>          <div class="col-md-4">            <label class="form-label">Daily Rate</label>            <input type="number" step="0.01" name="daily_rate" class="form-control" value="<%= employee ? employee.daily_rate || '' : '' %>">          </div>          <div class="col-md-4">            <label class="form-label">Monthly Rate</label>            <input type="number" step="0.01" name="monthly_rate" class="form-control" value="<%= employee ? employee.monthly_rate || '' : '' %>">          </div>          <div class="col-12"><hr><h6 class="fw-bold text-primary"><i class="bi bi-telephone-forward"></i> Emergency Contact</h6></div>          <div class="col-md-6">            <label class="form-label">Contact Person</label>            <input type="text" name="emergency_contact" class="form-control" value="<%= employee ? employee.emergency_contact || '' : '' %>">          </div>          <div class="col-md-6">            <label class="form-label">Contact Number</label>            <input type="text" name="emergency_contact_no" class="form-control" value="<%= employee ? employee.emergency_contact_no || '' : '' %>">          </div>        </div>        <div class="mt-4">          <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> <%= employee ? 'Update Employee' : 'Save Employee' %></button>          <a href="/employees" class="btn btn-outline-secondary">Cancel</a>        </div>      </form>    </div>  </div></div><script>function computeFullName() {  const last = document.querySelector('input[name="last_name"]').value.trim();  const first = document.querySelector('input[name="first_name"]').value.trim();  const middle = document.querySelector('input[name="middle_name"]').value.trim();  const parts = [last, first];  if (middle) parts.push(middle);  document.querySelector('input[name="full_name"]').value = parts.join(', ');}document.addEventListener('DOMContentLoaded', function() {  computeFullName();});</script>