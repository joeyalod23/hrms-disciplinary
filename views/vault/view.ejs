<div class="container-fluid px-4 py-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="fw-bold mb-0"><i class="bi bi-file-text"></i> <%= doc.title %></h4>
    <div class="d-flex gap-2">
      <a href="/vault" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
      <button onclick="window.print()" class="btn btn-primary"><i class="bi bi-printer"></i> Print</button>
    </div>
  </div>
  <div class="card border-0 shadow-sm">
    <div class="card-body">
      <div class="row mb-3 text-muted small">
        <div class="col-md-3"><strong>Type:</strong> <%= doc.document_type %></div>
        <div class="col-md-3"><strong>Category:</strong> <%= doc.category || '---' %></div>
        <div class="col-md-3"><strong>Revision:</strong> <%= doc.revision || '---' %></div>
        <div class="col-md-3"><strong>Uploaded:</strong> <%= new Date(doc.created_at).toLocaleDateString() %></div>
      </div>
      <% if (doc.description) { %>
        <p class="text-muted small mb-3"><%= doc.description %></p>
      <% } %>
    </div>
  </div>
  <div class="card border-0 shadow-sm mt-3">
    <div class="card-body p-0" style="background:#f5f5f5;">
      <% var ext = doc.original_name ? doc.original_name.split('.').pop().toLowerCase() : ''; %>
      <% if (htmlContent && htmlContent.type === 'xlsx') { %>
        <% htmlContent.sheets.forEach(function(sheet, idx) { %>
          <div class="p-3">
            <% if (htmlContent.sheets.length > 1) { %>
              <h6 class="text-start text-muted mb-2"><%= sheet.name %></h6>
            <% } %>
            <div style="overflow:auto;">
              <%- sheet.html %>
            </div>
          </div>
          <% if (idx < htmlContent.sheets.length - 1) { %><hr class="m-0"><% } %>
        <% }); %>
      <% } else if (htmlContent && htmlContent.type === 'docx') { %>
        <div class="p-4 text-start bg-white" style="max-width:100%;margin:0 auto;">
          <%- htmlContent.html %>
        </div>
      <% } else if (['jpg','jpeg','png','gif','bmp','webp','svg'].includes(ext)) { %>
        <img src="<%= doc.file_path %>" alt="<%= doc.title %>" style="max-width:100%;max-height:90vh;">
      <% } else if (ext === 'pdf') { %>
        <iframe src="<%= doc.file_path %>" style="width:100%;height:90vh;border:none;"></iframe>
      <% } else { %>
        <iframe src="<%= doc.file_path %>" style="width:100%;height:90vh;border:none;"></iframe>
      <% } %>
    </div>
  </div>
</div>
