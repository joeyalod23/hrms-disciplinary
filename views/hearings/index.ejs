<div class="container-fluid px-4 py-4">  <div class="d-flex justify-content-between align-items-center mb-4">    <h4 class="fw-bold"><i class="bi bi-calendar-event"></i> Hearings</h4>    <a href="/hearings/add" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Schedule Hearing</a>  </div>  <div class="card border-0 shadow-sm">    <div class="card-body">      <form method="GET" class="row g-2 mb-3">        <div class="col-md-2">          <select name="status" class="form-select">            <option value="">All Status</option>            <option value="Scheduled" <%= status === 'Scheduled' ? 'selected' : '' %>>Scheduled</option>            <option value="Ongoing" <%= status === 'Ongoing' ? 'selected' : '' %>>Ongoing</option>            <option value="Completed" <%= status === 'Completed' ? 'selected' : '' %>>Completed</option>            <option value="Cancelled" <%= status === 'Cancelled' ? 'selected' : '' %>>Cancelled</option>          </select>        </div>        <div class="col-md-1">          <button type="submit" class="btn btn-outline-primary w-100"><i class="bi bi-filter"></i></button>        </div>      </form>      <div class="table-responsive">        <table class="table table-hover">          <thead class="table-dark">            <tr><th>Case #</th><th>Employee</th><th>Date</th><th>Time</th><th>Status</th><th>Actions</th></tr>          </thead>          <tbody>            <% if (hearings.length === 0) { %>              <tr><td colspan="6" class="text-center text-muted py-4">No hearings found</td></tr>            <% } else { %>              <% hearings.forEach(h => { %>              <tr>                <td><%= h.case_number %></td>                <td><%= h.employee_name %></td>                <td><%= new Date(h.hearing_date).toLocaleDateString() %></td>                <td><%= h.start_time || '--' %> - <%= h.end_time || '--' %></td>                <td><span class="badge bg-<%= h.status === 'Completed' ? 'success' : h.status === 'Cancelled' ? 'secondary' : h.status === 'Ongoing' ? 'warning' : 'primary' %>"><%= h.status %></span></td>                <td>                  <a href="/hearings/edit/<%= h.id %>" class="btn btn-sm btn-outline-warning" title="Edit"><i class="bi bi-pencil"></i></a>                </td>              </tr>              <% }) %>            <% } %>          </tbody>        </table>      </div>      <% if (pages > 1) { %>      <nav><ul class="pagination pagination-sm justify-content-center">        <% for (var i = 1; i <= pages; i++) { %>          <li class="page-item <%= i === page ? 'active' : '' %>">            <a class="page-link" href="?page=<%= i %><%= status ? '&status=' + status : '' %>"><%= i %></a>          </li>        <% } %>      </ul></nav>      <% } %>    </div>  </div></div>