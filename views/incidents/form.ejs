<div class="container-fluid px-4 py-4">  <div class="d-flex justify-content-between align-items-center mb-4">    <h4 class="fw-bold"><i class="bi bi-<%= report ? 'pencil' : 'plus' %>-square"></i> <%= report ? 'Edit' : 'New' %> Incident Information Report</h4>    <div>      <small class="text-muted me-3">F-HRD-023 Rev 2 (01/17/23)</small>      <a href="/incidents" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>    </div>  </div>  <div class="card border-0 shadow-sm">    <div class="card-body">      <form method="POST" action="<%= report ? '/incidents/edit/' + report.id : '/incidents/add' %>">        <div class="row g-3">          <div class="col-12"><h6 class="fw-bold text-primary border-bottom pb-2"><i class="bi bi-building"></i> Project Information</h6></div>          <div class="col-md-6">            <label class="form-label">Project Name</label>            <input type="text" name="project_name" class="form-control" value="<%= report ? report.project_name : 'Vail Land Development' %>">          </div>          <div class="col-md-6">            <label class="form-label">Address</label>            <input type="text" name="address" class="form-control" value="<%= report ? report.address : '' %>" placeholder="Project address">          </div>          <div class="col-12"><h6 class="fw-bold text-primary border-bottom pb-2 mt-2"><i class="bi bi-person-badge"></i> Alleged Violator Details</h6></div>          <div class="col-md-4">            <label class="form-label">Name of Alleged Violator *</label>            <% if (report) { %>              <input type="hidden" name="employee_id" value="<%= report.employee_id %>">              <input type="text" name="alleged_violator_name" class="form-control" value="<%= report.alleged_violator_name %>" required>            <% } else { %>              <div style="position:relative;">                <input type="text" class="form-control" id="employeeSearch" placeholder="Type employee name or ID..." autocomplete="off" required>                <input type="hidden" name="employee_id" id="employeeId">                <input type="hidden" name="alleged_violator_name" id="employeeName">                <div id="employeeResults" style="position:absolute;top:100%;left:0;right:0;z-index:1000;max-height:250px;overflow-y:auto;background:#fff;border:1px solid #ccc;border-radius:4px;display:none;box-shadow:0 4px 8px rgba(0,0,0,.1);"></div>              </div>            <% } %>          </div>                    <div class="col-md-3">
            <label class="form-label">Craft/Position</label>
            <input type="text" name="craft_position" class="form-control" value="<%= report ? report.craft_position : '' %>">
          </div>
          <div class="col-md-3">
            <label class="form-label">Immediate Supervisor</label>
            <input type="text" name="immediate_supervisor" class="form-control" value="<%= report ? report.immediate_supervisor : '' %>">
          </div>
          <div class="col-md-6">
            <label class="form-label">Flr. or Bldg. Assignment/Dept.</label>            <input type="text" name="department" class="form-control" value="<%= report ? report.department : '' %>">          </div>          <div class="col-12"><h6 class="fw-bold text-primary border-bottom pb-2 mt-2"><i class="bi bi-calendar-event"></i> Incident Details</h6></div>          <div class="col-md-3">            <label class="form-label">Date of Incident *</label>            <input type="date" name="incident_date" class="form-control" value="<%= report ? report.incident_date : '' %>" required>          </div>          <div class="col-md-2">            <label class="form-label">Time of Incident</label>            <input type="time" name="incident_time" class="form-control" value="<%= report ? report.incident_time : '' %>">          </div>          <div class="col-md-3">            <label class="form-label">Date Reported *</label>            <input type="date" name="date_reported" class="form-control" value="<%= report ? report.date_reported : (today || '') %>" required>          </div>          <div class="col-12"><h6 class="fw-bold text-primary border-bottom pb-2 mt-2"><i class="bi bi-geo-alt"></i> Location of Incident</h6></div>          <div class="col-12">            <% var locs = ['Construction Site', 'Warehouse', 'Office (Operations/Administration/Client)', 'Bunkhouse', 'Canteen', 'Others']; %>            <div class="row">              <% var selectedLocs = report ? (report.location_of_incident || '').split(', ').map(s => s.trim()) : []; %>              <% locs.forEach(function(loc) { %>              <div class="col-md-4">                <div class="form-check">                  <input class="form-check-input" type="checkbox" name="location_of_incident" value="<%= loc %>" id="loc_<%= loc.replace(/\s+/g, '_') %>" <%= selectedLocs.includes(loc) ? 'checked' : '' %>>                  <label class="form-check-label" for="loc_<%= loc.replace(/\s+/g, '_') %>"><%= loc %></label>                </div>              </div>              <% }); %>            </div>          </div>          <div class="col-md-4" id="locationOtherGroup" style="display:<%= selectedLocs.includes('Others') ? 'block' : 'none' %>">            <label class="form-label">If Others, please specify</label>            <input type="text" name="location_other" class="form-control" value="<%= report ? report.location_other : '' %>">          </div>          <div class="col-12"><h6 class="fw-bold text-primary border-bottom pb-2 mt-2"><i class="bi bi-exclamation-triangle"></i> Type of Incident</h6></div>          <div class="col-12">            <% var types = ['Inappropriate Behavior', 'Property Damage/Misuse', 'Negligence of Duty', 'Inappropriate Comment', 'Physical Harm', 'Others']; %>            <div class="row">              <% var selectedTypes = report ? (report.incident_type || '').split(', ').map(s => s.trim()) : []; %>              <% types.forEach(function(t) { %>              <div class="col-md-4">                <div class="form-check">                  <input class="form-check-input" type="checkbox" name="incident_type" value="<%= t %>" id="type_<%= t.replace(/\s+/g, '_').replace(/\//g, '_') %>" <%= selectedTypes.includes(t) ? 'checked' : '' %>>                  <label class="form-check-label" for="type_<%= t.replace(/\s+/g, '_').replace(/\//g, '_') %>"><%= t %></label>                </div>              </div>              <% }); %>            </div>          </div>          <div class="col-md-4" id="typeOtherGroup" style="display:<%= selectedTypes.includes('Others') ? 'block' : 'none' %>">            <label class="form-label">If Others, please specify</label>            <input type="text" name="type_other" class="form-control" value="<%= report ? report.type_other : '' %>">          </div>          <div class="col-12"><h6 class="fw-bold text-primary border-bottom pb-2 mt-2"><i class="bi bi-people"></i> Other Involved Parties & Description</h6></div>          <div class="col-md-6">            <label class="form-label">Others Involved in Incident</label>            <textarea name="others_involved" class="form-control" rows="2" placeholder="Describe, providing names"><%= report ? report.others_involved : '' %></textarea>          </div>          <div class="col-md-6">            <label class="form-label">Witnesses</label>            <textarea name="witnesses" class="form-control" rows="2" placeholder="Describe, providing any known names"><%= report ? report.witnesses : '' %></textarea>          </div>          <div class="col-12">            <label class="form-label">Narrative Description (describe in detail what occurred and how you responded) *</label>            <textarea name="narrative_description" class="form-control" rows="5" required><%= report ? report.narrative_description : '' %></textarea>          </div>                    <div class="col-12"><h6 class="fw-bold text-primary border-bottom pb-2 mt-2"><i class="bi bi-pencil-square"></i> Signatories</h6></div>
          <div class="col-md-4">
            <label class="form-label">Reported by / Date (Print Full Name and Signature)</label>
            <div class="row g-1">
              <div class="col-8"><input type="text" name="reported_by" class="form-control form-control-sm" value="<%= report ? report.reported_by : '' %>" placeholder="Name"></div>
              <div class="col-4"><input type="date" name="reported_date" class="form-control form-control-sm" value="<%= report ? report.reported_date : (today || '') %>"></div>
            </div>
          </div>
          <div class="col-md-4">
            <label class="form-label">Noted by / Date (PM or PIC/Supervisor)</label>
            <div class="row g-1">
              <div class="col-8"><input type="text" name="noted_by" class="form-control form-control-sm" value="<%= report ? report.noted_by : '' %>" placeholder="Name"></div>
              <div class="col-4"><input type="date" name="noted_date" class="form-control form-control-sm" value="<%= report ? report.noted_date : '' %>"></div>
            </div>
          </div>
          <div class="col-md-4">
            <label class="form-label">Reviewed by / Date (Admin Asst./HR Personnel)</label>
            <div class="row g-1">
              <div class="col-8"><input type="text" name="reviewed_by" class="form-control form-control-sm" value="<%= report ? report.reviewed_by : '' %>" placeholder="Name"></div>
              <div class="col-4"><input type="date" name="reviewed_date" class="form-control form-control-sm" value="<%= report ? report.reviewed_date : '' %>"></div>
            </div>
          </div>          <% if (report) { %>          <div class="col-12"><h6 class="fw-bold text-primary border-bottom pb-2 mt-2"><i class="bi bi-check-circle"></i> Status & Resolution</h6></div>          <div class="col-md-3">            <label class="form-label">Status</label>            <select name="status" class="form-select">              <option value="Open" <%= report.status === 'Open' ? 'selected' : '' %>>Open</option>              <option value="Resolved" <%= report.status === 'Resolved' ? 'selected' : '' %>>Resolved</option>              <option value="Closed" <%= report.status === 'Closed' ? 'selected' : '' %>>Closed</option>            </select>          </div>          <div class="col-md-3">            <label class="form-label">Resolution Date</label>            <input type="date" name="resolution_date" class="form-control" value="<%= report.resolution_date || '' %>">          </div>          <div class="col-12">            <label class="form-label">Resolution Notes</label>            <textarea name="resolution_notes" class="form-control" rows="2"><%= report.resolution_notes || '' %></textarea>          </div>          <% } %>        </div>        <div class="mt-4">          <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> <%= report ? 'Update Report' : 'Submit Report' %></button>          <a href="/incidents" class="btn btn-outline-secondary">Cancel</a>        </div>      </form>    </div>  </div></div><script>  document.querySelectorAll('input[name="location_of_incident"]').forEach(cb => {    cb.addEventListener('change', function() {      const others = document.querySelector('input[name="location_of_incident"][value="Others"]');      document.getElementById('locationOtherGroup').style.display = others && others.checked ? 'block' : 'none';    });  });  document.querySelectorAll('input[name="incident_type"]').forEach(cb => {    cb.addEventListener('change', function() {      const others = document.querySelector('input[name="incident_type"][value="Others"]');      document.getElementById('typeOtherGroup').style.display = others && others.checked ? 'block' : 'none';    });  });</script><% if (!report) { %><script>
const employees = <%- JSON.stringify(employees || []) %>;  const empSearch = document.getElementById('employeeSearch');  const empId = document.getElementById('employeeId');  const empName = document.getElementById('employeeName');  const empResults = document.getElementById('employeeResults');  empSearch.addEventListener('input', function() {    const q = this.value.toLowerCase();    if (!q) { empResults.style.display = 'none'; empId.value = ''; empName.value = ''; return; }    const matches = employees.filter(e => e.full_name.toLowerCase().includes(q) || e.employee_id.includes(q)).slice(0, 20);    if (matches.length === 0) { empResults.style.display = 'none'; return; }    empResults.innerHTML = matches.map(e =>      '<div class="emp-item" data-id="' + e.id + '" data-name="' + e.full_name + '" data-position="' + (e.position || '') + '" data-dept="' + (e.department || '') + '" style="padding:8px 12px;cursor:pointer;border-bottom:1px solid #eee;font-size:14px;">' +        '<strong>' + e.employee_id + '</strong> - ' + e.full_name + ' <span style="color:#666;font-size:12px;">(' + e.department + ')</span>' +      '</div>'    ).join('');    empResults.style.display = 'block';  });  empResults.addEventListener('click', function(e) {    const item = e.target.closest('.emp-item');    if (!item) return;    empId.value = item.dataset.id;    empName.value = item.dataset.name;    empSearch.value = item.dataset.name;    empResults.style.display = 'none';    const posInput = document.querySelector('input[name="craft_position"]');    if (posInput && !posInput.value) posInput.value = item.dataset.position;    const deptInput = document.querySelector('input[name="department"]');    if (deptInput && !deptInput.value) deptInput.value = item.dataset.dept;  });  document.addEventListener('click', function(e) {    if (!e.target.closest('#employeeSearch') && !e.target.closest('#employeeResults')) empResults.style.display = 'none';  });  empSearch.addEventListener('blur', function() { setTimeout(() => { if (!document.activeElement.closest('#employeeResults')) empResults.style.display = 'none'; }, 200); });</script><% } %>
