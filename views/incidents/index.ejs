<div class="container-fluid px-4 py-4">  <div class="d-flex justify-content-between align-items-center mb-4">    <h4 class="fw-bold"><i class="bi bi-exclamation-triangle"></i> Incident Information Reports</h4>    <div>      <small class="text-muted me-3">F-HRD-023 Rev 2</small>      <a href="/incidents/add" class="btn btn-primary"><i class="bi bi-plus-lg"></i> New Report</a>    </div>  </div>  <div class="card border-0 shadow-sm">    <div class="card-body">      <form method="GET" class="row g-2 mb-3">        <div class="col-md-4">          <input type="text" name="search" class="form-control" placeholder="Search violator, report #, or type..." value="<%= search %>">        </div>        <div class="col-md-2">          <select name="status" class="form-select">            <option value="">All Status</option>            <option value="Open" <%= status === 'Open' ? 'selected' : '' %>>Open</option>            <option value="Resolved" <%= status === 'Resolved' ? 'selected' : '' %>>Resolved</option>            <option value="Closed" <%= status === 'Closed' ? 'selected' : '' %>>Closed</option>          </select>        </div>        <div class="col-md-2">          <select name="nte_overdue" class="form-select">            <option value="">NTE Filter</option>            <option value="1" <%= nte_overdue === '1' ? 'selected' : '' %>>Overdue NTE</option>          </select>        </div>        <div class="col-md-1">          <button type="submit" class="btn btn-outline-primary w-100"><i class="bi bi-search"></i></button>        </div>      </form>      <div class="table-responsive">        <table class="table table-hover">          <thead class="table-dark">            <tr><th>Report #</th><th>Alleged Violator</th><th>Type</th><th>Incident Date</th><th>Status</th><th>NTE Deadline</th><th>Actions</th></tr>          </thead>          <tbody>            <% if (reports.length === 0) { %>              <tr><td colspan="7" class="text-center text-muted py-4">No incident reports found</td></tr>            <% } else { %>              <% reports.forEach(r => { %>              <tr class="<%= r.nte_overdue_flag == 1 ? 'table-danger' : '' %>">                <td><a href="/incidents/view/<%= r.id %>" class="text-decoration-none fw-medium"><%= r.report_number %></a></td>                <td><%= r.alleged_violator_name %></td>                <td><%= r.incident_type || 'N/A' %></td>                <td><%= new Date(r.incident_date).toLocaleDateString() %></td>                <td><span class="badge bg-<%= r.status === 'Open' ? 'primary' : r.status === 'Resolved' ? 'success' : 'secondary' %>"><%= r.status %></span></td>                <td>                  <% if (r.nte_deadline_date) { %>                    <% if (r.nte_issued_date) { %>                      <span class="text-success"><i class="bi bi-check-circle"></i> Issued</span>                    <% } else if (r.nte_overdue_flag == 1) { %>                      <span class="text-danger fw-bold"><%= new Date(r.nte_deadline_date).toLocaleDateString() %> <i class="bi bi-exclamation-circle"></i></span>                    <% } else { %>                      <%= new Date(r.nte_deadline_date).toLocaleDateString() %>                    <% } %>                  <% } else { %>                    --                  <% } %>                </td>                <td>                                    <a href="/incidents/view/<%= r.id %>" class="btn btn-sm btn-outline-info" title="View"><i class="bi bi-eye"></i></a>
                  <a href="/incidents/print/<%= r.id %>" class="btn btn-sm btn-outline-success" target="_blank" title="Transcribe / Print Form"><i class="bi bi-printer"></i></a>
                  <a href="/incidents/edit/<%= r.id %>" class="btn btn-sm btn-outline-warning" title="Edit"><i class="bi bi-pencil"></i></a>                </td>              </tr>              <% }) %>            <% } %>          </tbody>        </table>      </div>      <% if (pages > 1) { %>      <nav><ul class="pagination pagination-sm justify-content-center">        <% for (var i = 1; i <= pages; i++) { %>          <li class="page-item <%= i === page ? 'active' : '' %>">            <a class="page-link" href="?page=<%= i %><%= status ? '&status=' + status : '' %><%= search ? '&search=' + search : '' %><%= nte_overdue ? '&nte_overdue=' + nte_overdue : '' %>"><%= i %></a>          </li>        <% } %>      </ul></nav>      <% } %>    </div>  </div></div>
