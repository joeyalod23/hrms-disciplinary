<div class="container-fluid px-4 py-4">  <div class="d-flex justify-content-between align-items-center mb-4">    <h4 class="fw-bold"><i class="bi bi-exclamation-triangle"></i> Incident Information Report</h4>        <div>
      <a href="/incidents/print/<%= report.id %>" class="btn btn-outline-primary" target="_blank"><i class="bi bi-printer"></i> Print Form</a>
      <small class="text-muted me-3">F-HRD-023 Rev 2 (01/17/23)</small>
      <% if (report.status === 'Open') { %>
        <a href="/incidents/edit/<%= report.id %>" class="btn btn-outline-warning"><i class="bi bi-pencil"></i> Edit</a>
      <% } %>
      <a href="/incidents" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
    </div>  </div>
  <% if (report.sla_incident_submission == 1) { %>
    <div class="alert alert-danger py-2"><i class="bi bi-exclamation-triangle-fill"></i> <strong>SLA Violation:</strong> <%= report.sla_incident_notes %></div>
  <% } %>
  <% if (report.nte_notes && report.nte_notes.includes('SLA')) { %>
    <div class="alert alert-warning py-2"><i class="bi bi-exclamation-triangle"></i> <strong>NTE SLA:</strong> <%= report.nte_notes %></div>
  <% } %>  <div class="row g-3">    <div class="col-md-8">      <div class="card border-0 shadow-sm mb-3">        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">          <h6 class="mb-0 fw-bold"><%= report.report_number %></h6>          <span class="badge bg-<%= report.status === 'Open' ? 'primary' : report.status === 'Resolved' ? 'success' : 'secondary' %> fs-6"><%= report.status %></span>        </div>        <div class="card-body">          <h6 class="fw-bold text-primary border-bottom pb-1 mb-3"><i class="bi bi-building"></i> Project Information</h6>          <div class="row g-3">            <div class="col-md-6">              <p class="mb-1 text-muted small">Project Name</p>              <p class="fw-medium"><%= report.project_name %></p>            </div>            <div class="col-md-6">              <p class="mb-1 text-muted small">Address</p>              <p class="fw-medium"><%= report.address || 'N/A' %></p>            </div>          </div>          <h6 class="fw-bold text-primary border-bottom pb-1 mb-3 mt-4"><i class="bi bi-person-badge"></i> Alleged Violator</h6>          <div class="row g-3">            <div class="col-md-4">              <p class="mb-1 text-muted small">Name</p>              <p class="fw-medium"><%= report.alleged_violator_name %></p>            </div>            <div class="col-md-4">              <p class="mb-1 text-muted small">Craft/Position</p>              <p class="fw-medium"><%= report.craft_position || 'N/A' %></p>            </div>            <div class="col-md-4">              <p class="mb-1 text-muted small">Immediate Supervisor</p>              <p class="fw-medium"><%= report.immediate_supervisor || 'N/A' %></p>            </div>            <div class="col-md-6">              <p class="mb-1 text-muted small">Floor/Bldg. Assignment/Dept.</p>              <p class="fw-medium"><%= report.department || 'N/A' %></p>            </div>          </div>          <h6 class="fw-bold text-primary border-bottom pb-1 mb-3 mt-4"><i class="bi bi-calendar-event"></i> Incident Details</h6>          <div class="row g-3">            <div class="col-md-3">              <p class="mb-1 text-muted small">Date of Incident</p>              <p class="fw-medium"><%= new Date(report.incident_date).toLocaleDateString() %></p>            </div>            <div class="col-md-3">              <p class="mb-1 text-muted small">Time</p>              <p class="fw-medium"><%= report.incident_time || 'N/A' %></p>            </div>            <div class="col-md-3">              <p class="mb-1 text-muted small">Date Reported</p>              <p class="fw-medium"><%= new Date(report.date_reported).toLocaleDateString() %></p>            </div>          </div>          <h6 class="fw-bold text-primary border-bottom pb-1 mb-3 mt-4"><i class="bi bi-geo-alt"></i> Location of Incident</h6>          <p><%= report.location_of_incident || 'N/A' %><%= report.location_other ? ' - ' + report.location_other : '' %></p>          <h6 class="fw-bold text-primary border-bottom pb-1 mb-3 mt-4"><i class="bi bi-exclamation-triangle"></i> Type of Incident</h6>          <p><%= report.incident_type || 'N/A' %><%= report.type_other ? ' - ' + report.type_other : '' %></p>          <h6 class="fw-bold text-primary border-bottom pb-1 mb-3 mt-4"><i class="bi bi-people"></i> Other Involved Parties</h6>          <div class="row g-3">            <div class="col-md-6">              <p class="mb-1 text-muted small">Others Involved</p>              <p><%= report.others_involved || 'None' %></p>            </div>            <div class="col-md-6">              <p class="mb-1 text-muted small">Witnesses</p>              <p><%= report.witnesses || 'None' %></p>            </div>          </div>          <h6 class="fw-bold text-primary border-bottom pb-1 mb-3 mt-4"><i class="bi bi-file-text"></i> Narrative Description</h6>          <p><%= report.narrative_description %></p>          <h6 class="fw-bold text-primary border-bottom pb-1 mb-3 mt-4"><i class="bi bi-pencil-square"></i> Signatories</h6>          <div class="row g-3">            <div class="col-md-4">              <p class="mb-1 text-muted small">Reported by</p>              <p class="fw-medium"><%= report.reported_by || '--' %> <%= report.reported_date ? '(' + new Date(report.reported_date).toLocaleDateString() + ')' : '' %></p>            </div>            <div class="col-md-4">              <p class="mb-1 text-muted small">Noted by (PM or PIC/Supervisor)</p>              <p class="fw-medium"><%= report.noted_by || '--' %> <%= report.noted_date ? '(' + new Date(report.noted_date).toLocaleDateString() + ')' : '' %></p>            </div>            <div class="col-md-4">              <p class="mb-1 text-muted small">Reviewed by (Admin Asst./HR)</p>              <p class="fw-medium"><%= report.reviewed_by || '--' %> <%= report.reviewed_date ? '(' + new Date(report.reviewed_date).toLocaleDateString() + ')' : '' %></p>            </div>          </div>          <% if (report.resolution_date || report.resolution_notes) { %>          <h6 class="fw-bold text-success border-bottom pb-1 mb-3 mt-4">Resolution</h6>          <div class="row g-3">            <% if (report.resolution_date) { %>            <div class="col-md-3">              <p class="mb-1 text-muted small">Resolution Date</p>              <p class="fw-medium"><%= new Date(report.resolution_date).toLocaleDateString() %></p>            </div>            <% } %>            <% if (report.resolution_notes) { %>            <div class="col-12">              <p class="mb-1 text-muted small">Resolution Notes</p>              <p><%= report.resolution_notes %></p>            </div>            <% } %>          </div>          <% } %>          <small class="text-muted">Created by: <%= report.created_by_name || 'System' %> | <%= new Date(report.created_at).toLocaleString() %></small>        </div>      </div>    </div>    <div class="col-md-4">      <div class="card border-0 shadow-sm mb-3">        <div class="card-header bg-white py-3">          <h6 class="mb-0 fw-bold"><i class="bi bi-arrow-right-square"></i> Workflow Actions</h6>        </div>        <div class="card-body">                    <% if (report.status === 'Open') { %>
          <div class="mb-3">            <h6 class="fw-bold text-<%= report.nte_overdue_flag == 1 ? 'danger' : 'warning' %>">NTE Deadline Tracker</h6>            <% if (report.nte_deadline_date) { %>              <p class="mb-1 small text-muted">NTE Deadline: <strong><%= new Date(report.nte_deadline_date).toLocaleDateString() %></strong></p>              <% if (report.nte_issued_date) { %>                <p class="text-success small"><i class="bi bi-check-circle"></i> NTE Issued on <%= new Date(report.nte_issued_date).toLocaleDateString() %></p>                <a href="/nte?search=<%= report.report_number %>" class="btn btn-outline-success btn-sm w-100 mt-1"><i class="bi bi-file-earmark-text"></i> View NTE Case</a>              <% } else if (report.nte_overdue_flag == 1) { %>                <p class="text-danger fw-bold small"><i class="bi bi-exclamation-circle"></i> OVERDUE! NTE must be issued within 5 days from report.</p>              <% } else { %>                <p class="small">NTE must be issued within 5 days from date reported.</p>              <% } %>            <% } %>          </div>

          <div class="mb-3">
            <h6 class="fw-bold text-primary">Notice of Violation (NoV)</h6>
            <% if (report.nov_id) { %>
              <p class="small text-muted">NoV Status: <strong><%= report.nov_status %></strong></p>
              <a href="/nov/view/<%= report.nov_id %>" class="btn btn-outline-warning btn-sm w-100"><i class="bi bi-file-earmark-text"></i> View NoV</a>
            <% } else { %>
              <p class="small text-muted">No Notice of Violation created yet. Site HR must create the NoV draft first before NTE can be issued.</p>
              <a href="/nov/add/<%= report.id %>" class="btn btn-warning btn-sm w-100"><i class="bi bi-file-earmark-text"></i> Create Notice of Violation (Draft)</a>
            <% } %>
          </div>

          <% if (!report.nte_issued_date && report.nov_status === 'Returned to Site') { %>
          <form method="POST" action="/incidents/issue-nte/<%= report.id %>" class="mb-3">
            <h6 class="fw-bold text-primary">Issue Notice to Explain (NTE)</h6>
            <p class="small text-muted">This will auto-generate an NTE case (F-HRD-036 Rev 0) pre-filled with IR data and redirect you to it.</p>
            <div class="mb-2">
              <label class="form-label small">Date NTE Issued *</label>
              <input type="date" name="nte_issued_date" class="form-control form-control-sm" value="<%= new Date().toISOString().split('T')[0] %>" required>
            </div>
            <div class="mb-2">
              <label class="form-label small">Notes</label>
              <textarea name="nte_notes" class="form-control form-control-sm" rows="2" placeholder="NTE reference details..."></textarea>
            </div>
            <button type="submit" class="btn btn-primary btn-sm w-100"><i class="bi bi-send"></i> Generate & Issue NTE</button>
          </form>
          <% } %>          <form method="POST" action="/incidents/resolve/<%= report.id %>">            <h6 class="fw-bold text-success">Resolve Report</h6>            <div class="mb-2">              <label class="form-label small">Resolution Date</label>              <input type="date" name="resolution_date" class="form-control form-control-sm">            </div>            <div class="mb-2">              <label class="form-label small">Resolution Notes</label>              <textarea name="resolution_notes" class="form-control form-control-sm" rows="2" placeholder="Describe the resolution..."></textarea>            </div>            <button type="submit" class="btn btn-success btn-sm w-100"><i class="bi bi-check2-all"></i> Resolve Report</button>          </form>          <% } %>          <% if (report.status === 'Resolved') { %>          <form method="POST" action="/incidents/close/<%= report.id %>">            <button type="submit" class="btn btn-dark btn-sm w-100"><i class="bi bi-lock"></i> Close Report</button>          </form>          <% } %>          <% if (report.status === 'Closed') { %>          <div class="alert alert-secondary mb-0">            <i class="bi bi-check-circle"></i> This report is <strong>Closed</strong>. No further actions available.          </div>          <% } %>        </div>      </div>      <% if (report.status !== 'Closed' && report.status !== 'Resolved') { %>      <div class="card border-0 shadow-sm">        <div class="card-header bg-white py-3">          <h6 class="mb-0 fw-bold text-danger"><i class="bi bi-trash"></i> Danger Zone</h6>        </div>        <div class="card-body">          <form method="POST" action="/incidents/delete/<%= report.id %>" onsubmit="return confirm('Are you sure you want to delete this incident report? This action cannot be undone.')">            <button type="submit" class="btn btn-outline-danger btn-sm w-100"><i class="bi bi-trash"></i> Delete Report</button>          </form>        </div>      </div>      <% } %>    </div>  </div></div>
