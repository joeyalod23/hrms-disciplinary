<!DOCTYPE html><html lang="en"><head>  <meta charset="UTF-8">  <title>IR - <%= report.report_number %></title>  <style>    @page { size: letter; margin: 0.5in 0.5in 0.3in; }    * { margin: 0; padding: 0; box-sizing: border-box; }    body { font-family: 'Times New Roman', Times, serif; font-size: 11pt; line-height: 1.4; color: #000; padding: 15px; }    .header { text-align: center; margin-bottom: 8px; }    .header h1 { font-size: 14pt; font-weight: bold; text-transform: uppercase; letter-spacing: 1px; }    hr { border: none; border-top: 1px solid #000; margin: 4px 0; }    hr.bold { border-top: 2px solid #000; }    .field-row { display: flex; margin-bottom: 2px; align-items: baseline; }    .field-label { font-weight: bold; min-width: 180px; font-size: 10pt; }    .field-label-sm { font-weight: bold; min-width: 100px; font-size: 10pt; }    .field-value { border-bottom: 1px solid #000; flex: 1; padding: 0 4px; min-height: 20px; font-size: 10pt; }    .field-value-inline { border-bottom: 1px solid #000; padding: 0 4px; min-width: 120px; font-size: 10pt; }    .section-title { font-weight: bold; font-size: 11pt; margin-top: 8px; margin-bottom: 4px; }    .checkbox-line { display: flex; flex-wrap: wrap; gap: 4px 20px; margin: 2px 0; font-size: 10pt; }    .checkbox-item { min-width: 200px; }    .checkbox-box { border: 1px solid #000; display: inline-block; width: 12px; height: 12px; margin-right: 4px; vertical-align: middle; }    .checkbox-checked .checkbox-box { background: #000; }    .narrative-box { border: 1px solid #000; min-height: 120px; padding: 8px; margin: 4px 0; font-size: 10pt; }    .signature-row { display: flex; justify-content: space-between; margin-top: 20px; }    .signature-box { width: 30%; text-align: center; }    .sig-line { border-top: 1px solid #000; margin-top: 40px; padding-top: 4px; font-size: 9pt; }    .footer { margin-top: 20px; font-size: 9pt; color: #555; text-align: center; border-top: 1px solid #999; padding-top: 4px; }    .btn-print { display: block; margin: 10px auto; padding: 8px 24px; font-size: 14px; cursor: pointer; }    .others-specify { font-size: 10pt; margin-left: 20px; }    @media print { .btn-print { display: none; } }  </style></head><body>  <button class="btn-print" onclick="window.print()"><i class="bi bi-printer"></i> Print / Save PDF</button>  <div class="header">    <h1>INCIDENT INFORMATION REPORT</h1>    <hr class="bold">  </div>  <div class="field-row">    <span class="field-label">project name:</span>    <span class="field-value"><%= report.project_name || '' %></span>    <span style="min-width:20px"></span>    <span class="field-label-sm">Address:</span>    <span class="field-value-inline"><%= report.address || '' %></span>  </div>  <hr>  <div class="field-row">    <span class="field-label">Name of Alleged Violator:</span>    <span class="field-value"><%= report.alleged_violator_name || '' %></span>    <span style="min-width:20px"></span>    <span class="field-label-sm">Craft/Position:</span>    <span class="field-value-inline"><%= report.craft_position || '' %></span>  </div>  <div class="field-row">    <span class="field-label">Flr. or Bldg. Assignment/Dept.:</span>    <span class="field-value"><%= report.department || '' %></span>    <span style="min-width:20px"></span>    <span class="field-label-sm">Immediate Supervisor:</span>    <span class="field-value-inline"><%= report.immediate_supervisor || '' %></span>  </div>  <div class="field-row">    <span class="field-label">Date of Incident:</span>    <span class="field-value" style="max-width:150px"><%= report.incident_date ? new Date(report.incident_date).toLocaleDateString() : '' %></span>    <span style="min-width:20px"></span>    <span class="field-label-sm">Time of Incident:</span>    <span class="field-value-inline"><%= report.incident_time || '' %></span>  </div>  <div class="field-row">    <span class="field-label">Date Reported:</span>    <span class="field-value" style="max-width:150px"><%= report.date_reported ? new Date(report.date_reported).toLocaleDateString() : '' %></span>  </div>  <hr>  <div class="section-title">Location of Incident</div>  <div class="checkbox-line">    <% var locs = ['Construction Site', 'Warehouse', 'Office (Operations/Administration/Client)', 'Bunkhouse', 'Canteen', 'Others']; %>    <% var selLocs = (report.location_of_incident || '').split(', ').map(s => s.trim()); %>    <% locs.forEach(function(loc) { %>      <span class="checkbox-item <%= selLocs.includes(loc) ? 'checkbox-checked' : '' %>">        <span class="checkbox-box"></span><%= loc %>      </span>    <% }); %>  </div>  <% if (report.location_other) { %>    <div class="others-specify">Others (please specify): <%= report.location_other %></div>  <% } %>  <div class="section-title">Type of Incident</div>  <div class="checkbox-line">    <% var types = ['Inappropriate Behavior', 'Property Damage/Misuse', 'Negligence of Duty', 'Inappropriate Comment', 'Physical Harm', 'Others']; %>    <% var selTypes = (report.incident_type || '').split(', ').map(s => s.trim()); %>    <% types.forEach(function(t) { %>      <span class="checkbox-item <%= selTypes.includes(t) ? 'checkbox-checked' : '' %>">        <span class="checkbox-box"></span><%= t %>      </span>    <% }); %>  </div>  <% if (report.type_other) { %>    <div class="others-specify">Others (please specify): <%= report.type_other %></div>  <% } %>  <hr>  <div class="section-title">Others involved in incident (please describe, providing names)</div>  <div class="narrative-box" style="min-height:50px"><%= report.others_involved || '' %></div>  <div class="section-title">Witnesses (please describe, providing any known names)</div>  <div class="narrative-box" style="min-height:50px"><%= report.witnesses || '' %></div>  <div class="section-title">Narrative Description (describe in detail what occurred and how you responded)</div>  <div class="narrative-box"><%= report.narrative_description || '' %></div>  <hr class="bold">  <div class="signature-row">    <div class="signature-box">      <div class="sig-line">        <strong>Reported by/Date:</strong><br>        <%= report.reported_by || '________________________' %><br>        <span style="font-size:8pt"><%= report.reported_date ? new Date(report.reported_date).toLocaleDateString() : '' %></span><br>        Print Full Name and Signature      </div>    </div>    <div class="signature-box">      <div class="sig-line">        <strong>Noted by/Date:</strong><br>        <%= report.noted_by || '________________________' %><br>        <span style="font-size:8pt"><%= report.noted_date ? new Date(report.noted_date).toLocaleDateString() : '' %></span><br>        PM or PIC/Supervisor      </div>    </div>    <div class="signature-box">      <div class="sig-line">        <strong>Reviewed by/Date:</strong><br>        <%= report.reviewed_by || '________________________' %><br>        <span style="font-size:8pt"><%= report.reviewed_date ? new Date(report.reviewed_date).toLocaleDateString() : '' %></span><br>        Admin Asst./HR Personnel      </div>    </div>  </div>  <div class="footer">    F-HRD-023 &nbsp;&nbsp; Rev 2 01/17/23 &nbsp;&nbsp;|&nbsp;&nbsp; <%= report.report_number %>  </div></body></html>
