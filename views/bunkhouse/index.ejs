<div class="container-fluid py-3">  <div class="d-flex justify-content-between align-items-center mb-3">    <h4 class="mb-0"><i class="bi bi-building me-2"></i>Bunkhouse Management</h4>    <div>      <a href="/bunkhouse/rooms/add" class="btn btn-success btn-sm me-1"><i class="bi bi-plus-circle"></i> Add Room</a>      <a href="/bunkhouse/occupants/add" class="btn btn-primary btn-sm"><i class="bi bi-person-plus"></i> Add Occupant</a>    </div>  </div>  <div class="row g-3 mb-4">    <div class="col-md-4">      <div class="card text-bg-primary shadow-sm">        <div class="card-body text-center">          <h2 class="mb-0"><%= totalBeds %></h2>          <div>Total Beds</div>        </div>      </div>    </div>    <div class="col-md-4">      <div class="card text-bg-warning shadow-sm">        <div class="card-body text-center">          <h2 class="mb-0"><%= totalOccupied %></h2>          <div>Occupied</div>        </div>      </div>    </div>    <div class="col-md-4">      <div class="card text-bg-success shadow-sm">        <div class="card-body text-center">          <h2 class="mb-0"><%= totalVacant %></h2>          <div>Vacant</div>        </div>      </div>    </div>  </div>  <div class="card shadow-sm mb-4">    <div class="card-header bg-dark text-white">      <i class="bi bi-grid-3x3-gap me-1"></i> Rooms    </div>    <div class="card-body">      <% if (rooms && rooms.length) { %>        <div class="row g-3">          <% rooms.forEach(function(room) { %>            <% var vacant = room.capacity - (room.currentOccupants || 0) %>            <div class="col-xl-3 col-lg-4 col-md-6">              <div class="card h-100 border-<%= vacant > 0 ? 'success' : 'secondary' %> shadow-sm">                <div class="card-header d-flex justify-content-between align-items-center                  <%= vacant > 0 ? 'bg-success text-white' : 'bg-secondary text-white' %>">                  <span class="fw-bold"><%= room.roomNumber %></span>                  <span class="badge bg-light text-dark"><%= room.bunkhouse %></span>                </div>                <div class="card-body">                  <p class="mb-1"><strong>Capacity:</strong> <%= room.capacity %></p>                  <p class="mb-1"><strong>Occupied:</strong> <%= room.currentOccupants || 0 %></p>                  <p class="mb-0"><strong>Vacant:</strong> <%= vacant %></p>                  <% if (room.projectSite) { %>                    <small class="text-muted"><i class="bi bi-geo-alt"></i> <%= room.projectSite %></small>                  <% } %>                </div>                <div class="card-footer text-end">                  <a href="/bunkhouse/rooms/<%= room._id %>/edit" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>                </div>              </div>            </div>          <% }) %>        </div>      <% } else { %>        <p class="text-muted mb-0 text-center">No rooms added yet.</p>      <% } %>    </div>  </div>  <div class="card shadow-sm">    <div class="card-header bg-info text-white">      <i class="bi bi-people me-1"></i> Active Occupants    </div>    <div class="card-body p-0">      <div class="table-responsive">        <table class="table table-hover mb-0">          <thead class="table-light">            <tr>              <th>Room</th>              <th>Occupant Name</th>              <th>Designation</th>              <th>Start Date</th>              <th>Rental Rate</th>              <th>Frequency</th>              <th class="text-end">Actions</th>            </tr>          </thead>          <tbody>            <% if (activeOccupants && activeOccupants.length) { %>              <% activeOccupants.forEach(function(o) { %>                <tr>                  <td><%= o.room ? o.room.roomNumber + ' (' + (o.room.bunkhouse || '') + ')' : 'N/A' %></td>                  <td><%= o.occupantName || (o.employee ? o.employee.firstName + ' ' + o.employee.lastName : '') %></td>                  <td><%= o.designation || '-' %></td>                  <td><%= o.startDate instanceof Date ? o.startDate.toLocaleDateString() : o.startDate %></td>                  <td><%= o.rentalRate ? Number(o.rentalRate).toLocaleString() : '-' %></td>                  <td><%= o.rentalFrequency || '-' %></td>                  <td class="text-end">                    <a href="/bunkhouse/occupants/<%= o._id %>/edit" class="btn btn-sm btn-outline-primary" title="Edit"><i class="bi bi-pencil"></i></a>                    <form action="/bunkhouse/occupants/<%= o._id %>/checkout" method="POST" class="d-inline" onsubmit="return confirm('Checkout this occupant?')">                      <button class="btn btn-sm btn-outline-warning" title="Checkout"><i class="bi bi-box-arrow-right"></i></button>                    </form>                  </td>                </tr>              <% }) %>            <% } else { %>              <tr><td colspan="7" class="text-center text-muted">No active occupants.</td></tr>            <% } %>          </tbody>        </table>      </div>    </div>  </div></div>