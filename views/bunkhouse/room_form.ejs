<div class="container-fluid py-3">  <nav aria-label="breadcrumb">    <ol class="breadcrumb">      <li class="breadcrumb-item"><a href="/bunkhouse">Bunkhouse</a></li>      <li class="breadcrumb-item active"><%= room && room._id ? 'Edit Room' : 'Add Room' %></li>    </ol>  </nav>  <div class="card shadow-sm">    <div class="card-header bg-primary text-white">      <i class="bi bi-door-open me-1"></i>      <h5 class="mb-0"><%= room && room._id ? 'Edit Room' : 'Add New Room' %></h5>    </div>    <div class="card-body">      <form action="/bunkhouse/rooms<%= room && room._id ? '/' + room._id + '?_method=PUT' : '' %>" method="POST">        <div class="row g-3 mb-3">          <div class="col-md-4">            <label for="roomNumber" class="form-label">Room Number</label>            <input type="text" class="form-control" id="roomNumber" name="roomNumber"                   value="<%= room ? room.roomNumber : '' %>" placeholder="e.g. A-101" required>          </div>          <div class="col-md-4">            <label for="bunkhouse" class="form-label">Bunkhouse Name</label>            <input type="text" class="form-control" id="bunkhouse" name="bunkhouse"                   value="<%= room ? room.bunkhouse : '' %>" placeholder="e.g. Main Bunkhouse" required>          </div>          <div class="col-md-4">            <label for="capacity" class="form-label">Capacity</label>            <input type="number" class="form-control" id="capacity" name="capacity" min="1"                   value="<%= room ? room.capacity : '' %>" required>          </div>        </div>        <div class="mb-3">          <label for="projectSite" class="form-label">Project Site</label>          <input type="text" class="form-control" id="projectSite" name="projectSite"                 value="<%= room ? room.projectSite : '' %>" placeholder="e.g. Site A">        </div>        <div class="d-flex justify-content-end">          <a href="/bunkhouse" class="btn btn-secondary me-2">Cancel</a>          <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i> Save</button>        </div>      </form>    </div>  </div></div>