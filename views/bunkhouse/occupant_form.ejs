<div class="container-fluid py-3">  <nav aria-label="breadcrumb">    <ol class="breadcrumb">      <li class="breadcrumb-item"><a href="/bunkhouse">Bunkhouse</a></li>      <li class="breadcrumb-item active"><%= occupant && occupant._id ? 'Edit Occupant' : 'Add Occupant' %></li>    </ol>  </nav>  <div class="card shadow-sm">    <div class="card-header bg-primary text-white">      <i class="bi bi-person-badge me-1"></i>      <h5 class="mb-0"><%= occupant && occupant._id ? 'Edit Occupant' : 'Add New Occupant' %></h5>    </div>    <div class="card-body">      <form action="/bunkhouse/occupants<%= occupant && occupant._id ? '/' + occupant._id + '?_method=PUT' : '' %>" method="POST">        <div class="row g-3 mb-3">          <div class="col-md-6">            <label for="room" class="form-label">Room</label>            <select class="form-select" id="room" name="room" required>              <option value="">-- Select Room --</option>              <% if (rooms && rooms.length) { %>                <% rooms.forEach(function(r) { %>                  <option value="<%= r._id %>" <%= occupant && occupant.room && (occupant.room._id === r._id || occupant.room.toString() === r._id.toString()) ? 'selected' : '' %>>                    <%= r.roomNumber %> - <%= r.bunkhouse %> (<%= r.capacity - (r.currentOccupants || 0) %> vacant)                  </option>                <% }) %>              <% } %>            </select>          </div>          <div class="col-md-6">            <label for="employee" class="form-label">Employee (if in system)</label>            <select class="form-select" id="employee" name="employee">              <option value="">-- Manual Entry --</option>              <% if (employees && employees.length) { %>                <% employees.forEach(function(e) { %>                  <option value="<%= e._id %>" <%= occupant && occupant.employee && (occupant.employee._id === e._id || occupant.employee.toString() === e._id.toString()) ? 'selected' : '' %>>                    <%= e.firstName %> <%= e.lastName %> - <%= e.employeeId || e.idNumber %>                  </option>                <% }) %>              <% } %>            </select>          </div>        </div>        <div class="row g-3 mb-3">          <div class="col-md-4">            <label for="occupantName" class="form-label">Occupant Name (if not in system)</label>            <input type="text" class="form-control" id="occupantName" name="occupantName"                   value="<%= occupant ? occupant.occupantName : '' %>">          </div>          <div class="col-md-4">            <label for="designation" class="form-label">Designation</label>            <input type="text" class="form-control" id="designation" name="designation"                   value="<%= occupant ? occupant.designation : '' %>">          </div>          <div class="col-md-4">            <label for="projectSite" class="form-label">Project Site</label>            <input type="text" class="form-control" id="projectSite" name="projectSite"                   value="<%= occupant ? occupant.projectSite : '' %>">          </div>        </div>        <div class="row g-3 mb-3">          <div class="col-md-3">            <label for="startDate" class="form-label">Start Date</label>            <input type="date" class="form-control" id="startDate" name="startDate"                   value="<%= occupant && occupant.startDate ? (occupant.startDate instanceof Date ? occupant.startDate.toISOString().split('T')[0] : occupant.startDate) : today %>" required>          </div>          <div class="col-md-3">            <label for="endDate" class="form-label">End Date</label>            <input type="date" class="form-control" id="endDate" name="endDate"                   value="<%= occupant && occupant.endDate ? (occupant.endDate instanceof Date ? occupant.endDate.toISOString().split('T')[0] : occupant.endDate) : '' %>">          </div>          <div class="col-md-3">            <label for="rentalRate" class="form-label">Rental Rate</label>            <input type="number" step="0.01" class="form-control" id="rentalRate" name="rentalRate"                   value="<%= occupant ? occupant.rentalRate : '' %>">          </div>          <div class="col-md-3">            <label for="rentalFrequency" class="form-label">Rental Frequency</label>            <select class="form-select" id="rentalFrequency" name="rentalFrequency">              <option value="">-- Select --</option>              <option value="Weekly" <%= occupant && occupant.rentalFrequency === 'Weekly' ? 'selected' : '' %>>Weekly</option>              <option value="Monthly" <%= occupant && occupant.rentalFrequency === 'Monthly' ? 'selected' : '' %>>Monthly</option>              <option value="One Time" <%= occupant && occupant.rentalFrequency === 'One Time' ? 'selected' : '' %>>One Time</option>            </select>          </div>        </div>        <% if (occupant && occupant._id) { %>        <div class="mb-3 form-check">          <input type="checkbox" class="form-check-input" id="isActive" name="isActive" value="true"                 <%= occupant.isActive !== false ? 'checked' : '' %>>          <label class="form-check-label" for="isActive">Is Active</label>        </div>        <% } %>        <div class="mb-3">          <label for="remarks" class="form-label">Remarks</label>          <textarea class="form-control" id="remarks" name="remarks" rows="2"><%= occupant ? occupant.remarks : '' %></textarea>        </div>        <div class="d-flex justify-content-end">          <a href="/bunkhouse" class="btn btn-secondary me-2">Cancel</a>          <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i> Save</button>        </div>      </form>    </div>  </div></div>