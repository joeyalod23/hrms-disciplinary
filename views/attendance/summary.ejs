<div class="container-fluid px-4 py-4">  <div class="d-flex justify-content-between align-items-center mb-4">    <h4 class="fw-bold"><i class="bi bi-table"></i> Monthly Attendance Summary</h4>    <div>      <form method="POST" action="/attendance/update-summary" class="d-inline">        <input type="hidden" name="month" value="<%= month %>">        <input type="hidden" name="year" value="<%= year %>">        <button type="submit" class="btn btn-primary"><i class="bi bi-arrow-repeat"></i> Update Summary</button>      </form>      <a href="/attendance" class="btn btn-outline-secondary"><i class="bi bi-list"></i> Records</a>    </div>  </div>  <div class="card border-0 shadow-sm">    <div class="card-body">      <form method="GET" class="row g-2 mb-3">        <div class="col-md-2">          <select name="month" class="form-select">            <% months.forEach(m => { %>              <option value="<%= m.value %>" <%= month === m.value ? 'selected' : '' %>><%= m.name %></option>            <% }) %>          </select>        </div>        <div class="col-md-1">          <input type="number" name="year" class="form-control" value="<%= year %>" min="2020" max="2099">        </div>        <div class="col-md-1">          <button type="submit" class="btn btn-outline-primary w-100"><i class="bi bi-search"></i></button>        </div>        <div class="col-md-8 text-end">          <a href="/attendance/export?month=<%= month %>&year=<%= year %>" class="btn btn-success"><i class="bi bi-download"></i> Export CSV</a>        </div>      </form>      <script>        (function() {          var sel = document.querySelector('select[name="month"]');          var inp = document.querySelector('input.form-control[name="year"]');          function sync() {            var hm = document.querySelector('input[type="hidden"][name="month"]');            var hy = document.querySelector('input[type="hidden"][name="year"]');            if (sel && hm) hm.value = sel.value;            if (inp && hy) hy.value = inp.value;          }          if (sel) sel.addEventListener('change', sync);          if (inp) inp.addEventListener('change', sync);        })();      </script>      <div class="table-responsive">        <table class="table table-hover table-bordered">          <thead class="table-dark">            <tr>              <th>Employee ID</th>              <th>Name</th>              <th>Trade</th>              <th>Working Days</th>              <th>Present</th>              <th>Tardiness (min)</th>              <th>Half Day</th>              <th>AWOL / Absent</th>              <th>Sick Leave</th>              <th>Filed Leave</th>              <th>Emergency Leave</th>            </tr>          </thead>          <tbody>            <% if (summary.length === 0) { %>              <tr><td colspan="11" class="text-center text-muted py-4">No summary data for this month. Click "Update Summary" to generate.</td></tr>            <% } else { %>              <% summary.forEach(s => { %>              <tr>                <td><%= s.employee_id %></td>                <td class="fw-medium"><%= s.full_name %></td>                <td><%= s.trade || s.position %></td>                <td><%= s.total_working_days %></td>                <td><%= s.days_present %></td>                <td><%= s.total_tardiness %></td>                <td><%= s.total_halfday %></td>                <td><%= s.total_awol + s.total_absent %></td>                <td><%= s.total_sick_leave %></td>                <td><%= s.total_filed_leave %></td>                <td><%= s.total_emergency_leave %></td>              </tr>              <% }) %>            <% } %>          </tbody>        </table>      </div>    </div>  </div></div>