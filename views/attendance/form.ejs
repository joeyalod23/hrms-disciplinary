<div class="container-fluid px-4 py-4">  <div class="d-flex justify-content-between align-items-center mb-4">    <h4 class="fw-bold"><i class="bi bi-<%= record ? 'pencil' : 'plus' %>-square"></i> <%= record ? 'Edit Attendance Record' : 'New Attendance Record' %></h4>    <a href="/attendance" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>  </div>  <div class="card border-0 shadow-sm">    <div class="card-body">      <form method="POST" action="<%= record ? '/attendance/edit/' + record.id : '/attendance/add' %>">        <div class="row g-3">          <div class="col-md-6">            <label class="form-label">Employee *</label>            <select name="employee_id" class="form-select" <%= record ? 'required' : '' %>>              <% if (!record) { %>                <option value="">-- Select Employee --</option>              <% } %>              <% employees.forEach(e => { %>                <option value="<%= e.id %>" <%= record && record.employee_id === e.id ? 'selected' : '' %>><%= e.employee_id %> - <%= e.full_name %> (<%= e.position %>)</option>              <% }) %>            </select>          </div>          <div class="col-md-3">            <label class="form-label">Date *</label>            <input type="date" name="date" class="form-control" value="<%= record ? record.date : today %>" required>          </div>          <div class="col-md-3">            <label class="form-label">Status *</label>            <select name="status" class="form-select" required>              <option value="Present" <%= record && record.status === 'Present' ? 'selected' : '' %>>Present</option>              <option value="Late" <%= record && record.status === 'Late' ? 'selected' : '' %>>Late</option>              <option value="Half Day" <%= record && record.status === 'Half Day' ? 'selected' : '' %>>Half Day</option>              <option value="Absent" <%= record && record.status === 'Absent' ? 'selected' : '' %>>Absent</option>              <option value="Sick Leave" <%= record && record.status === 'Sick Leave' ? 'selected' : '' %>>Sick Leave</option>              <option value="Filed Leave" <%= record && record.status === 'Filed Leave' ? 'selected' : '' %>>Filed Leave</option>              <option value="Emergency Leave" <%= record && record.status === 'Emergency Leave' ? 'selected' : '' %>>Emergency Leave</option>              <option value="AWOL" <%= record && record.status === 'AWOL' ? 'selected' : '' %>>AWOL</option>            </select>          </div>          <div class="col-md-2">            <label class="form-label">AM In (7:30-12:00)</label>            <input type="time" name="am_in" class="form-control" value="<%= record ? record.am_in : '' %>">          </div>          <div class="col-md-2">            <label class="form-label">AM Out (7:30-12:00)</label>            <input type="time" name="am_out" class="form-control" value="<%= record ? record.am_out : '' %>">          </div>          <div class="col-md-2">            <label class="form-label">PM In (1:00-4:30)</label>            <input type="time" name="pm_in" class="form-control" value="<%= record ? record.pm_in : '' %>">          </div>          <div class="col-md-2">            <label class="form-label">PM Out (1:00-4:30)</label>            <input type="time" name="pm_out" class="form-control" value="<%= record ? record.pm_out : '' %>">          </div>          <div class="col-md-2">            <label class="form-label">OT In</label>            <input type="time" name="ot_in" class="form-control" value="<%= record ? record.ot_in : '' %>">          </div>          <div class="col-md-2">            <label class="form-label">OT Out</label>            <input type="time" name="ot_out" class="form-control" value="<%= record ? record.ot_out : '' %>">          </div>          <div class="col-md-2">            <label class="form-label">Tardiness (min)</label>            <input type="number" name="tardiness_minutes" class="form-control" value="<%= record ? record.tardiness_minutes : 0 %>" min="0">          </div>          <div class="col-md-2">            <label class="form-label">Night Diff (min)</label>            <input type="number" name="nd_minutes" class="form-control" value="<%= record ? record.nd_minutes || 0 : 0 %>" min="0">          </div>          <div class="col-12">            <label class="form-label">Remarks</label>            <textarea name="remarks" class="form-control" rows="3"><%= record ? record.remarks : '' %></textarea>          </div>        </div>        <div class="mt-4">          <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> <%= record ? 'Update Record' : 'Save Record' %></button>          <a href="/attendance" class="btn btn-outline-secondary">Cancel</a>        </div>      </form>    </div>  </div></div>
