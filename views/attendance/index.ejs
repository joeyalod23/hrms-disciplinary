<!-- Apply Leave Modal (Formal) -->
<div id="applyModal" class="modal fade" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header"><h5 class="modal-title">Apply for Leave</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
      <form onsubmit="submitLeave(event)">
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label">Employee</label>
            <select id="leaveEmployee" class="form-select" required>
              <option value="">-- Select Employee --</option>
              <% employees.forEach(e => { %><option value="<%= e.id %>"><%= e.full_name %> (<%= e.employee_id %>)</option><% }) %>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label">Leave Type</label>
            <select id="leaveType" class="form-select" required>
              <option value="">-- Select --</option>
              <% leaveTypes.forEach(t => { %><option value="<%= t.id %>"><%= t.name %> (<%= t.code %>)</option><% }) %>
            </select>
          </div>
          <div class="mb-3"><small id="balanceHint" class="text-muted"></small></div>
          <div class="row g-2 mb-3">
            <div class="col-6"><label class="form-label">From</label><input type="date" id="leaveFrom" class="form-control" required onchange="calcDays()"></div>
            <div class="col-6"><label class="form-label">To</label><input type="date" id="leaveTo" class="form-control" required onchange="calcDays()"></div>
          </div>
          <div class="mb-3">
            <label class="form-label">Days</label>
            <input type="number" id="leaveDays" class="form-control" required min="0.5" step="0.5" readonly>
          </div>
          <div class="mb-3">
            <label class="form-label">Reason</label>
            <textarea id="leaveReason" class="form-control" rows="3" required></textarea>
          </div>
          <div class="mb-3">
            <label class="form-label">Attachment (medical certificate, etc.)</label>
            <input type="file" id="leaveAttachment" class="form-control" accept=".pdf,.jpg,.jpeg,.png,.webp">
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Submit</button>
        </div>
      </form>
    </div>
  </div>
</div>

<% scripts = '<script>const dailyTrendData = ' + JSON.stringify(dailyTrend) + ';</script><script src="/js/attendance-trend.js"></script>' %>
<script>
let leaves = <%- JSON.stringify(leaves) %>;
const isAdminOrHRD = <%= user.role === 'admin' || user.role === 'hrd' %>;

function esc(s) { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

function statusBadge(s) {
  const m = { Pending: 'warning', Approved: 'success', Denied: 'danger', Cancelled: 'secondary', Open: 'danger', Resolved: 'success' };
  return '<span class="badge bg-' + (m[s] || 'secondary') + '">' + s + '</span>';
}

function updateLeaveStats() {
  const pending = leaves.filter(l => l.status === 'Pending').length;
  const approved = leaves.filter(l => l.status === 'Approved').length;
  const statCards = document.querySelectorAll('#leaveMon .leave-card h4');
  if (statCards.length >= 2) {
    statCards[0].textContent = pending;
    statCards[1].textContent = approved;
  }
  const badge = document.querySelector('#leave-tab .badge');
  if (pending > 0) {
    if (badge) { badge.textContent = pending; } 
    else { document.querySelector('#leave-tab').innerHTML = '<i class="bi bi-calendar-check me-1"></i> Leave Monitoring <span class="badge bg-warning ms-1">' + pending + '</span>'; }
  } else if (badge) {
    badge.remove();
  }
}

function filterLeaveStatus(val) {
  const filtered = val ? leaves.filter(l => l.status === val) : leaves;
  renderLeaveTable(filtered);
}

function renderLeaveTable(list) {
  const tbody = document.getElementById('leaveTableBody');
  tbody.innerHTML = list.map(l => '<tr>' +
    '<td class="py-2 fw-medium">' + esc(l.employee_name) + '<br><small class="text-muted">' + l.employee_id + '</small></td>' +
    '<td class="py-2"><span class="badge bg-info">' + esc(l.leave_type_code) + '</span> ' + esc(l.leave_type_name) + '</td>' +
    '<td class="py-2">' + l.date_from + '</td>' +
    '<td class="py-2">' + l.date_to + '</td>' +
    '<td class="py-2 fw-bold">' + l.days + '</td>' +
    '<td class="py-2">' + statusBadge(l.status) + '</td>' +
    '<td class="py-2">' + (l.attachment_url ? '<a href="' + l.attachment_url + '" target="_blank" class="btn btn-sm btn-outline-secondary"><i class="bi bi-paperclip"></i></a>' : '<span class="text-muted">&mdash;</span>') + '</td>' +
    '<td class="py-2 text-muted small">' + new Date(l.created_at).toLocaleDateString() + '</td>' +
    '<td class="py-2 text-end">' + (l.status === 'Pending' && isAdminOrHRD ? '<button class="btn btn-sm btn-success me-1" onclick="updateStatus(' + l.id + ',\'Approved\')"><i class="bi bi-check-lg"></i></button><button class="btn btn-sm btn-danger" onclick="updateStatus(' + l.id + ',\'Denied\')"><i class="bi bi-x-lg"></i></button>' : '') + '</td>' +
  '</tr>').join('');
}

function calcDays() {
  const from = new Date(document.getElementById('leaveFrom').value);
  const to = new Date(document.getElementById('leaveTo').value);
  if (from && to && to >= from) {
    document.getElementById('leaveDays').value = Math.ceil((to - from) / 86400000) + 1;
  }
  checkBalance();
}

async function checkBalance() {
  const eid = document.getElementById('leaveEmployee').value;
  const ltid = document.getElementById('leaveType').value;
  const hint = document.getElementById('balanceHint');
  if (!eid || !ltid) return (hint.textContent = '');
  try {
    const r = await fetch('/leaves/api/balances/' + eid + '/' + ltid);
    const bal = await r.json();
    if (bal.available === Infinity || bal.available === null) {
      hint.innerHTML = '<i class="bi bi-info-circle me-1"></i>Available balance: <strong>Unlimited</strong>';
    } else {
      hint.innerHTML = '<i class="bi bi-info-circle me-1"></i>Available balance: <strong>' + bal.available + '</strong> day(s) (Total: ' + bal.total_days + ', Used: ' + bal.used_days + ', Pending: ' + bal.pending_days + ')';
    }
  } catch(e) { hint.textContent = ''; }
}

async function submitLeave(e) {
  e.preventDefault();
  const payload = {
    employee_id: Number(document.getElementById('leaveEmployee').value),
    leave_type_id: Number(document.getElementById('leaveType').value),
    date_from: document.getElementById('leaveFrom').value,
    date_to: document.getElementById('leaveTo').value,
    days: Number(document.getElementById('leaveDays').value),
    reason: document.getElementById('leaveReason').value,
  };
  const file = document.getElementById('leaveAttachment').files[0];
  try {
    let res;
    if (file) {
      const fd = new FormData();
      Object.entries(payload).forEach(([k, v]) => fd.append(k, v));
      fd.append('attachment', file);
      res = await fetch('/leaves/api/apply-with-attachment', { method: 'POST', body: fd });
    } else {
      res = await fetch('/leaves/api/apply', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
    }
    if (!res.ok) throw new Error((await res.json()).error);
    const data = await res.json();
    const empName = document.getElementById('leaveEmployee').options[document.getElementById('leaveEmployee').selectedIndex].text;
    const typeName = document.getElementById('leaveType').options[document.getElementById('leaveType').selectedIndex].text;
    const match = typeName.match(/\((\w+)\)/);
    const code = match ? match[1] : 'VL';
    const name = typeName.replace(/\s*\(\w+\)/, '');
    const newLeave = {
      id: data.id, employee_id: payload.employee_id, employee_name: empName,
      leave_type_id: payload.leave_type_id, leave_type_code: code, leave_type_name: name,
      date_from: payload.date_from, date_to: payload.date_to, days: payload.days,
      reason: payload.reason, status: 'Pending', attachment_url: data.attachment_url || null,
      created_at: new Date().toISOString()
    };
    leaves.unshift(newLeave);
    renderLeaveTable(leaves);
    updateLeaveStats();
    bootstrap.Modal.getInstance(document.getElementById('applyModal')).hide();
    document.getElementById('leaveEmployee').value = '';
    document.getElementById('leaveType').value = '';
    document.getElementById('leaveFrom').value = '';
    document.getElementById('leaveTo').value = '';
    document.getElementById('leaveDays').value = '';
    document.getElementById('leaveReason').value = '';
    document.getElementById('leaveAttachment').value = '';
    document.getElementById('balanceHint').textContent = '';
  } catch (e) { alert(e.message); }
}

async function updateStatus(id, status) {
  const reason = status === 'Denied' ? prompt('Reason for denial:') : '';
  if (status === 'Denied' && !reason) return;
  try {
    const res = await fetch('/leaves/api/' + id + '/status', {
      method: 'PATCH', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ status, denied_reason: reason }),
    });
    if (!res.ok) { const data = await res.json(); throw new Error(data.error || 'Failed'); }
    const leave = leaves.find(l => l.id === id);
    if (leave) leave.status = status;
    renderLeaveTable(leaves);
    updateLeaveStats();
  } catch (e) { alert(e.message); }
}

function openApplyModal() { new bootstrap.Modal(document.getElementById('applyModal')).show(); }

async function loadBalances() {
  const eid = document.getElementById('balEmployee').value;
  const body = document.getElementById('balancesBody');
  if (!eid) return body.innerHTML = '<p class="text-muted text-center py-4">Select an employee to view leave balances</p>';
  try {
    const r = await fetch('/leaves/api/balances/' + eid);
    const bals = await r.json();
    if (bals.length === 0) return body.innerHTML = '<p class="text-muted text-center py-4">No leave balances set up yet.</p>';
    body.innerHTML = '<table class="table table-sm table-hover mb-0"><thead class="table-light"><tr><th>Leave Type</th><th>Code</th><th>Total Days</th><th>Used</th><th>Pending</th><th>Available</th></tr></thead><tbody>' +
      bals.map(b => {
        const isUnlimited = b.days_per_year === 0;
        return '<tr>' +
        '<td>' + esc(b.name) + '</td>' +
        '<td><span class="badge bg-info">' + b.code + '</span></td>' +
        '<td>' + (isUnlimited ? '<span class="text-success fw-bold">Unlimited</span>' : b.total_days) + '</td>' +
        '<td>' + b.used_days + '</td>' +
        '<td>' + b.pending_days + '</td>' +
        '<td><strong class="text-' + (isUnlimited ? 'success' : (b.available > 0 ? 'success' : 'danger')) + '">' + (isUnlimited ? 'Unlimited' : b.available) + '</strong></td>' +
      '</tr>';
      }).join('') +
    '</tbody></table>';
  } catch(e) { body.innerHTML = '<p class="text-danger text-center py-4">Failed to load balances</p>'; }
}

async function updateBalance(eid, ltid) {
  const total = document.getElementById('balTotal_' + ltid).value;
  if (!confirm('Set total days to ' + total + '?')) return;
  try {
    const r = await fetch('/leaves/api/balances/update', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ employee_id: eid, leave_type_id: ltid, total_days: Number(total) }),
    });
    if (!r.ok) throw new Error('Failed');
    loadBalances();
  } catch(e) { alert(e.message); }
}

async function checkSilStatus() {
  const eid = document.getElementById('silEmployeeSelect').value;
  const result = document.getElementById('silStatusResult');
  if (!eid) return result.innerHTML = '<p class="text-muted mb-0">Select an employee and click "Check".</p>';
  try {
    const r = await fetch('/leaves/api/employees/' + eid + '/sil-status');
    const data = await r.json();
    result.innerHTML =
      '<div class="d-flex align-items-center gap-3 mb-3">' +
        '<div class="flex-grow-1"><h6 class="fw-bold mb-1">' + esc(data.full_name) + ' (' + esc(data.employee_id) + ')</h6>' +
        '<small class="text-muted">Date Hired: ' + (data.date_hired || 'N/A') + ' &middot; SIL Credited: ' + (data.sil_credited ? 'Yes' : 'No') + '</small></div>' +
        '<span class="badge ' + (data.sil_credited ? 'bg-success' : 'bg-warning') + ' fs-6 px-3 py-2">' + (data.sil_credited ? 'Credited' : 'Not Credited') + '</span>' +
      '</div>' +
      (data.sil_balance ?
      '<div class="row g-2">' +
        '<div class="col-3"><div class="border rounded p-2 text-center"><small class="d-block text-muted">Total</small><strong>' + data.sil_balance.total + '</strong></div></div>' +
        '<div class="col-3"><div class="border rounded p-2 text-center"><small class="d-block text-muted">Used</small><strong>' + data.sil_balance.used + '</strong></div></div>' +
        '<div class="col-3"><div class="border rounded p-2 text-center"><small class="d-block text-muted">Pending</small><strong>' + data.sil_balance.pending + '</strong></div></div>' +
        '<div class="col-3"><div class="border rounded p-2 text-center bg-light"><small class="d-block text-muted">Available</small><strong class="text-success">' + data.sil_balance.available + '</strong></div></div>' +
      '</div>' : '<p class="text-muted mb-0">No SIL balance record yet.</p>');
  } catch(e) { result.innerHTML = '<p class="text-danger mb-0">Error: ' + e.message + '</p>'; }
}

async function grantSil() {
  const eid = document.getElementById('silEmployeeSelect').value;
  if (!eid) return alert('Select an employee first');
  if (!confirm('Grant 5 days SIL to this employee?')) return;
  try {
    const r = await fetch('/leaves/api/sil/grant/' + eid, { method: 'POST' });
    const data = await r.json();
    alert(data.granted ? 'SIL granted: ' + data.days + ' days' : data.reason);
    if (data.granted) checkSilStatus();
  } catch(e) { alert(e.message); }
}

async function runSilAccrual() {
  if (!confirm('Process SIL accrual for all eligible employees?')) return;
  try {
    const r = await fetch('/leaves/api/sil/process-all', { method: 'POST' });
    const data = await r.json();
    alert(data.granted + ' employee(s) granted SIL out of ' + data.processed + ' eligible');
  } catch(e) { alert(e.message); }
}

async function renderAwolTable() {
  try {
    const r = await fetch('/leaves/api/awol-exceptions');
    const exceptions = await r.json();
    const tbody = document.getElementById('awolTableBody');
    if (!tbody) return;
    tbody.innerHTML = exceptions.map(ex =>
      '<tr class="' + (ex.status === 'Open' ? 'awol-alert' : '') + '">' +
        '<td class="py-2 fw-medium">' + esc(ex.employee_name) + '<br><small class="text-muted">' + ex.employee_id + '</small></td>' +
        '<td class="py-2"><span class="badge bg-danger">' + ex.exception_type + '</span></td>' +
        '<td class="py-2">' + ex.start_date + ' to ' + ex.end_date + '</td>' +
        '<td class="py-2 fw-bold">' + ex.days_missed + '</td>' +
        '<td class="py-2">' + statusBadge(ex.status) + '</td>' +
        '<td class="py-2 text-muted small">' + new Date(ex.created_at).toLocaleDateString() + '</td>' +
        '<td class="py-2 text-end">' + (ex.status === 'Open' && isAdminOrHRD ? '<button class="btn btn-sm btn-outline-success" onclick="resolveAwol(' + ex.id + ')"><i class="bi bi-check2-circle"></i> Resolve</button>' : '') + '</td>' +
      '</tr>'
    ).join('');
  } catch(e) {}
}

async function resolveAwol(id) {
  const resolution = prompt('Resolution notes (optional):');
  try {
    await fetch('/leaves/api/awol-exceptions/' + id + '/resolve', {
      method: 'PATCH', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ resolution }),
    });
    renderAwolTable();
  } catch(e) { alert(e.message); }
}

async function resolveAllAwol() {
  if (!confirm('Resolve all open AWOL exceptions? This will clear all flags.')) return;
  try {
    const r = await fetch('/leaves/api/awol-exceptions/resolve-all', { method: 'POST' });
    const data = await r.json();
    alert(data.resolved + ' exception(s) resolved');
    renderAwolTable();
  } catch(e) { alert(e.message); }
}

async function runAwolDetection() {
  try {
    const r = await fetch('/leaves/api/detect-absenteeism', { method: 'POST' });
    const data = await r.json();
    alert(data.flagged + ' employee(s) flagged for AWOL');
    if (data.flagged > 0) renderAwolTable();
  } catch(e) { alert(e.message); }
}

function activateTabFromHash() {
  const hash = window.location.hash;
  if (hash === '#leave' || hash === '#leaveMon') {
    const leaveTab = document.getElementById('leave-tab');
    if (leaveTab) {
      const bsTab = new bootstrap.Tab(leaveTab);
      bsTab.show();
    }
  }
}

renderLeaveTable(leaves);
renderAwolTable();
activateTabFromHash();
</script>
