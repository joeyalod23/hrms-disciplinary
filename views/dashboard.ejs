<div class="container-fluid px-4 py-4">

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
  <div>
    <h2 class="fw-bold mb-1"><i class="bi bi-speedometer2 me-2"></i>Dashboard</h2>
    <p class="text-muted mb-0">
      <%= new Date().toLocaleDateString('en-PH', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
      <% if (typeof userBranch !== 'undefined' && userBranch) { %>
      &middot; <span class="badge bg-info"><%= userBranch.name %></span>
      <% } else if (typeof isCorporate !== 'undefined' && isCorporate) { %>
      &middot; <span class="badge bg-secondary" style="background:#6f42c1">Corporate View</span>
      <% } %>
    </p>
  </div>
  <div class="d-flex gap-2">
    <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 fs-6 fw-normal">
      <i class="bi bi-people me-1"></i> <strong><%= stats.totalEmployees %></strong> Total Employees
    </span>
    <span class="badge bg-danger bg-opacity-10 text-danger px-3 py-2 fs-6 fw-normal">
      <i class="bi bi-shield-exclamation me-1"></i> <strong><%= totalCases %></strong> Total Cases
    </span>
  </div>
</div>

<div class="card border-0 shadow-sm mb-4">
  <div class="card-header bg-white d-flex flex-wrap justify-content-between align-items-center py-3 gap-2">
    <h5 class="fw-bold mb-0"><i class="bi bi-calendar-check me-2"></i>Attendance</h5>
    <form method="GET" class="d-flex align-items-center gap-1">
      <input type="date" name="date" value="<%= selectedDate %>" class="form-control form-control-sm" style="max-width:170px">
      <button type="submit" class="btn btn-sm btn-primary">View</button>
      <a href="/" class="btn btn-sm btn-outline-secondary">Today</a>
    </form>
  </div>
  <div class="card-body">
    <div class="row g-2 mb-3">
      <div class="col-4 col-md-2">
        <div class="border-start border-4 border-success ps-2">
          <div class="fs-4 fw-bold text-success"><%= stats.presentCount %></div>
          <small class="text-muted">Present</small>
        </div>
      </div>
      <div class="col-4 col-md-2">
        <div class="border-start border-4 border-warning ps-2">
          <div class="fs-4 fw-bold text-warning"><%= stats.lateCount %></div>
          <small class="text-muted">Late</small>
        </div>
      </div>
      <div class="col-4 col-md-2">
        <div class="border-start border-4 border-secondary ps-2">
          <div class="fs-4 fw-bold text-secondary"><%= stats.halfDayCount %></div>
          <small class="text-muted">Half Day</small>
        </div>
      </div>
      <div class="col-4 col-md-2">
        <div class="border-start border-4 border-danger ps-2">
          <div class="fs-4 fw-bold text-danger"><%= stats.absentCount %></div>
          <small class="text-muted">Absent / AWOL</small>
        </div>
      </div>
      <div class="col-4 col-md-2">
        <div class="border-start border-4 border-info ps-2">
          <div class="fs-4 fw-bold text-info"><%= stats.onLeaveCount %></div>
          <small class="text-muted">On Leave</small>
        </div>
      </div>
      <div class="col-4 col-md-2">
        <div class="border-start border-4 border-primary ps-2">
          <div class="fs-4 fw-bold text-primary"><%= stats.holidayCount %></div>
          <small class="text-muted">Holiday</small>
        </div>
      </div>
    </div>
    <div class="row g-3">
      <div class="col-md-5">
        <canvas id="attBreakdownChart" height="200"></canvas>
      </div>
      <div class="col-md-7">
        <h6 class="fw-bold text-danger mb-2"><i class="bi bi-exclamation-triangle me-1"></i>Absent Employees Today</h6>
        <% if (stats.absentEmployees.length === 0) { %>
          <p class="text-muted small mb-0">No absent employees on this date.</p>
        <% } else { %>
          <div class="table-responsive" style="max-height:220px;overflow-y:auto">
            <table class="table table-sm table-hover mb-0">
              <thead class="table-light"><tr><th>ID</th><th>Name</th><th>Position</th><th>Department</th><th>Status</th></tr></thead>
              <tbody>
                <% stats.absentEmployees.forEach(function(e) { %>
                  <tr>
                    <td><%= e.employee_id %></td>
                    <td><%= e.full_name %></td>
                    <td><%= e.position || '-' %></td>
                    <td><%= e.department || '-' %></td>
                    <td><span class="badge bg-<%= e.att_status === 'No Record' ? 'secondary' : 'danger' %>"><%= e.att_status %></span></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<div class="row g-2 mb-4" id="moduleStats">
  <div class="col-4 col-md-3 col-lg">
    <a href="/employees" class="text-decoration-none">
      <div class="card border-0 shadow-sm h-100 dashboard-card">
        <div class="card-body text-center py-3">
          <i class="bi bi-people-fill fs-4 text-primary mb-1 d-block"></i>
          <h5 class="fw-bold mb-0"><%= stats.totalEmployees %></h5>
          <small class="text-muted lh-1 d-block" style="font-size:.75rem">HR Management</small>
        </div>
      </div>
    </a>
  </div>
  <div class="col-4 col-md-3 col-lg">
    <a href="/recruitment" class="text-decoration-none">
      <div class="card border-0 shadow-sm h-100 dashboard-card">
        <div class="card-body text-center py-3">
          <i class="bi bi-person-badge-fill fs-4 text-info mb-1 d-block"></i>
          <h5 class="fw-bold mb-0"><%= moduleStats.openPRF %></h5>
          <small class="text-muted lh-1 d-block" style="font-size:.75rem">Recruitment</small>
        </div>
      </div>
    </a>
  </div>

  <div class="col-4 col-md-3 col-lg">
    <a href="/fieldchecking" class="text-decoration-none">
      <div class="card border-0 shadow-sm h-100 dashboard-card">
        <div class="card-body text-center py-3">
          <i class="bi bi-tools fs-4 text-success mb-1 d-block"></i>
          <h5 class="fw-bold mb-0"><%= moduleStats.activeFieldChecks + moduleStats.activeSubcon + moduleStats.manpowerAssign %></h5>
          <small class="text-muted lh-1 d-block" style="font-size:.75rem">Site Operations</small>
        </div>
      </div>
    </a>
  </div>
  <div class="col-4 col-md-3 col-lg">
    <a href="/cases" class="text-decoration-none">
      <div class="card border-0 shadow-sm h-100 dashboard-card">
        <div class="card-body text-center py-3">
          <i class="bi bi-shield-exclamation fs-4 text-warning mb-1 d-block"></i>
          <h5 class="fw-bold mb-0"><%= totalCases %></h5>
          <small class="text-muted lh-1 d-block" style="font-size:.75rem">Disciplinary</small>
        </div>
      </div>
    </a>
  </div>
  <div class="col-4 col-md-3 col-lg">
    <a href="/reports" class="text-decoration-none">
      <div class="card border-0 shadow-sm h-100 dashboard-card">
        <div class="card-body text-center py-3">
          <i class="bi bi-graph-up-arrow fs-4 text-secondary mb-1 d-block"></i>
          <h5 class="fw-bold mb-0"><%= stats.openCases %></h5>
          <small class="text-muted lh-1 d-block" style="font-size:.75rem">Open Cases</small>
        </div>
      </div>
    </a>
  </div>
  <div class="col-4 col-md-3 col-lg">
    <a href="/vault" class="text-decoration-none">
      <div class="card border-0 shadow-sm h-100 dashboard-card">
        <div class="card-body text-center py-3">
          <i class="bi bi-file-earmark-fill fs-4 text-dark mb-1 d-block"></i>
          <h5 class="fw-bold mb-0"><%= moduleStats.vaultDocs %></h5>
          <small class="text-muted lh-1 d-block" style="font-size:.75rem">Documents</small>
        </div>
      </div>
    </a>
  </div>
  <div class="col-4 col-md-3 col-lg">
    <a href="/compliance" class="text-decoration-none">
      <div class="card border-0 shadow-sm h-100 dashboard-card">
        <div class="card-body text-center py-3">
          <i class="bi bi-gear-fill fs-4 text-danger mb-1 d-block"></i>
          <h5 class="fw-bold mb-0"><%= overdueCount %></h5>
          <small class="text-muted lh-1 d-block" style="font-size:.75rem">Overdue Tasks</small>
        </div>
      </div>
    </a>
  </div>
</div>

<% if (tasks.length > 0) { %>
<div class="card border-0 shadow-sm mb-4">
  <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
    <h5 class="fw-bold mb-0"><i class="bi bi-list-check me-2"></i>Compliance Tasks (Next 7 Days)</h5>
    <a href="/compliance" class="btn btn-sm btn-outline-primary">View All</a>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr><th>Task</th><th>Module</th><th>Due Date</th><th>Priority</th><th>Status</th></tr>
        </thead>
        <tbody>
          <% tasks.forEach(function(t) { %>
            <tr>
              <td><%= t.title %></td>
              <td><span class="badge bg-secondary"><%= t.module %></span></td>
              <td><%= t.due_date %></td>
              <td>
                <span class="badge bg-<%= t.priority === 'Urgent' ? 'danger' : t.priority === 'High' ? 'warning' : 'info' %>">
                  <%= t.priority %>
                </span>
              </td>
              <td><span class="badge bg-<%= t.status === 'Overdue' ? 'danger' : 'warning' %>"><%= t.status %></span></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<% } %>

<div class="row g-3 mb-4">
  <div class="col-md-4">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-header bg-white py-3">
        <h6 class="fw-bold mb-0"><i class="bi bi-pie-chart me-2"></i>Cases by Severity</h6>
      </div>
      <div class="card-body">
        <canvas id="severityChart" height="200"></canvas>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-header bg-white py-3">
        <h6 class="fw-bold mb-0"><i class="bi bi-pie-chart me-2"></i>Cases by Status</h6>
      </div>
      <div class="card-body">
        <canvas id="statusChart" height="200"></canvas>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-header bg-white py-3">
        <h6 class="fw-bold mb-0"><i class="bi bi-graph-up me-2"></i>Monthly Trend (6mo)</h6>
      </div>
      <div class="card-body">
        <canvas id="monthlyChart" height="200"></canvas>
      </div>
    </div>
  </div>
</div>

<div class="row g-3 mb-4">
  <div class="col-md-6">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
        <h6 class="fw-bold mb-0"><i class="bi bi-journal-text me-2"></i>Recent Cases</h6>
        <a href="/cases" class="btn btn-sm btn-outline-primary">View All</a>
      </div>
      <div class="card-body p-0">
        <% if (recentCases.length === 0) { %>
          <p class="text-muted small p-3 mb-0">No recent cases.</p>
        <% } else { %>
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr><th>Case #</th><th>Employee</th><th>Status</th><th>Date</th></tr>
              </thead>
              <tbody>
                <% recentCases.forEach(function(c) { %>
                  <tr class="cursor-pointer" onclick="window.location='/cases/<%= c.id %>'">
                    <td><%= c.case_number %></td>
                    <td><%= c.employee_name %></td>
                    <td><span class="badge bg-<%= c.status === 'Resolved' ? 'success' : c.status === 'Open' ? 'primary' : 'warning' %>"><%= c.status %></span></td>
                    <td><%= new Date(c.created_at).toLocaleDateString() %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
        <h6 class="fw-bold mb-0"><i class="bi bi-calendar-event me-2"></i>Upcoming Hearings</h6>
        <a href="/hearings" class="btn btn-sm btn-outline-primary">View All</a>
      </div>
      <div class="card-body p-0">
        <% if (upcomingHearings.length === 0) { %>
          <p class="text-muted small p-3 mb-0">No upcoming hearings.</p>
        <% } else { %>
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr><th>Case #</th><th>Employee</th><th>Date</th><th>Status</th></tr>
              </thead>
              <tbody>
                <% upcomingHearings.forEach(function(h) { %>
                  <tr class="cursor-pointer" onclick="window.location='/hearings/<%= h.id %>'">
                    <td><%= h.case_number %></td>
                    <td><%= h.employee_name %></td>
                    <td><%= new Date(h.hearing_date).toLocaleDateString() %></td>
                    <td><span class="badge bg-info"><%= h.status %></span></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<div class="row g-3 mb-4">
  <div class="col-md-6">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
        <h6 class="fw-bold mb-0"><i class="bi bi-clock-history me-2"></i>Expiring Contracts (30 Days)</h6>
        <a href="/contracts" class="btn btn-sm btn-outline-primary">View All</a>
      </div>
      <div class="card-body p-0">
        <% if (expiringContracts.length === 0) { %>
          <p class="text-muted small p-3 mb-0">No contracts expiring soon.</p>
        <% } else { %>
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr><th>Employee</th><th>End Date</th><th>Days Left</th></tr>
              </thead>
              <tbody>
                <% expiringContracts.forEach(function(c) { %>
                  <% var daysLeft = Math.ceil((new Date(c.end_date) - new Date()) / (1000*60*60*24)); %>
                  <tr class="cursor-pointer" onclick="window.location='/contracts/<%= c.id %>'">
                    <td><%= c.full_name %></td>
                    <td><%= new Date(c.end_date).toLocaleDateString() %></td>
                    <td><span class="badge bg-<%= daysLeft <= 7 ? 'danger' : 'warning' %>"><%= daysLeft %> days</span></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
        <h6 class="fw-bold mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Top Offenses</h6>
      </div>
      <div class="card-body p-0">
        <% if (topOffenses.length === 0) { %>
          <p class="text-muted small p-3 mb-0">No offense data.</p>
        <% } else { %>
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr><th>Offense</th><th>Severity</th><th>Cases</th><th>Weight</th></tr>
              </thead>
              <tbody>
                <% topOffenses.forEach(function(o) { %>
                  <tr>
                    <td><%= o.name %></td>
                    <td><span class="badge bg-<%= o.severity === 'Serious' ? 'danger' : o.severity === 'Less Serious' ? 'warning' : 'info' %>"><%= o.severity %></span></td>
                    <td><strong><%= o.count %></strong></td>
                    <td><%= o.weight %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<div class="row g-3 mb-4">
  <div class="col-md-6">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
        <h6 class="fw-bold mb-0"><i class="bi bi-person-exclamation me-2"></i>Repeat Offenders</h6>
      </div>
      <div class="card-body p-0">
        <% if (repeatOffenders.length === 0) { %>
          <p class="text-muted small p-3 mb-0">No repeat offenders.</p>
        <% } else { %>
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr><th>Employee</th><th>Dept</th><th>Cases</th><th>Weight</th></tr>
              </thead>
              <tbody>
                <% repeatOffenders.forEach(function(r) { %>
                  <tr>
                    <td><%= r.full_name %><br><small class="text-muted"><%= r.employee_id %></small></td>
                    <td><%= r.department || '-' %></td>
                    <td><strong><%= r.case_count %></strong></td>
                    <td><span class="badge bg-<%= r.total_weight >= 10 ? 'danger' : r.total_weight >= 5 ? 'warning' : 'info' %>"><%= r.total_weight || 0 %></span></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-header bg-white py-3">
        <h6 class="fw-bold mb-0"><i class="bi bi-bar-chart me-2"></i>Cases by COD Group</h6>
      </div>
      <div class="card-body">
        <canvas id="groupChart" height="200"></canvas>
      </div>
    </div>
  </div>
</div>

</div>

<style>
.dashboard-card { transition: transform 0.15s, box-shadow 0.15s; cursor: pointer; }
.dashboard-card:hover { transform: translateY(-2px); box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important; }
.dashboard-header { transition: background 0.15s; cursor: pointer; }
.dashboard-header:hover { background: #f0f0f0 !important; }
.cursor-pointer { cursor: pointer; }
#moduleStats .card { transition: transform 0.15s, box-shadow 0.15s; }
#moduleStats .card:hover { transform: translateY(-2px); box-shadow: 0 .25rem .75rem rgba(0,0,0,.1) !important; }
</style>

<% scripts = '<script>const monthlyLabels = ' + JSON.stringify(monthlyData.map(d => d.month)) + '; const monthlyCounts = ' + JSON.stringify(monthlyData.map(d => d.count)) + '; const statusLabels = ' + JSON.stringify(statusData.map(d => d.status)) + '; const statusCounts = ' + JSON.stringify(statusData.map(d => d.count)) + '; const severityLabels = ' + JSON.stringify(severityData.map(d => d.severity)) + '; const severityCounts = ' + JSON.stringify(severityData.map(d => d.count)) + '; const attBreakdown = { labels: ["Present","Late","Half Day","Absent/AWOL","On Leave","Holiday"], counts: [' + stats.presentCount + ',' + stats.lateCount + ',' + stats.halfDayCount + ',' + stats.absentCount + ',' + stats.onLeaveCount + ',' + stats.holidayCount + '] }; const groupLabels = ' + JSON.stringify(groupData.map(d => "Group " + d.group_code)) + '; const groupCounts = ' + JSON.stringify(groupData.map(d => d.count)) + '; const groupWeights = ' + JSON.stringify(groupData.map(d => d.total_weight || 0)) + ';</script><script src="/js/dashboard.js"></script>' %>
