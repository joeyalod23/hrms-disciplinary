<div class="container-fluid px-4 py-4">
<div class="d-flex justify-content-between align-items-center mb-4">
<div>
<h2 class="fw-bold mb-1"><i class="bi bi-building me-2"></i>Branches / Sites</h2>
<p class="text-muted mb-0">Manage company branches and project sites</p>
</div>
<div>
<a href="/branches/users" class="btn btn-outline-info"><i class="bi bi-people"></i> User Assignment</a>
<a href="/branches/add" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Add Branch</a>
</div>
</div>

<% if (typeof error !== 'undefined' && error) { %>
<div class="alert alert-danger"><%= error %></div>
<% } %>

<div class="card border-0 shadow-sm">
<div class="card-body p-0">
<table class="table table-hover mb-0">
<thead class="table-light">
<tr>
<th class="py-3">Code</th>
<th class="py-3">Name</th>
<th class="py-3">Contact</th>
<th class="py-3 text-center">Employees</th>
<th class="py-3 text-center">Users</th>
<th class="py-3 text-center">Status</th>
<th class="py-3 text-end">Actions</th>
</tr>
</thead>
<tbody>
<% if (branches.length === 0) { %>
<tr><td colspan="7" class="text-center text-muted py-4">No branches defined yet</td></tr>
<% } %>
<% branches.forEach(b => { %>
<tr class="<%= b.is_active ? '' : 'text-muted' %>">
<td><span class="badge bg-secondary fs-6"><%= b.code %></span></td>
<td class="fw-medium"><%= b.name %></td>
<td>
<small><%= b.contact_person || '—' %><br><%= b.contact_number || '' %></small>
</td>
<td class="text-center"><%= b.employee_count %></td>
<td class="text-center"><%= b.user_count %></td>
<td class="text-center">
<span class="badge bg-<%= b.is_active ? 'success' : 'danger' %>"><%= b.is_active ? 'Active' : 'Inactive' %></span>
</td>
<td class="text-end">
<a href="/branches/edit/<%= b.id %>" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
<% if (b.employee_count === 0 && b.user_count === 0) { %>
<form method="post" action="/branches/delete/<%= b.id %>" class="d-inline" onsubmit="return confirm('Delete this branch?')">
<button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
</form>
<% } %>
</td>
</tr>
<% }) %>
</tbody>
</table>
</div>
</div>
</div>
