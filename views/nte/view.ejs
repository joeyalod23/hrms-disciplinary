<div class="container-fluid px-4 py-4">  <div class="d-flex justify-content-between align-items-center mb-4">    <h4 class="fw-bold"><i class="bi bi-file-earmark-text"></i> NTE Case Details</h4>        <div>
      <a href="/nte/print/<%= caseData.id %>" class="btn btn-outline-primary" target="_blank"><i class="bi bi-printer"></i> Print NTE</a>
      <% if (caseData.status === 'Draft') { %>
        <a href="/nte/edit/<%= caseData.id %>" class="btn btn-outline-warning"><i class="bi bi-pencil"></i> Edit</a>
      <% } %>
      <a href="/nte" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
    </div>  </div>  <div class="row g-3">    <div class="col-md-8">      <div class="card border-0 shadow-sm mb-3">        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">          <h6 class="mb-0 fw-bold"><%= caseData.memo_number %></h6>          <span class="badge bg-<%= caseData.status === 'Draft' ? 'secondary' : caseData.status === 'Issued/Served' ? 'primary' : caseData.status === 'Replied' ? 'info' : caseData.status === 'Resolved' ? 'success' : 'dark' %> fs-6"><%= caseData.status %></span>        </div>        <div class="card-body">          <div class="row g-3">            <div class="col-md-6">              <p class="mb-1 text-muted small">Employee</p>              <p class="fw-medium"><%= caseData.employee_name %></p>            </div>            <div class="col-md-3">              <p class="mb-1 text-muted small">Position</p>              <p class="fw-medium"><%= caseData.position || 'N/A' %></p>            </div>            <div class="col-md-3">              <p class="mb-1 text-muted small">Project / Location</p>              <p class="fw-medium"><%= caseData.project_location || 'N/A' %></p>            </div>          </div>          <hr>          <div class="row g-3">            <div class="col-md-4">              <p class="mb-1 text-muted small">Memo No.</p>              <p class="fw-medium"><%= caseData.memo_number %></p>            </div>            <div class="col-md-4">              <p class="mb-1 text-muted small">Date</p>              <p class="fw-medium"><%= caseData.incident_date ? new Date(caseData.incident_date).toLocaleDateString() : 'N/A' %></p>            </div>          </div>
          <% if (caseData.nte_body) { %>
          <hr>
          <h6 class="fw-bold text-primary">NTE Letter Body (F-HRD-036 Rev 1)</h6>
          <div class="p-3 bg-light border rounded"><%= caseData.nte_body.replace(/\n/g, '<br>') %></div>
          <% } %>
          <% if (caseData.ir_report_number) { %>
          <hr>
          <div class="row g-3">
            <div class="col-md-4">
              <p class="mb-1 text-muted small">Linked Incident Report</p>
              <p class="fw-medium"><a href="/incidents/view/<%= caseData.incident_report_id %>"><%= caseData.ir_report_number %></a></p>
            </div>
          </div>
          <% } %>
          <hr>          <div class="row g-3">            <div class="col-md-4">              <p class="mb-1 text-muted small">Written by (Prepared By)</p>              <p class="fw-medium"><%= caseData.prepared_by || '--' %></p>            </div>          </div>          <hr>          <div class="row g-3">            <% if (caseData.date_received) { %>            <div class="col-md-3">              <p class="mb-1 text-muted small">Date Received</p>              <p class="fw-medium"><%= new Date(caseData.date_received).toLocaleDateString() %></p>            </div>            <% } %>            <% if (caseData.explanation_deadline) { %>            <div class="col-md-3">              <p class="mb-1 text-muted small">Explanation Deadline</p>              <p class="fw-medium"><%= new Date(caseData.explanation_deadline).toLocaleDateString() %></p>            </div>            <% } %>            <% if (caseData.date_explanation_submitted) { %>            <div class="col-md-3">              <p class="mb-1 text-muted small">Explanation Submitted</p>              <p class="fw-medium"><%= new Date(caseData.date_explanation_submitted).toLocaleDateString() %></p>            </div>            <% } %>            <% if (caseData.final_decision) { %>            <div class="col-md-3">              <p class="mb-1 text-muted small">Final Decision</p>              <span class="badge bg-<%= caseData.final_decision === 'Cleared' ? 'success' : caseData.final_decision === 'Written Warning' ? 'warning' : caseData.final_decision === 'Suspension' ? 'danger' : 'dark' %>"><%= caseData.final_decision %></span>            </div>            <% } %>          </div>          <% if (caseData.preventive_suspension == 1) { %>          <hr>          <h6 class="fw-bold text-danger">Preventive Suspension</h6>          <div class="row g-3">            <div class="col-md-3">              <p class="mb-1 text-muted small">Suspension Days</p>              <p class="fw-medium"><%= caseData.suspension_days || 'N/A' %></p>            </div>            <div class="col-md-3">              <p class="mb-1 text-muted small">Effective Date</p>              <p class="fw-medium"><%= caseData.suspension_effective_date ? new Date(caseData.suspension_effective_date).toLocaleDateString() : 'N/A' %></p>            </div>            <div class="col-md-3">              <p class="mb-1 text-muted small">Return to Work Date</p>              <p class="fw-medium"><%= caseData.suspension_return_date ? new Date(caseData.suspension_return_date).toLocaleDateString() : 'N/A' %></p>            </div>          </div>          <% } %>          <% if (caseData.employee_signed == 1 || caseData.refused_to_sign == 1) { %>          <hr>          <h6 class="fw-bold text-primary">Employee Acknowledgement</h6>          <div class="row g-3">            <% if (caseData.employee_signed == 1) { %>            <div class="col-md-3">              <p class="mb-1 text-muted small">Signed Date</p>              <p class="fw-medium"><%= caseData.date_signed ? new Date(caseData.date_signed).toLocaleDateString() : 'N/A' %></p>            </div>            <% } %>            <% if (caseData.refused_to_sign == 1) { %>            <div class="col-md-3">              <p class="mb-1 text-muted small text-danger">Refused to Sign</p>              <p class="fw-medium">Yes</p>            </div>            <div class="col-md-3">              <p class="mb-1 text-muted small">Witness</p>              <p class="fw-medium"><%= caseData.witness_name || '--' %> (<%= caseData.witness_position || '--' %>)</p>            </div>            <% } %>          </div>          <% } %>          <% if (caseData.employee_explanation) { %>          <hr>          <h6 class="fw-bold text-primary">Employee Explanation</h6>          <p><%= caseData.employee_explanation %></p>          <% } %>          <% if (caseData.resolution_date) { %>          <hr>          <div class="row g-3">            <div class="col-md-3">              <p class="mb-1 text-muted small">Resolution Date</p>              <p class="fw-medium"><%= new Date(caseData.resolution_date).toLocaleDateString() %></p>            </div>          </div>          <% } %>          <% if (caseData.remarks) { %>          <hr>          <p class="mb-1 text-muted small">Remarks</p>          <p><%= caseData.remarks %></p>          <% } %>          <small class="text-muted">Created by: <%= caseData.created_by_name || 'System' %> | <%= new Date(caseData.created_at).toLocaleString() %></small>        </div>      </div>    </div>    <div class="col-md-4">      <div class="card border-0 shadow-sm mb-3">        <div class="card-header bg-white py-3">          <h6 class="mb-0 fw-bold"><i class="bi bi-arrow-right-square"></i> Workflow Actions</h6>        </div>        <div class="card-body">          <% if (caseData.status === 'Draft') { %>          <form method="POST" action="/nte/issue/<%= caseData.id %>">            <h6 class="fw-bold text-primary">Issue / Serve NTE</h6>            <div class="mb-2">              <label class="form-label small">Date Received *</label>              <input type="date" name="date_received" class="form-control form-control-sm" required>            </div>            <div class="mb-2">              <label class="form-label small">Employee Signed?</label>              <div class="form-check">                <input type="checkbox" name="employee_signed" class="form-check-input" id="empSigned" value="1">                <label class="form-check-label small" for="empSigned">Yes, employee signed</label>              </div>            </div>            <div class="mb-2" id="signedDateGroup" style="display:none">              <label class="form-label small">Date Signed</label>              <input type="date" name="date_signed" class="form-control form-control-sm">            </div>            <div class="mb-2">              <div class="form-check">                <input type="checkbox" name="refused_to_sign" class="form-check-input" id="refusedSign" value="1">                <label class="form-check-label small text-danger" for="refusedSign">Employee refused to sign</label>              </div>            </div>            <div id="witnessGroup" style="display:none">              <div class="mb-2">                <label class="form-label small">Witness Name</label>                <input type="text" name="witness_name" class="form-control form-control-sm">              </div>              <div class="mb-2">                <label class="form-label small">Witness Position</label>                <input type="text" name="witness_position" class="form-control form-control-sm">              </div>            </div>            <button type="submit" class="btn btn-primary btn-sm w-100"><i class="bi bi-check-circle"></i> Issue NTE</button>          </form>          <hr>          <form method="POST" action="/nte/suspend/<%= caseData.id %>">            <h6 class="fw-bold text-danger">Preventive Suspension</h6>            <div class="mb-2">              <div class="form-check">                <input type="checkbox" name="preventive_suspension" class="form-check-input" id="prevSusp" value="1" <%= caseData.preventive_suspension == 1 ? 'checked' : '' %>>                <label class="form-check-label small" for="prevSusp">Place on Preventive Suspension</label>              </div>            </div>            <div id="suspDetails" style="display:<%= caseData.preventive_suspension == 1 ? 'block' : 'none' %>">              <div class="mb-2">                <label class="form-label small">Number of Days</label>                <input type="number" name="suspension_days" class="form-control form-control-sm" value="<%= caseData.suspension_days || '' %>" min="1">              </div>              <div class="mb-2">                <label class="form-label small">Effective Date</label>                <input type="date" name="suspension_effective_date" class="form-control form-control-sm" value="<%= caseData.suspension_effective_date || '' %>">              </div>              <div class="mb-2">                <label class="form-label small">Return to Work Date</label>                <input type="date" name="suspension_return_date" class="form-control form-control-sm" value="<%= caseData.suspension_return_date || '' %>">              </div>            </div>            <button type="submit" class="btn btn-outline-danger btn-sm w-100"><i class="bi bi-clock"></i> Update Suspension</button>          </form>          <% } %>          <% if (caseData.status === 'Issued/Served') { %>          <form method="POST" action="/nte/reply/<%= caseData.id %>">            <h6 class="fw-bold text-primary">Record Employee Reply</h6>            <div class="mb-2">              <label class="form-label small">Date Explanation Submitted *</label>              <input type="date" name="date_explanation_submitted" class="form-control form-control-sm" required>            </div>            <div class="mb-2">              <label class="form-label small">Employee Explanation</label>              <textarea name="employee_explanation" class="form-control form-control-sm" rows="4" placeholder="Enter the employee's written explanation..."></textarea>            </div>            <button type="submit" class="btn btn-info btn-sm w-100"><i class="bi bi-chat-dots"></i> Record Reply</button>          </form>          <hr>          <form method="POST" action="/nte/resolve/<%= caseData.id %>">            <h6 class="fw-bold text-success">Final Resolution</h6>            <div class="mb-2">              <label class="form-label small">Final Decision *</label>              <select name="final_decision" class="form-select form-select-sm" required>                <option value="">-- Select --</option>                <option value="Cleared">Cleared</option>                <option value="Written Warning">Written Warning</option>                <option value="Suspension">Suspension</option>                <option value="Termination">Termination</option>              </select>            </div>            <div class="mb-2">              <label class="form-label small">Resolution Date</label>              <input type="date" name="resolution_date" class="form-control form-control-sm">            </div>            <div class="mb-2">              <label class="form-label small">Remarks</label>              <textarea name="remarks" class="form-control form-control-sm" rows="2"></textarea>            </div>            <button type="submit" class="btn btn-success btn-sm w-100"><i class="bi bi-check2-all"></i> Resolve Case</button>          </form>          <% } %>          <% if (caseData.status === 'Replied') { %>          <form method="POST" action="/nte/resolve/<%= caseData.id %>">            <h6 class="fw-bold text-success">Final Resolution</h6>            <div class="mb-2">              <label class="form-label small">Final Decision *</label>              <select name="final_decision" class="form-select form-select-sm" required>                <option value="">-- Select --</option>                <option value="Cleared">Cleared</option>                <option value="Written Warning">Written Warning</option>                <option value="Suspension">Suspension</option>                <option value="Termination">Termination</option>              </select>            </div>            <div class="mb-2">              <label class="form-label small">Resolution Date</label>              <input type="date" name="resolution_date" class="form-control form-control-sm">            </div>            <div class="mb-2">              <label class="form-label small">Remarks</label>              <textarea name="remarks" class="form-control form-control-sm" rows="2"></textarea>            </div>            <button type="submit" class="btn btn-success btn-sm w-100"><i class="bi bi-check2-all"></i> Resolve Case</button>          </form>          <% } %>          <% if (caseData.status === 'Resolved') { %>          <form method="POST" action="/nte/close/<%= caseData.id %>">            <button type="submit" class="btn btn-dark btn-sm w-100"><i class="bi bi-lock"></i> Close Case</button>          </form>          <% } %>          <% if (caseData.status !== 'Closed' && caseData.status !== 'Resolved') { %>          <hr>          <form method="POST" action="/nte/suspend/<%= caseData.id %>">            <h6 class="fw-bold text-danger">Preventive Suspension</h6>            <div class="mb-2">              <div class="form-check">                <input type="checkbox" name="preventive_suspension" class="form-check-input" id="prevSusp2" value="1" <%= caseData.preventive_suspension == 1 ? 'checked' : '' %>>                <label class="form-check-label small" for="prevSusp2">Place on Preventive Suspension</label>              </div>            </div>            <div id="suspDetails2" style="display:<%= caseData.preventive_suspension == 1 ? 'block' : 'none' %>">              <div class="mb-2">                <label class="form-label small">Number of Days</label>                <input type="number" name="suspension_days" class="form-control form-control-sm" value="<%= caseData.suspension_days || '' %>" min="1">              </div>              <div class="mb-2">                <label class="form-label small">Effective Date</label>                <input type="date" name="suspension_effective_date" class="form-control form-control-sm" value="<%= caseData.suspension_effective_date || '' %>">              </div>              <div class="mb-2">                <label class="form-label small">Return to Work Date</label>                <input type="date" name="suspension_return_date" class="form-control form-control-sm" value="<%= caseData.suspension_return_date || '' %>">              </div>            </div>            <button type="submit" class="btn btn-outline-danger btn-sm w-100"><i class="bi bi-clock"></i> Update Suspension</button>          </form>          <% } %>          <% if (caseData.status === 'Closed') { %>          <div class="alert alert-secondary mb-0">            <i class="bi bi-check-circle"></i> This case is <strong>Closed</strong>. No further actions available.          </div>          <% } %>        </div>      </div>      <% if (caseData.status !== 'Closed') { %>      <div class="card border-0 shadow-sm">        <div class="card-header bg-white py-3">          <h6 class="mb-0 fw-bold text-danger"><i class="bi bi-trash"></i> Danger Zone</h6>        </div>        <div class="card-body">          <form method="POST" action="/nte/delete/<%= caseData.id %>" onsubmit="return confirm('Are you sure you want to delete this NTE case? This action cannot be undone.')">            <button type="submit" class="btn btn-outline-danger btn-sm w-100"><i class="bi bi-trash"></i> Delete Case</button>          </form>        </div>      </div>      <% } %>    </div>  </div></div><script>  const empSigned = document.getElementById('empSigned');  const refusedSign = document.getElementById('refusedSign');  const signedDateGroup = document.getElementById('signedDateGroup');  const witnessGroup = document.getElementById('witnessGroup');  if (empSigned) {    empSigned.addEventListener('change', function() {      signedDateGroup.style.display = this.checked ? 'block' : 'none';      if (this.checked && refusedSign) refusedSign.checked = false;      if (this.checked && witnessGroup) witnessGroup.style.display = 'none';    });  }  if (refusedSign) {    refusedSign.addEventListener('change', function() {      witnessGroup.style.display = this.checked ? 'block' : 'none';      if (this.checked && empSigned) empSigned.checked = false;      if (this.checked && signedDateGroup) signedDateGroup.style.display = 'none';    });  }  const prevSusp = document.getElementById('prevSusp');  if (prevSusp) {    prevSusp.addEventListener('change', function() {      document.getElementById('suspDetails').style.display = this.checked ? 'block' : 'none';    });  }  const prevSusp2 = document.getElementById('prevSusp2');  if (prevSusp2) {    prevSusp2.addEventListener('change', function() {      document.getElementById('suspDetails2').style.display = this.checked ? 'block' : 'none';    });  }</script>
