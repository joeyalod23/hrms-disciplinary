<div class="container-fluid px-4 py-4">  <div class="d-flex justify-content-between align-items-center mb-4">    <h4 class="fw-bold"><i class="bi bi-file-earmark-text"></i> NTE Cases</h4>    <a href="/nte/add" class="btn btn-primary"><i class="bi bi-plus-lg"></i> New NTE Case</a>  </div>  <div class="card border-0 shadow-sm">    <div class="card-body">      <form method="GET" class="row g-2 mb-3">        <div class="col-md-3">          <input type="text" name="search" class="form-control" placeholder="Search employee or memo #..." value="<%= search %>">        </div>        <div class="col-md-2">          <select name="status" class="form-select">            <option value="">All Status</option>            <option value="Draft" <%= status === 'Draft' ? 'selected' : '' %>>Draft</option>            <option value="Issued/Served" <%= status === 'Issued/Served' ? 'selected' : '' %>>Issued/Served</option>            <option value="Replied" <%= status === 'Replied' ? 'selected' : '' %>>Replied</option>            <option value="Resolved" <%= status === 'Resolved' ? 'selected' : '' %>>Resolved</option>            <option value="Closed" <%= status === 'Closed' ? 'selected' : '' %>>Closed</option>          </select>        </div>        <div class="col-md-1">          <button type="submit" class="btn btn-outline-primary w-100"><i class="bi bi-search"></i></button>        </div>      </form>      <div class="table-responsive">        <table class="table table-hover">          <thead class="table-dark">            <tr><th>Memo #</th><th>Employee</th><th>Status</th><th>Date Received</th><th>Deadline</th><th>Actions</th></tr>          </thead>          <tbody>            <% if (cases.length === 0) { %>              <tr><td colspan="6" class="text-center text-muted py-4">No NTE cases found</td></tr>            <% } else { %>              <% cases.forEach(c => { %>              <tr>                <td><a href="/nte/view/<%= c.id %>" class="text-decoration-none fw-medium"><%= c.memo_number %></a></td>                <td><%= c.employee_name %></td>                <td><span class="badge bg-<%= c.status === 'Draft' ? 'secondary' : c.status === 'Issued/Served' ? 'primary' : c.status === 'Replied' ? 'info' : c.status === 'Resolved' ? 'success' : 'dark' %>"><%= c.status %></span></td>                <td><%= c.date_received ? new Date(c.date_received).toLocaleDateString() : '--' %></td>                <td><%= c.explanation_deadline ? new Date(c.explanation_deadline).toLocaleDateString() : '--' %></td>                <td>                  <a href="/nte/view/<%= c.id %>" class="btn btn-sm btn-outline-info" title="View"><i class="bi bi-eye"></i></a>                  <a href="/nte/print/<%= c.id %>" class="btn btn-sm btn-outline-primary" target="_blank" title="Print NTE"><i class="bi bi-printer"></i></a>                  <a href="/nte/edit/<%= c.id %>" class="btn btn-sm btn-outline-warning" title="Edit"><i class="bi bi-pencil"></i></a>                </td>              </tr>              <% }) %>            <% } %>          </tbody>        </table>      </div>      <% if (pages > 1) { %>      <nav><ul class="pagination pagination-sm justify-content-center">        <% for (var i = 1; i <= pages; i++) { %>          <li class="page-item <%= i === page ? 'active' : '' %>">            <a class="page-link" href="?page=<%= i %><%= status ? '&status=' + status : '' %><%= search ? '&search=' + search : '' %>"><%= i %></a>          </li>        <% } %>      </ul></nav>      <% } %>    </div>  </div></div>
