<!DOCTYPE html><html lang="en"><head>  <meta charset="UTF-8">  <title>NTE - <%= caseData.memo_number %></title>  <style>    @page { size: letter; margin: 0.75in 0.75in 0.5in; }    * { margin: 0; padding: 0; box-sizing: border-box; }    body { font-family: 'Times New Roman', Times, serif; font-size: 12pt; line-height: 1.5; color: #000; padding: 20px; }    .header { text-align: center; margin-bottom: 20px; }    .header h1 { font-size: 14pt; font-weight: bold; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px; }    .header .sub { font-size: 11pt; }    .header .form-ref { font-size: 10pt; color: #555; margin-top: 2px; }    .hr-bold { border: none; border-top: 2px solid #000; margin: 6px 0; }    .hr-thin { border: none; border-top: 1px solid #000; margin: 4px 0; }    .field-row { display: flex; margin-bottom: 6px; align-items: baseline; }    .field-label { font-weight: bold; min-width: 120px; }    .field-label-sm { font-weight: bold; min-width: 80px; }    .field-value { border-bottom: 1px solid #000; flex: 1; padding: 0 4px; min-height: 22px; }    .nte-body { margin: 20px 0; padding: 10px 0; }    .nte-body p { margin-bottom: 12px; text-align: justify; text-indent: 40px; }    .signature-section { margin-top: 30px; display: flex; justify-content: space-between; }    .signature-box { width: 45%; }    .signature-line { border-top: 1px solid #000; margin-top: 50px; padding-top: 6px; text-align: center; font-size: 11pt; }    .attestation { margin-top: 20px; font-style: italic; font-size: 11pt; }    .footer { margin-top: 30px; font-size: 10pt; color: #555; text-align: center; border-top: 1px solid #ccc; padding-top: 8px; }    .btn-print { display: block; margin: 20px auto; padding: 10px 30px; font-size: 14px; cursor: pointer; }    @media print { .btn-print { display: none; } }  </style></head><body>  <button class="btn-print" onclick="window.print()"><i class="bi bi-printer"></i> Print / Save PDF</button>  <div class="header">    <h1>Notice to Explain</h1>    <div class="sub">F-HRD-036 Rev 1</div>    <hr class="hr-bold">  </div>  <div class="field-row">    <span class="field-label">NAME:</span>    <span class="field-value"><%= caseData.employee_name %></span>    <span style="width:30px"></span>    <span class="field-label" style="min-width:60px">DATE:</span>    <span class="field-value"><%= caseData.created_at ? new Date(caseData.created_at).toLocaleDateString() : '' %></span>  </div>  <div class="field-row">    <span class="field-label">POSITION:</span>    <span class="field-value"><%= caseData.position || 'N/A' %></span>    <span style="width:30px"></span>    <span class="field-label" style="min-width:60px">PROJECT:</span>    <span class="field-value"><%= caseData.project_location || 'Vail Land Development' %></span>  </div>  <hr class="hr-bold">  <% if (caseData.incident_report_id) { %>  <div class="field-row">    <span class="field-label">IR Reference:</span>    <span class="field-value"><%= caseData.ir_report_number || 'IR-' + caseData.incident_report_id %></span>  </div>  <hr class="hr-thin">  <% } %>  <div class="field-row">    <span class="field-label">Memo No.:</span>    <span class="field-value"><%= caseData.memo_number %></span>  </div>  <hr class="hr-bold">  <div class="nte-body">    <%= (caseData.nte_body || caseData.incident_description || '').replace(/\n/g, '<br>') %>  </div>  <hr class="hr-thin">  <div class="attestation">    I hereby attest that all of the information above is true and accurate to the best of my knowledge.  </div>  <div class="signature-section">    <div class="signature-box">      <div class="signature-line">        <strong>Written by:</strong><br>        <%= caseData.prepared_by || '_________________________' %><br>        Signature Over Printed Name      </div>    </div>    <div class="signature-box">      <div class="signature-line">        <strong>Received by:</strong><br>        <%= caseData.reviewed_by || '_________________________' %><br>        Admin Asst./HR Personnel      </div>    </div>  </div>  <div class="footer">    F-HRD-036 Rev 1 | <%= caseData.memo_number %>  </div></body></html>
