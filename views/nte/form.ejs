<div class="container-fluid px-4 py-4">  <div class="d-flex justify-content-between align-items-center mb-4">    <h4 class="fw-bold"><i class="bi bi-<%= caseData ? 'pencil' : 'plus' %>-square"></i> <%= caseData ? 'Edit NTE Case' : 'New NTE Case' %></h4>    <a href="/nte" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>  </div>  <div class="card border-0 shadow-sm">    <div class="card-body">      <form method="POST" action="<%= caseData ? '/nte/edit/' + caseData.id : '/nte/add' %>">        <div class="row g-3">          <div class="col-12"><h6 class="fw-bold text-primary border-bottom pb-2"><i class="bi bi-person-badge"></i> Employee Details</h6></div>          <div class="col-md-4">            <label class="form-label">NAME *</label>            <% if (caseData) { %>              <input type="hidden" name="employee_id" value="<%= caseData.employee_id %>">              <input type="text" class="form-control" value="<%= caseData.employee_name %>" readonly>              <input type="hidden" name="employee_name" value="<%= caseData.employee_name %>">            <% } else { %>              <div style="position:relative;">                <input type="text" class="form-control" id="employeeSearch" placeholder="Type employee name or ID..." autocomplete="off" required>                <input type="hidden" name="employee_id" id="employeeId">                <input type="hidden" name="employee_name" id="employeeName">                <div id="employeeResults" style="position:absolute;top:100%;left:0;right:0;z-index:1000;max-height:250px;overflow-y:auto;background:#fff;border:1px solid #ccc;border-radius:4px;display:none;box-shadow:0 4px 8px rgba(0,0,0,.1);"></div>              </div>            <% } %>          </div>          <div class="col-md-4">            <label class="form-label">POSITION</label>            <input type="text" name="position" class="form-control" value="<%= caseData ? caseData.position : '' %>">          </div>          <div class="col-md-4">            <label class="form-label">PROJECT</label>            <input type="text" name="project_location" class="form-control" value="<%= caseData ? caseData.project_location : 'Vail Land Development' %>">          </div>          <div class="col-md-4">            <label class="form-label">DATE *</label>            <input type="date" name="incident_date" class="form-control" value="<%= caseData ? caseData.incident_date : new Date().toISOString().split('T')[0] %>" required>          </div>          <div class="col-12"><h6 class="fw-bold text-primary border-bottom pb-2 mt-2"><i class="bi bi-file-text"></i> NTE Content</h6></div>          <div class="col-12">            <label class="form-label">Notice to Explain Body *</label>            <textarea name="nte_body" class="form-control" rows="12" placeholder="Write the full NTE letter content here. Include violation details, incident facts, company policies violated, and the directive for the employee to explain.&#10;&#10;Tip: You can also upload an existing document below to auto-fill this field."><%= caseData ? caseData.nte_body : '' %></textarea>          </div>          <% if (!caseData) { %>          <div class="col-12">            <div class="card border-0 shadow-sm bg-light p-3">              <div class="d-flex align-items-center justify-content-between">                <div>                  <h6 class="fw-bold mb-1"><i class="bi bi-file-earmark-text"></i> Transcribe from Doc/PDF</h6>                  <small class="text-muted">Upload an existing NTE document to auto-fill the letter body</small>                </div>                <div class="d-flex gap-2">                  <input type="file" id="transcribeFile" accept=".pdf,.docx,.jpg,.jpeg,.png,.bmp,.tiff,.tif" class="form-control form-control-sm" style="width:auto">                  <button type="button" id="transcribeBtn" class="btn btn-sm btn-info" onclick="transcribeDocument()"><i class="bi bi-magic"></i> Transcribe</button>                </div>              </div>              <div id="transcribeStatus" class="mt-2 small" style="display:none"></div>            </div>          </div>          <% } %>          <div class="col-12"><h6 class="fw-bold text-primary border-bottom pb-2 mt-2"><i class="bi bi-pencil-square"></i> Signatories</h6></div>          <div class="col-md-4">            <label class="form-label">Written by (Prepared By)</label>            <input type="text" name="prepared_by" class="form-control" value="<%= caseData ? caseData.prepared_by : '' %>">          </div>        </div>        <div class="mt-4">          <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> <%= caseData ? 'Update NTE Case' : 'Create NTE Case (Draft)' %></button>          <a href="/nte" class="btn btn-outline-secondary">Cancel</a>        </div>      </form>    </div>  </div></div><% if (!caseData) { %><script>  const employees = <%- JSON.stringify(employees || []) %>;  const empSearch = document.getElementById('employeeSearch');  const empId = document.getElementById('employeeId');  const empName = document.getElementById('employeeName');  const empResults = document.getElementById('employeeResults');  empSearch.addEventListener('input', function() {    const q = this.value.toLowerCase();    if (!q) { empResults.style.display = 'none'; empId.value = ''; empName.value = ''; return; }    const matches = employees.filter(e => e.full_name.toLowerCase().includes(q) || e.employee_id.includes(q)).slice(0, 20);    if (matches.length === 0) { empResults.style.display = 'none'; return; }    empResults.innerHTML = matches.map(e =>      '<div class="emp-item" data-id="' + e.id + '" data-name="' + e.full_name + '" data-position="' + (e.position || '') + '" style="padding:8px 12px;cursor:pointer;border-bottom:1px solid #eee;font-size:14px;">' +        '<strong>' + e.employee_id + '</strong> - ' + e.full_name + ' <span style="color:#666;font-size:12px;">(' + e.department + ')</span>' +      '</div>'    ).join('');    empResults.style.display = 'block';  });  empResults.addEventListener('click', function(e) {    const item = e.target.closest('.emp-item');    if (!item) return;    empId.value = item.dataset.id;    empName.value = item.dataset.name;    empSearch.value = item.dataset.name;    empResults.style.display = 'none';    const posInput = document.querySelector('input[name="position"]');    if (posInput && !posInput.value) posInput.value = item.dataset.position;  });  document.addEventListener('click', function(e) {    if (!e.target.closest('#employeeSearch') && !e.target.closest('#employeeResults')) empResults.style.display = 'none';  });  empSearch.addEventListener('blur', function() { setTimeout(() => { if (!document.activeElement.closest('#employeeResults')) empResults.style.display = 'none'; }, 200); });  function transcribeDocument() {    var fileInput = document.getElementById('transcribeFile');    var btn = document.getElementById('transcribeBtn');    var status = document.getElementById('transcribeStatus');    if (!fileInput.files || !fileInput.files[0]) {      status.style.display = 'block';      status.className = 'mt-2 small text-danger';      status.textContent = 'Please select a file first.';      return;    }    var fd = new FormData();    fd.append('document', fileInput.files[0]);    btn.disabled = true;    btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Transcribing...';    status.style.display = 'block';    status.className = 'mt-2 small text-info';    status.textContent = 'Processing document, please wait...';    fetch('/nte/transcribe', { method: 'POST', body: fd }).then(function(r) { if (!r.ok) { return r.text().then(function(t) { throw new Error(t.substring(0, 300)); }); } return r.json(); }).then(function(data) {      if (data.error) {        status.className = 'mt-2 small text-danger';        status.textContent = data.error;        btn.disabled = false;        btn.innerHTML = '<i class="bi bi-magic"></i> Transcribe';        return;      }      var text = data.text || '';      var nteBody = document.querySelector('textarea[name="nte_body"]');      if (nteBody && text) {        nteBody.value = text;        nteBody.focus();      }      status.className = 'mt-2 small text-success';      status.textContent = 'Transcription complete! Text extracted (' + text.length + ' chars) and filled into NTE Body.';      btn.disabled = false;      btn.innerHTML = '<i class="bi bi-magic"></i> Transcribe';    }).catch(function(err) {      status.className = 'mt-2 small text-danger';      status.textContent = 'Upload failed: ' + err.message;      btn.disabled = false;      btn.innerHTML = '<i class="bi bi-magic"></i> Transcribe';    });  }</script><% } %>
