<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css" rel="stylesheet">
<style>
.tab-pane { padding-top: 1.5rem; }
</style>
<div class="container-fluid px-4 py-4">
<h2 class="fw-bold mb-4"><i class="bi bi-gear me-2"></i>System Settings</h2>

<ul class="nav nav-tabs" id="settingsTabs">
<li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-security">Security (2FA)</button></li>
<li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-email">Email (SMTP)</button></li>
<li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-notify">Notifications</button></li>
</ul>

<div class="tab-content">
<div class="tab-pane fade show active" id="tab-security">
<div class="card border-0 shadow-sm">
<div class="card-header bg-white py-3"><h6 class="mb-0 fw-bold"><i class="bi bi-shield-lock me-2"></i>Two-Factor Authentication</h6></div>
<div class="card-body">
<% if (user.totp_enabled) { %>
<div class="alert alert-success"><i class="bi bi-check-circle me-2"></i>2FA is currently enabled.</div>
<button class="btn btn-danger" onclick="disable2FA()"><i class="bi bi-shield-slash me-1"></i> Disable 2FA</button>
<% } else { %>
<button class="btn btn-primary" onclick="setup2FA()"><i class="bi bi-qr-code me-1"></i> Setup 2FA</button>
<div id="qrcodeContainer" class="mt-3 text-center" style="display:none"></div>
<div id="verifyContainer" class="mt-3" style="display:none">
<input type="text" id="totpToken" class="form-control d-inline-block w-auto" placeholder="Enter 6-digit code" maxlength="6">
<button class="btn btn-success ms-2" onclick="verify2FA()">Verify</button>
<p class="text-muted small mt-2">Scan the QR code with Google Authenticator or similar, then enter the 6-digit code.</p>
</div>
<% } %>
</div>
</div>
</div>

<div class="tab-pane fade" id="tab-email">
<div class="card border-0 shadow-sm">
<div class="card-header bg-white py-3"><h6 class="mb-0 fw-bold"><i class="bi bi-envelope me-2"></i>SMTP Configuration</h6></div>
<div class="card-body">
<form onsubmit="saveSMTP(event)">
<div class="row g-3">
<div class="col-md-6">
<label class="form-label">SMTP Host</label>
<input type="text" class="form-control" id="smtpHost" value="<%= settings.smtp_host || '' %>" placeholder="smtp.gmail.com">
</div>
<div class="col-md-3">
<label class="form-label">Port</label>
<input type="number" class="form-control" id="smtpPort" value="<%= settings.smtp_port || '587' %>">
</div>
<div class="col-md-3">
<label class="form-label">Secure</label>
<select class="form-select" id="smtpSecure"><option value="0" <%= settings.smtp_secure !== 'true' ? 'selected' : '' %>>No (TLS)</option><option value="1" <%= settings.smtp_secure === 'true' ? 'selected' : '' %>>Yes (SSL)</option></select>
</div>
<div class="col-md-6">
<label class="form-label">Username</label>
<input type="text" class="form-control" id="smtpUser" value="<%= settings.smtp_user || '' %>">
</div>
<div class="col-md-6">
<label class="form-label">Password</label>
<input type="password" class="form-control" id="smtpPass" value="<%= settings.smtp_pass || '' %>">
</div>
<div class="col-12">
<label class="form-label">From Email</label>
<input type="email" class="form-control" id="smtpFrom" value="<%= settings.smtp_from || '' %>" placeholder="sitevigil@lvledesma.com">
</div>
</div>
 <div class="mt-4 d-flex gap-2">
<button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i> Save SMTP Settings</button>
<button type="button" class="btn btn-outline-success" onclick="testSMTP()"><i class="bi bi-send me-1"></i> Send Test Email</button>
</div>
</form>
</div>
</div>
</div>
</div>
</div>

<div class="tab-pane fade" id="tab-notify">
<div class="card border-0 shadow-sm">
<div class="card-header bg-white py-3"><h6 class="mb-0 fw-bold"><i class="bi bi-bell me-2"></i>Notification Recipients</h6></div>
<div class="card-body">
<p class="text-muted small">Configure email addresses for automatic workflow notifications.</p>
<form onsubmit="saveNotify(event)">
<div class="row g-3">
<div class="col-md-6">
<label class="form-label">Project Manager <span class="text-muted small">(Acknowledgement)</span></label>
<input type="email" class="form-control" id="notifyPmEmail" value="<%= settings.notify_pm_email || '' %>" placeholder="pm@company.com">
</div>
<div class="col-md-6">
<label class="form-label">HR Deputy Officer <span class="text-muted small">(Review &amp; Final Memo)</span></label>
<input type="email" class="form-control" id="notifyHrDeputyEmail" value="<%= settings.notify_hr_deputy_email || '' %>" placeholder="hr.deputy@company.com">
</div>
<div class="col-md-6">
<label class="form-label">HR Head / Supervisor <span class="text-muted small">(Final Approval)</span></label>
<input type="email" class="form-control" id="notifyHrHeadEmail" value="<%= settings.notify_hr_head_email || '' %>" placeholder="hr.head@company.com">
</div>
</div>
<div class="mt-4">
<button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i> Save Notification Settings</button>
</div>
</form>
</div>
</div>
</div>
</div>

<%- include('../partials/toast') %>
<script>
async function setup2FA() {
  const res = await fetch('/settings/totp/setup', { method: 'POST' });
  const data = await res.json();
  document.getElementById('qrcodeContainer').innerHTML = `<img src="${data.qr}" style="max-width:220px" class="img-fluid"><p class="mt-2 small text-muted">Secret: <code>${data.secret}</code></p>`;
  document.getElementById('qrcodeContainer').style.display = 'block';
  document.getElementById('verifyContainer').style.display = 'block';
}
async function verify2FA() {
  const token = document.getElementById('totpToken').value;
  if (token.length !== 6) return showToast('Enter 6-digit code', 'error');
  const res = await fetch('/settings/totp/verify', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ token }) });
  if (!res.ok) return showToast('Invalid code', 'error');
  showToast('2FA enabled successfully', 'success');
  location.reload();
}
async function disable2FA() {
  if (!confirm('Disable 2FA?')) return;
  await fetch('/settings/totp/disable', { method: 'POST' });
  location.reload();
}
async function saveSMTP(e) {
  e.preventDefault();
  const payload = {
    host: document.getElementById('smtpHost').value,
    port: parseInt(document.getElementById('smtpPort').value),
    secure: document.getElementById('smtpSecure').value === '1',
    user: document.getElementById('smtpUser').value,
    pass: document.getElementById('smtpPass').value,
    from: document.getElementById('smtpFrom').value,
  };
  const res = await fetch('/settings/smtp', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
  if (!res.ok) return showToast('Failed to save', 'error');
  showToast('SMTP settings saved', 'success');
}
async function saveNotify(e) {
  e.preventDefault();
  const payload = {
    pm_email: document.getElementById('notifyPmEmail').value,
    hr_deputy_email: document.getElementById('notifyHrDeputyEmail').value,
    hr_head_email: document.getElementById('notifyHrHeadEmail').value,
  };
  const res = await fetch('/settings/notify', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
  if (!res.ok) return showToast('Failed to save', 'error');
  showToast('Notification settings saved', 'success');
}
async function testSMTP() {
  const to = document.getElementById('smtpFrom').value;
  if (!to) return showToast('Enter a From Email first', 'error');
  const res = await fetch('/settings/smtp/test', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ to }) });
  if (!res.ok) return showToast('Email failed. Check SMTP settings.', 'error');
  showToast('Test email sent to ' + to, 'success');
}
</script>
