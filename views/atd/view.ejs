<div class="container-fluid py-3">  <nav aria-label="breadcrumb">    <ol class="breadcrumb">      <li class="breadcrumb-item"><a href="/atd">ATD Records</a></li>      <li class="breadcrumb-item active">ATD Detail</li>    </ol>  </nav>  <div class="row">    <div class="col-lg-8">      <div class="card shadow-sm mb-3">        <div class="card-header bg-primary text-white d-flex align-items-center">          <i class="bi bi-receipt me-2"></i>          <h5 class="mb-0">ATD #<%= record.atdNumber || record._id %></h5>        </div>        <div class="card-body">          <div class="row mb-2">            <div class="col-sm-4 fw-bold">Employee:</div>            <div class="col-sm-8"><%= record.employee ? record.employee.firstName + ' ' + record.employee.lastName : (record.employeeName || 'N/A') %></div>          </div>          <div class="row mb-2">            <div class="col-sm-4 fw-bold">ID Number:</div>            <div class="col-sm-8"><%= record.employee ? (record.employee.employeeId || record.employee.idNumber) : (record.employeeId || '-') %></div>          </div>          <div class="row mb-2">            <div class="col-sm-4 fw-bold">Period:</div>            <div class="col-sm-8">              <%= record.startDate instanceof Date ? record.startDate.toLocaleDateString() : record.startDate %>              to              <%= record.endDate instanceof Date ? record.endDate.toLocaleDateString() : (record.endDate || 'Present') %>            </div>          </div>          <div class="row mb-2">            <div class="col-sm-4 fw-bold">Weekly Deduction:</div>            <div class="col-sm-8">PHP <%= record.weeklyDeduction ? Number(record.weeklyDeduction).toLocaleString() : '0.00' %></div>          </div>          <div class="row mb-2">            <div class="col-sm-4 fw-bold">Total Deduction:</div>            <div class="col-sm-8">PHP <%= record.totalDeduction ? Number(record.totalDeduction).toLocaleString() : '0.00' %></div>          </div>          <div class="row mb-0">            <div class="col-sm-4 fw-bold">Status:</div>            <div class="col-sm-8">              <span class="badge bg-<%= record.status === 'Active' ? 'primary' : record.status === 'Completed' ? 'success' : 'secondary' %>">                <%= record.status || 'Active' %>              </span>            </div>          </div>          <% if (record.remarks) { %>          <div class="row mb-0 mt-2">            <div class="col-sm-4 fw-bold">Remarks:</div>            <div class="col-sm-8"><%= record.remarks %></div>          </div>          <% } %>        </div>      </div>      <div class="card shadow-sm">        <div class="card-header bg-secondary text-white">          <i class="bi bi-list-check me-1"></i> Deduction Items        </div>        <div class="card-body p-0">          <div class="table-responsive">            <table class="table table-striped table-hover mb-0">              <thead class="table-light">                <tr>                  <th>Item</th>                  <th class="text-end">Amount</th>                  <th class="text-center">Paid?</th>                </tr>              </thead>              <tbody>                <% if (items && items.length) { %>                  <% items.forEach(function(item) { %>                    <tr>                      <td><%= item.name || item.customName || 'N/A' %></td>                      <td class="text-end">PHP <%= Number(item.amount).toLocaleString() %></td>                      <td class="text-center">                        <% if (item.paid === true || item.paid === 'true') { %>                          <span class="badge bg-success"><i class="bi bi-check-circle"></i> Paid</span>                        <% } else { %>                          <span class="badge bg-warning text-dark"><i class="bi bi-clock"></i> Unpaid</span>                        <% } %>                      </td>                    </tr>                  <% }) %>                <% } else { %>                  <tr><td colspan="3" class="text-center text-muted">No items recorded.</td></tr>                <% } %>              </tbody>              <tfoot class="table-light">                <tr>                  <th class="text-end">Total:</th>                  <th class="text-end">PHP <%= record.totalDeduction ? Number(record.totalDeduction).toLocaleString() : '0.00' %></th>                  <th></th>                </tr>              </tfoot>            </table>          </div>        </div>      </div>    </div>    <div class="col-lg-4">      <div class="card shadow-sm">        <div class="card-header bg-secondary text-white">          <i class="bi bi-pencil-square me-1"></i> Update Status        </div>        <div class="card-body">          <form action="/atd/<%= record._id %>/status?_method=PUT" method="POST">            <div class="mb-3">              <label for="status" class="form-label">Status</label>              <select class="form-select" id="status" name="status">                <option value="Active" <%= record.status === 'Active' ? 'selected' : '' %>>Active</option>                <option value="Completed" <%= record.status === 'Completed' ? 'selected' : '' %>>Completed</option>                <option value="Cancelled" <%= record.status === 'Cancelled' ? 'selected' : '' %>>Cancelled</option>              </select>            </div>            <button type="submit" class="btn btn-primary w-100"><i class="bi bi-check-circle me-1"></i> Update</button>          </form>        </div>        <div class="card-footer d-flex justify-content-between">          <a href="/atd" class="btn btn-sm btn-outline-secondary">Back</a>          <a href="/atd/<%= record._id %>/edit" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i> Edit</a>        </div>      </div>    </div>  </div></div>