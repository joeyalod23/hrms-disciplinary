<div class="container-fluid py-3">  <nav aria-label="breadcrumb">    <ol class="breadcrumb">      <li class="breadcrumb-item"><a href="/atd">ATD Records</a></li>      <li class="breadcrumb-item active"><%= record && record._id ? 'Edit ATD' : 'New ATD' %></li>    </ol>  </nav>  <div class="card shadow-sm">    <div class="card-header bg-primary text-white d-flex align-items-center">      <i class="bi bi-receipt me-2"></i>      <h5 class="mb-0"><%= record && record._id ? 'Edit ATD' : 'New ATD Record' %></h5>    </div>    <div class="card-body">      <form action="/atd<%= record && record._id ? '/' + record._id + '?_method=PUT' : '' %>" method="POST">        <div class="row g-3 mb-3">          <div class="col-md-6">            <label for="employee" class="form-label">Employee</label>            <select class="form-select" id="employee" name="employee" required>              <option value="">-- Select Employee --</option>              <% if (employees && employees.length) { %>                <% employees.forEach(function(e) { %>                  <option value="<%= e._id %>" <%= record && record.employee && (record.employee._id === e._id || record.employee.toString() === e._id.toString()) ? 'selected' : '' %>>                    <%= e.firstName %> <%= e.lastName %> - <%= e.employeeId || e.idNumber %>                  </option>                <% }) %>              <% } %>            </select>          </div>          <div class="col-md-3">            <label for="weeklyDeduction" class="form-label">Weekly Deduction</label>            <div class="input-group">              <span class="input-group-text">PHP</span>              <input type="number" step="0.01" class="form-control" id="weeklyDeduction" name="weeklyDeduction"                     value="<%= record ? record.weeklyDeduction : '' %>" required>            </div>          </div>          <div class="col-md-3">            <label for="totalDeduction" class="form-label">Total Deduction</label>            <div class="input-group">              <span class="input-group-text">PHP</span>              <input type="number" step="0.01" class="form-control" id="totalDeduction" name="totalDeduction"                     value="<%= record ? record.totalDeduction : '' %>" readonly>            </div>          </div>        </div>        <div class="row g-3 mb-3">          <div class="col-md-6">            <label for="startDate" class="form-label">Start Date</label>            <input type="date" class="form-control" id="startDate" name="startDate"                   value="<%= record && record.startDate ? (record.startDate instanceof Date ? record.startDate.toISOString().split('T')[0] : record.startDate) : today %>" required>          </div>          <div class="col-md-6">            <label for="endDate" class="form-label">End Date</label>            <input type="date" class="form-control" id="endDate" name="endDate"                   value="<%= record && record.endDate ? (record.endDate instanceof Date ? record.endDate.toISOString().split('T')[0] : record.endDate) : '' %>">          </div>        </div>        <hr>        <div class="d-flex justify-content-between align-items-center mb-2">          <h6 class="mb-0"><i class="bi bi-list-check me-1"></i> Deduction Items</h6>          <button type="button" class="btn btn-sm btn-outline-primary" id="addItemBtn">            <i class="bi bi-plus-circle"></i> Add Item          </button>        </div>        <div class="table-responsive" id="itemsContainer">          <table class="table table-bordered table-sm" id="itemsTable">            <thead class="table-light">              <tr>                <th style="width:55%">Item Name</th>                <th style="width:25%">Amount</th>                <th style="width:15%">Paid?</th>                <th style="width:5%"></th>              </tr>            </thead>            <tbody>              <% if (record && record.items && record.items.length) { %>                <% record.items.forEach(function(item, i) { %>                  <tr class="item-row">                    <td>                      <select class="form-select form-select-sm item-name-select" name="items[<%= i %>][name]">                        <option value="">-- Custom --</option>                        <option value="Safety Shoes" <%= item.name === 'Safety Shoes' ? 'selected' : '' %>>Safety Shoes</option>                        <option value="Uniform" <%= item.name === 'Uniform' ? 'selected' : '' %>>Uniform</option>                        <option value="Hard Hat" <%= item.name === 'Hard Hat' ? 'selected' : '' %>>Hard Hat</option>                        <option value="Safety Boots" <%= item.name === 'Safety Boots' ? 'selected' : '' %>>Safety Boots</option>                        <option value="Raincoat" <%= item.name === 'Raincoat' ? 'selected' : '' %>>Raincoat</option>                        <option value="Medical" <%= item.name === 'Medical' ? 'selected' : '' %>>Medical</option>                      </select>                      <input type="text" class="form-control form-control-sm mt-1 item-name-custom" name="items[<%= i %>][customName]"                             placeholder="Custom item name" value="<%= !['Safety Shoes','Uniform','Hard Hat','Safety Boots','Raincoat','Medical'].includes(item.name) ? item.name : '' %>" style="display:<%= ['Safety Shoes','Uniform','Hard Hat','Safety Boots','Raincoat','Medical'].includes(item.name) ? 'none' : 'block' %>">                    </td>                    <td>                      <input type="number" step="0.01" class="form-control form-control-sm item-amount" name="items[<%= i %>][amount]"                             value="<%= item.amount %>" required>                    </td>                    <td>                      <select class="form-select form-select-sm" name="items[<%= i %>][paid]">                        <option value="false" <%= item.paid === false || item.paid === 'false' ? 'selected' : '' %>>No</option>                        <option value="true" <%= item.paid === true || item.paid === 'true' ? 'selected' : '' %>>Yes</option>                      </select>                    </td>                    <td class="text-center"><button type="button" class="btn btn-sm btn-outline-danger remove-item"><i class="bi bi-x"></i></button></td>                  </tr>                <% }) %>              <% } %>            </tbody>          </table>        </div>        <div class="mb-3">          <label for="remarks" class="form-label">Remarks</label>          <textarea class="form-control" id="remarks" name="remarks" rows="2"><%= record ? record.remarks : '' %></textarea>        </div>        <div class="d-flex justify-content-end">          <a href="/atd" class="btn btn-secondary me-2">Cancel</a>          <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i> Save</button>        </div>      </form>    </div>  </div></div><script>let itemIndex = <%= (record && record.items) ? record.items.length : 0 %>;document.getElementById('addItemBtn').addEventListener('click', function() {  const tbody = document.querySelector('#itemsTable tbody');  const row = document.createElement('tr');  row.className = 'item-row';  row.innerHTML = `    <td>      <select class="form-select form-select-sm item-name-select" name="items[${itemIndex}][name]">        <option value="">-- Custom --</option>        <option value="Safety Shoes">Safety Shoes</option>        <option value="Uniform">Uniform</option>        <option value="Hard Hat">Hard Hat</option>        <option value="Safety Boots">Safety Boots</option>        <option value="Raincoat">Raincoat</option>        <option value="Medical">Medical</option>      </select>      <input type="text" class="form-control form-control-sm mt-1 item-name-custom" name="items[${itemIndex}][customName]"             placeholder="Custom item name" style="display:none">    </td>    <td><input type="number" step="0.01" class="form-control form-control-sm item-amount" name="items[${itemIndex}][amount]" required></td>    <td>      <select class="form-select form-select-sm" name="items[${itemIndex}][paid]">        <option value="false">No</option>        <option value="true">Yes</option>      </select>    </td>    <td class="text-center"><button type="button" class="btn btn-sm btn-outline-danger remove-item"><i class="bi bi-x"></i></button></td>  `;  tbody.appendChild(row);  itemIndex++;});document.querySelector('#itemsTable tbody').addEventListener('click', function(e) {  if (e.target.closest('.remove-item')) {    e.target.closest('tr').remove();    calcTotal();  }});document.querySelector('#itemsTable tbody').addEventListener('change', function(e) {  if (e.target.classList.contains('item-amount') || e.target.classList.contains('item-name-select')) {    calcTotal();  }  if (e.target.classList.contains('item-name-select')) {    const customInput = e.target.closest('td').querySelector('.item-name-custom');    customInput.style.display = e.target.value === '' ? 'block' : 'none';    if (e.target.value !== '') customInput.value = '';  }});function calcTotal() {  let total = 0;  document.querySelectorAll('.item-amount').forEach(function(inp) {    const val = parseFloat(inp.value);    if (!isNaN(val)) total += val;  });  document.getElementById('totalDeduction').value = total.toFixed(2);}</script>