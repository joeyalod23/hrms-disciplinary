<div class="container-fluid py-3">  <div class="d-flex justify-content-between align-items-center mb-3">    <h4 class="mb-0"><i class="bi bi-cash-stack me-2"></i>ATD Records</h4>    <div>      <a href="/atd/export?search=<%= search || '' %>&status=<%= status || '' %>" class="btn btn-success btn-sm me-1"><i class="bi bi-download"></i> Export CSV</a>      <a href="/atd/add" class="btn btn-primary btn-sm"><i class="bi bi-plus-circle"></i> Add ATD</a>    </div>  </div>  <div class="card shadow-sm mb-3">    <div class="card-body">      <form method="GET" action="/atd" class="row g-2">        <div class="col-md-5">          <input type="text" class="form-control" name="search" placeholder="Search by employee name or ID..." value="<%= search || '' %>">        </div>        <div class="col-md-3">          <select class="form-select" name="status">            <option value="">All Status</option>            <option value="Active" <%= status === 'Active' ? 'selected' : '' %>>Active</option>            <option value="Completed" <%= status === 'Completed' ? 'selected' : '' %>>Completed</option>            <option value="Cancelled" <%= status === 'Cancelled' ? 'selected' : '' %>>Cancelled</option>          </select>        </div>        <div class="col-md-2">          <button type="submit" class="btn btn-outline-primary w-100"><i class="bi bi-search"></i> Search</button>        </div>        <div class="col-md-2">          <a href="/atd" class="btn btn-outline-secondary w-100">Clear</a>        </div>      </form>    </div>  </div>  <div class="card shadow-sm">    <div class="card-body p-0">      <div class="table-responsive">        <table class="table table-striped table-hover mb-0">          <thead class="table-light">            <tr>              <th>ATD #</th>              <th>Employee</th>              <th>ID #</th>              <th class="text-end">Total Deduction</th>              <th class="text-end">Weekly</th>              <th>Period</th>              <th>Status</th>              <th class="text-end">Actions</th>            </tr>          </thead>          <tbody>            <% if (records && records.length) { %>              <% records.forEach(function(r) { %>                <tr>                  <td><strong><%= r.atdNumber || r._id %></strong></td>                  <td><%= r.employee ? r.employee.firstName + ' ' + r.employee.lastName : (r.employeeName || 'N/A') %></td>                  <td><%= r.employee ? (r.employee.employeeId || r.employee.idNumber) : (r.employeeId || '-') %></td>                  <td class="text-end"><%= r.totalDeduction ? Number(r.totalDeduction).toLocaleString() : '0.00' %></td>                  <td class="text-end"><%= r.weeklyDeduction ? Number(r.weeklyDeduction).toLocaleString() : '0.00' %></td>                  <td>                    <%= r.startDate instanceof Date ? r.startDate.toLocaleDateString() : r.startDate %>                    -                    <%= r.endDate instanceof Date ? r.endDate.toLocaleDateString() : (r.endDate || 'Present') %>                  </td>                  <td>                    <span class="badge bg-<%= r.status === 'Active' ? 'primary' : r.status === 'Completed' ? 'success' : 'secondary' %>">                      <%= r.status || 'Active' %>                    </span>                  </td>                  <td class="text-end">                    <a href="/atd/<%= r._id %>" class="btn btn-sm btn-outline-info" title="View"><i class="bi bi-eye"></i></a>                  </td>                </tr>              <% }) %>            <% } else { %>              <tr><td colspan="8" class="text-center text-muted">No ATD records found.</td></tr>            <% } %>          </tbody>        </table>      </div>    </div>    <% if (pages > 1) { %>    <div class="card-footer">      <nav>        <ul class="pagination justify-content-center mb-0">          <li class="page-item <%= page <= 1 ? 'disabled' : '' %>">            <a class="page-link" href="/atd?page=<%= page - 1 %>&limit=<%= limit %>&search=<%= search || '' %>&status=<%= status || '' %>">Previous</a>          </li>          <% for (var p = 1; p <= pages; p++) { %>            <li class="page-item <%= p === page ? 'active' : '' %>">              <a class="page-link" href="/atd?page=<%= p %>&limit=<%= limit %>&search=<%= search || '' %>&status=<%= status || '' %>"><%= p %></a>            </li>          <% } %>          <li class="page-item <%= page >= pages ? 'disabled' : '' %>">            <a class="page-link" href="/atd?page=<%= page + 1 %>&limit=<%= limit %>&search=<%= search || '' %>&status=<%= status || '' %>">Next</a>          </li>        </ul>      </nav>    </div>    <% } %>  </div></div>