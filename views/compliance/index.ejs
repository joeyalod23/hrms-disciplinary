<div class="container-fluid px-4 py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-calendar-check"></i> Compliance Calendar</h4>
    <div>
      <form method="POST" action="/compliance/auto-generate" style="display:inline">
        <button type="submit" class="btn btn-outline-info btn-sm" onclick="return confirm('Auto-generate compliance items from contracts and evaluations?')"><i class="bi bi-magic"></i> Auto-Generate</button>
      </form>
      <button class="btn btn-primary btn-sm ms-2" onclick="showCompliancePanel()"><i class="bi bi-plus-lg"></i> Add Item</button>
    </div>
  </div>



  <%
    var pendingItems = items.filter(function(i) { return i.status === 'Pending'; });
    var overdueItems = items.filter(function(i) { return i.status === 'Overdue'; });
    var completedItems = items.filter(function(i) { return i.status === 'Completed'; });
    var today = new Date(); today.setHours(0,0,0,0);
    function dueClass(status, due_date) {
      if (status === 'Completed') return '';
      var due = new Date(due_date + 'T00:00:00');
      var diff = Math.ceil((due - today) / (1000 * 60 * 60 * 24));
      if (diff < 0) return 'text-danger';
      if (diff <= 7) return 'text-warning';
      return '';
    }
    function priorityBadge(p) {
      if (p === 'Urgent') return 'danger';
      if (p === 'High') return 'warning';
      if (p === 'Normal') return 'primary';
      return 'info';
    }
  %>

  <div class="row g-3" style="min-height: 400px;">
    <div class="col-md-4">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-header bg-warning text-white fw-bold py-2 d-flex justify-content-between align-items-center">
          <span><i class="bi bi-clock"></i> Pending</span>
          <span class="badge bg-light text-dark"><%= pendingItems.length %></span>
        </div>
        <div class="card-body p-2" style="max-height: calc(100vh - 360px); overflow-y: auto;">
          <% if (pendingItems.length === 0) { %>
            <p class="text-muted text-center py-4 mb-0 small">No pending items</p>
          <% } else { %>
            <% pendingItems.forEach(function(item) { %>
              <div class="border-bottom py-2 px-1 task-row" role="button" data-item='<%- JSON.stringify(item) %>' data-bs-toggle="modal" data-bs-target="#viewModal">
                <div class="d-flex justify-content-between align-items-start">
                  <div class="flex-grow-1 min-w-0 me-2">
                    <div class="fw-semibold text-truncate small"><%= item.title %></div>
                    <div class="d-flex align-items-center gap-2 mt-1">
                      <span class="badge bg-secondary" style="font-size:0.6rem;"><%= item.module %></span>
                      <span class="<%= dueClass(item.status, item.due_date) %>" style="font-size:0.7rem;"><i class="bi bi-calendar"></i> <%= new Date(item.due_date).toLocaleDateString() %></span>
                    </div>
                  </div>
                  <span class="badge bg-<%= priorityBadge(item.priority) %>" style="font-size:0.6rem;"><%= item.priority %></span>
                </div>
              </div>
            <% }) %>
          <% } %>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-header bg-danger text-white fw-bold py-2 d-flex justify-content-between align-items-center">
          <span><i class="bi bi-exclamation-triangle"></i> Overdue</span>
          <span class="badge bg-light text-dark"><%= overdueItems.length %></span>
        </div>
        <div class="card-body p-2" style="max-height: calc(100vh - 360px); overflow-y: auto;">
          <% if (overdueItems.length === 0) { %>
            <p class="text-muted text-center py-4 mb-0 small">No overdue items</p>
          <% } else { %>
            <% overdueItems.forEach(function(item) { %>
              <div class="border-bottom py-2 px-1 task-row" role="button" data-item='<%- JSON.stringify(item) %>' data-bs-toggle="modal" data-bs-target="#viewModal">
                <div class="d-flex justify-content-between align-items-start">
                  <div class="flex-grow-1 min-w-0 me-2">
                    <div class="fw-semibold text-truncate small"><%= item.title %></div>
                    <div class="d-flex align-items-center gap-2 mt-1">
                      <span class="badge bg-secondary" style="font-size:0.6rem;"><%= item.module %></span>
                      <span class="<%= dueClass(item.status, item.due_date) %>" style="font-size:0.7rem;"><i class="bi bi-calendar"></i> <%= new Date(item.due_date).toLocaleDateString() %></span>
                    </div>
                  </div>
                  <span class="badge bg-<%= priorityBadge(item.priority) %>" style="font-size:0.6rem;"><%= item.priority %></span>
                </div>
              </div>
            <% }) %>
          <% } %>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-header bg-success text-white fw-bold py-2 d-flex justify-content-between align-items-center">
          <span><i class="bi bi-check-circle"></i> Completed</span>
          <span class="badge bg-light text-dark"><%= completedItems.length %></span>
        </div>
        <div class="card-body p-2" style="max-height: calc(100vh - 360px); overflow-y: auto;">
          <% if (completedItems.length === 0) { %>
            <p class="text-muted text-center py-4 mb-0 small">No completed items</p>
          <% } else { %>
            <% completedItems.forEach(function(item) { %>
              <div class="border-bottom py-2 px-1 task-row" role="button" data-item='<%- JSON.stringify(item) %>' data-bs-toggle="modal" data-bs-target="#viewModal">
                <div class="d-flex justify-content-between align-items-start">
                  <div class="flex-grow-1 min-w-0 me-2">
                    <div class="fw-semibold text-truncate small"><%= item.title %></div>
                    <div class="d-flex align-items-center gap-2 mt-1">
                      <span class="badge bg-secondary" style="font-size:0.6rem;"><%= item.module %></span>
                      <span class="text-muted" style="font-size:0.7rem;"><i class="bi bi-calendar-check"></i> <%= item.completed_date ? new Date(item.completed_date).toLocaleDateString() : '' %></span>
                    </div>
                  </div>
                  <span class="badge bg-<%= priorityBadge(item.priority) %>" style="font-size:0.6rem;"><%= item.priority %></span>
              </div>
            <% }) %>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<div id="addItemPanel" class="d-none" style="position:fixed;bottom:24px;right:24px;z-index:999;width:520px;max-width:calc(100vw - 48px);">
  <div class="bg-white rounded-xl shadow-2xl border border-gray-200 p-5" style="max-height:calc(100vh - 100px);overflow-y:auto;">
    <div class="d-flex align-items-center justify-content-between mb-3">
      <h5 class="fw-bold mb-0"><i class="bi bi-plus-circle"></i> Add Compliance Item</h5>
      <button type="button" onclick="hideCompliancePanel()" class="btn-close"></button>
    </div>
    <form method="POST" action="/compliance/add">
      <div class="row g-3">
        <div class="col-12">
          <label class="form-label">Title *</label>
          <input type="text" name="title" class="form-control" required>
        </div>
        <div class="col-12">
          <label class="form-label">Description</label>
          <textarea name="description" class="form-control" rows="3"></textarea>
        </div>
        <div class="col-md-4">
          <label class="form-label">Module *</label>
          <select name="module" class="form-select" required>
            <option value="">-- Select --</option>
            <option value="Contract">Contract</option>
            <option value="Evaluation">Evaluation</option>
            <option value="Medical">Medical</option>
            <option value="License">License</option>
            <option value="Other">Other</option>
          </select>
        </div>
        <div class="col-md-4">
          <label class="form-label">Reference ID</label>
          <input type="number" name="reference_id" class="form-control">
        </div>
        <div class="col-md-4">
          <label class="form-label">Due Date *</label>
          <input type="date" name="due_date" class="form-control" required>
        </div>
        <div class="col-md-4">
          <label class="form-label">Priority</label>
          <select name="priority" class="form-select">
            <option value="Low">Low</option>
            <option value="Normal" selected>Normal</option>
            <option value="High">High</option>
            <option value="Urgent">Urgent</option>
          </select>
        </div>
      </div>
      <div class="d-flex justify-content-end mt-4 gap-2">
        <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Add Item</button>
      </div>
    </form>
  </div>
</div>

<div class="modal fade" id="viewModal" tabindex="-1">
<div class="modal-dialog modal-lg">
<div class="modal-content">
<div class="modal-header">
<h5 class="modal-title fw-bold"><i class="bi bi-info-circle"></i> Compliance Item Details</h5>
<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>
<div class="modal-body">
<div class="row">
<div class="col-md-8">
<table class="table table-bordered mb-0">
<tr><th style="width:140px">ID</th><td id="view-id"></td></tr>
<tr><th>Title</th><td id="view-title" class="fw-bold"></td></tr>
<tr><th>Description</th><td id="view-description"></td></tr>
<tr><th>Module</th><td id="view-module"></td></tr>
<tr><th>Reference ID</th><td id="view-reference_id"></td></tr>
<tr><th>Due Date</th><td id="view-due_date"></td></tr>
<tr><th>Priority</th><td id="view-priority"></td></tr>
<tr><th>Status</th><td id="view-status"></td></tr>
<tr><th>Completed Date</th><td id="view-completed_date"></td></tr>
<tr><th>Completed By</th><td id="view-completed_by"></td></tr>
<tr><th>Created At</th><td id="view-created_at"></td></tr>
</table>
</div>
<div class="col-md-4">
<div class="card border shadow-sm" id="statusCard">
<div class="card-header bg-light fw-bold py-2"><i class="bi bi-pencil-square"></i> Update Status</div>
<div class="card-body">
<form method="POST" action="/compliance/status">
<input type="hidden" name="id" id="statusItemId">
<select name="status" class="form-select form-select-sm mb-2">
<option value="Pending">Pending</option>
<option value="Overdue">Overdue</option>
<option value="Completed">Completed</option>
</select>
<button type="submit" class="btn btn-primary btn-sm w-100"><i class="bi bi-save"></i> Save</button>
</form>
</div>
</div>
</div>
</div>
</div>
<div class="modal-footer">
<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
</div>
</div>
</div>
</div>

<script>
function showCompliancePanel(){document.getElementById('addItemPanel').classList.remove('d-none')}
function hideCompliancePanel(){document.getElementById('addItemPanel').classList.add('d-none')}
document.addEventListener('DOMContentLoaded',function(){
  var viewModal=document.getElementById('viewModal');
  if(viewModal){
    viewModal.addEventListener('show.bs.modal',function(event){
      var item;
      try{item=JSON.parse(event.relatedTarget.getAttribute('data-item'))}catch(e){return}
      var fields={id:item.id,title:item.title,description:item.description||'--',module:item.module,reference_id:item.reference_id||'--',due_date:new Date(item.due_date).toLocaleDateString(),priority:item.priority,status:item.status,completed_date:item.completed_date?new Date(item.completed_date).toLocaleDateString():'--',completed_by:item.completed_by||'--',created_at:item.created_at||'--'};
      Object.keys(fields).forEach(function(k){var el=document.getElementById('view-'+k);if(el){el.textContent=fields[k]}});
      var statusEl=document.getElementById('view-status');
      if(statusEl){var s=item.status;var badge='bg-'+(s==='Completed'?'success':s==='Overdue'?'danger':'secondary');statusEl.innerHTML='<span class="badge '+badge+'">'+s+'</span>'}
      var priorityEl=document.getElementById('view-priority');
      if(priorityEl){var p=item.priority;var pBadge='bg-'+(p==='Urgent'?'danger':p==='High'?'warning':p==='Normal'?'primary':'info');priorityEl.innerHTML='<span class="badge '+pBadge+'">'+p+'</span>'}
      document.getElementById('statusItemId').value=item.id;
      var sel=document.querySelector('#statusCard select[name=status]');if(sel){sel.value=item.status}
      var statusCard=document.getElementById('statusCard');
      if(statusCard){statusCard.style.display=item.status==='Completed'?'none':'block'}

    })
  }
})
</script>
