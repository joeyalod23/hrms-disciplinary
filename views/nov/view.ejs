<div class="container-fluid px-4 py-4">  <div class="d-flex justify-content-between align-items-center mb-4">    <h4 class="fw-bold"><i class="bi bi-file-earmark-text"></i> Notice of Violation</h4>    <div class="d-flex gap-2"><a href="/nov/pdf/<%= nov.id %>" class="btn btn-outline-danger" target="_blank"><i class="bi bi-file-pdf"></i> Download PDF</a><a href="/nov" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a></div>  </div>  <div class="card border-0 shadow-sm mb-3">    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">      <h6 class="mb-0 fw-bold"><%= nov.case_number %></h6>      <span class="badge bg-<%= nov.status === 'Draft' ? 'secondary' : nov.status === 'Submitted to Main Office' ? 'warning' : nov.status === 'Reviewed' ? 'info' : 'success' %> fs-6"><%= nov.status %></span>    </div>    <div class="card-body">      <h6 class="fw-bold text-primary border-bottom pb-1 mb-3"><i class="bi bi-exclamation-triangle"></i> Linked Incident Report</h6>      <div class="row g-3">        <div class="col-md-3">          <p class="mb-1 text-muted small">Report #</p>          <p class="fw-medium"><a href="/incidents/view/<%= nov.incident_report_id %>"><%= nov.ir_number %></a></p>        </div>        <div class="col-md-3">          <p class="mb-1 text-muted small">Alleged Violator</p>          <p class="fw-medium"><%= nov.alleged_violator_name %></p>        </div>        <div class="col-md-3">          <p class="mb-1 text-muted small">Incident Date</p>          <p class="fw-medium"><%= nov.incident_date ? new Date(nov.incident_date).toLocaleDateString() : 'N/A' %></p>        </div>        <div class="col-md-3">          <p class="mb-1 text-muted small">Incident Type</p>          <p class="fw-medium"><%= nov.incident_type || 'N/A' %></p>        </div>      </div>      <h6 class="fw-bold text-primary border-bottom pb-1 mb-3 mt-4"><i class="bi bi-pencil-square"></i> Findings & Recommendations</h6>      <div class="row g-3">        <div class="col-12">          <p class="mb-1 text-muted small">Findings (Site HR Assessment)</p>          <p><%= nov.findings || '<em class="text-muted">No findings recorded yet</em>' %></p>        </div>        <div class="col-12">          <p class="mb-1 text-muted small">Recommended Action</p>          <p><%= nov.recommended_action || '<em class="text-muted">No recommendation yet</em>' %></p>        </div>      </div>      <% if (nov.main_office_notes) { %>      <h6 class="fw-bold text-primary border-bottom pb-1 mb-3 mt-4"><i class="bi bi-building"></i> Main Office Review</h6>      <div class="row g-3">        <div class="col-12">          <p class="mb-1 text-muted small">Review Notes</p>          <p><%= nov.main_office_notes %></p>        </div>      </div>      <% } %>      <h6 class="fw-bold text-primary border-bottom pb-1 mb-3 mt-4"><i class="bi bi-clock-history"></i> Status Timeline</h6>      <div class="row g-3">        <div class="col-md-3">          <p class="mb-0 small text-muted">Drafted</p>          <small><%= new Date(nov.created_at).toLocaleString() %></small>        </div>        <% if (nov.submitted_to_main_office_date) { %>        <div class="col-md-3">          <p class="mb-0 small text-muted">Submitted to Main Office</p>          <small><%= new Date(nov.submitted_to_main_office_date).toLocaleDateString() %></small>        </div>        <% } %>        <% if (nov.reviewed_by_main_office_date) { %>        <div class="col-md-3">          <p class="mb-0 small text-muted">Reviewed by Main Office</p>          <small><%= new Date(nov.reviewed_by_main_office_date).toLocaleDateString() %></small>        </div>        <% } %>        <% if (nov.returned_to_site_date) { %>        <div class="col-md-3">          <p class="mb-0 small text-muted">Returned to Site</p>          <small><%= new Date(nov.returned_to_site_date).toLocaleDateString() %></small>        </div>        <% } %>      </div>      <small class="text-muted mt-3 d-block">Created by: <%= nov.created_by_name || 'System' %> | <%= new Date(nov.created_at).toLocaleString() %></small>    </div>  </div>  <div class="card border-0 shadow-sm">    <div class="card-header bg-white py-3">      <h6 class="mb-0 fw-bold"><i class="bi bi-arrow-right-square"></i> Workflow Actions</h6>    </div>    <div class="card-body">      <% if (nov.status === 'Draft') { %>      <p class="text-muted small">Submit this Notice of Violation to Main Office for review.</p>      <form method="POST" action="/nov/submit/<%= nov.id %>">        <button type="submit" class="btn btn-warning"><i class="bi bi-send"></i> Submit to Main Office</button>      </form>      <% } %>      <% if (nov.status === 'Submitted to Main Office') { %>      <p class="text-muted small">Record the Main Office's review decision and findings.</p>      <form method="POST" action="/nov/review/<%= nov.id %>">        <div class="mb-2">          <label class="form-label small">Main Office Review Notes</label>          <textarea name="main_office_notes" class="form-control" rows="4" placeholder="Main Office findings, decision, and instructions for Site HR..."></textarea>        </div>        <button type="submit" class="btn btn-info"><i class="bi bi-check2"></i> Record Review & Send Back to Site</button>      </form>      <% } %>      <% if (nov.status === 'Reviewed') { %>      <p class="text-muted small">Return this to Site HR so they can proceed with serving the NTE to the employee.</p>      <form method="POST" action="/nov/return/<%= nov.id %>">        <button type="submit" class="btn btn-success"><i class="bi bi-arrow-return-right"></i> Return to Site</button>      </form>      <% } %>      <% if (nov.status === 'Returned to Site') { %>      <div class="alert alert-success">        <i class="bi bi-check-circle"></i> NoV has been returned to Site. You can now issue the <strong>Notice to Explain (F-HRD-036 Rev 0)</strong> to the employee.        <a href="/incidents/view/<%= nov.incident_report_id %>" class="btn btn-primary btn-sm mt-2"><i class="bi bi-send"></i> Go to Incident to Issue NTE</a>      </div>      <% } %>    </div>  </div></div>
