<div class="container-fluid px-4 py-4">  <div class="d-flex justify-content-between align-items-center mb-4">    <h4 class="fw-bold"><i class="bi bi-file-earmark-text"></i> Notice of Violation</h4>    <div>      <a href="/incidents" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back to Incidents</a>    </div>  </div>  <div class="card border-0 shadow-sm">    <div class="card-body">      <form method="GET" class="row g-2 mb-3">        <div class="col-md-4">          <input type="text" name="search" class="form-control" placeholder="Search case #, violator, IR #..." value="<%= search %>">        </div>        <div class="col-md-2">          <select name="status" class="form-select">            <option value="">All Status</option>            <option value="Draft" <%= status === 'Draft' ? 'selected' : '' %>>Draft</option>            <option value="Submitted to Main Office" <%= status === 'Submitted to Main Office' ? 'selected' : '' %>>Submitted to Main Office</option>            <option value="Reviewed" <%= status === 'Reviewed' ? 'selected' : '' %>>Reviewed</option>            <option value="Returned to Site" <%= status === 'Returned to Site' ? 'selected' : '' %>>Returned to Site</option>          </select>        </div>        <div class="col-md-1">          <button type="submit" class="btn btn-outline-primary w-100"><i class="bi bi-search"></i></button>        </div>      </form>      <div class="table-responsive">        <table class="table table-hover">          <thead class="table-dark">            <tr><th>Case #</th><th>IR Reference</th><th>Alleged Violator</th><th>Status</th><th>Date Created</th><th>PDF</th><th>Actions</th></tr>          </thead>          <tbody>            <% if (reports.length === 0) { %>              <tr><td colspan="7" class="text-center text-muted py-4">No Notice of Violation records found</td></tr>            <% } else { %>              <% reports.forEach(n => { %>              <tr>                <td><a href="/nov/view/<%= n.id %>" class="text-decoration-none fw-medium"><%= n.case_number %></a></td>                <td><%= n.ir_number || 'N/A' %></td>                <td><%= n.alleged_violator_name || 'N/A' %></td>                <td><span class="badge bg-<%= n.status === 'Draft' ? 'secondary' : n.status === 'Submitted to Main Office' ? 'warning' : n.status === 'Reviewed' ? 'info' : 'success' %>"><%= n.status %></span></td>                <td><%= new Date(n.created_at).toLocaleDateString() %></td>                <td><a href="/nov/pdf/<%= n.id %>" target="_blank" class="btn btn-sm btn-outline-danger" title="Download PDF"><i class="bi bi-file-pdf"></i></a></td>                <td><a href="/nov/view/<%= n.id %>" class="btn btn-sm btn-outline-info"><i class="bi bi-eye"></i></a></td>              </tr>              <% }) %>            <% } %>          </tbody>        </table>      </div>      <% if (pages > 1) { %>      <nav><ul class="pagination pagination-sm justify-content-center">        <% for (var i = 1; i <= pages; i++) { %>          <li class="page-item <%= i === page ? 'active' : '' %>">            <a class="page-link" href="?page=<%= i %><%= status ? '&status=' + status : '' %><%= search ? '&search=' + search : '' %>"><%= i %></a>          </li>        <% } %>      </ul></nav>      <% } %>    </div>  </div></div>
