<div class="container-fluid px-4 py-4">  <div class="d-flex justify-content-between align-items-center mb-4">    <h4 class="fw-bold"><i class="bi bi-file-earmark-text"></i> Create Notice of Violation</h4>    <div>      <a href="/incidents/view/<%= ir.id %>" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back to IR</a>    </div>  </div>  <div class="row g-3">    <div class="col-md-5">      <div class="card border-0 shadow-sm">        <div class="card-header bg-white py-3">          <h6 class="mb-0 fw-bold"><i class="bi bi-exclamation-triangle"></i> Based on Incident Report</h6>        </div>        <div class="card-body">          <p class="mb-1 text-muted small">Report #</p>          <p class="fw-medium"><%= ir.report_number %></p>          <p class="mb-1 text-muted small">Alleged Violator</p>          <p class="fw-medium"><%= ir.alleged_violator_name %></p>          <p class="mb-1 text-muted small">Craft/Position</p>          <p class="fw-medium"><%= ir.craft_position || 'N/A' %></p>          <p class="mb-1 text-muted small">Incident Date</p>          <p class="fw-medium"><%= new Date(ir.incident_date).toLocaleDateString() %></p>          <p class="mb-1 text-muted small">Date Reported</p>          <p class="fw-medium"><%= new Date(ir.date_reported).toLocaleDateString() %></p>          <p class="mb-1 text-muted small">Incident Type</p>          <p class="fw-medium"><%= ir.incident_type || 'N/A' %></p>          <p class="mb-1 text-muted small">Narrative</p>          <p><%= ir.narrative_description %></p>        </div>      </div>    </div>    <div class="col-md-7">      <div class="card border-0 shadow-sm">        <div class="card-header bg-white py-3">          <h6 class="mb-0 fw-bold"><i class="bi bi-pencil-square"></i> Site HR Assessment</h6>        </div>        <div class="card-body">          <form method="POST" action="/nov/add">            <input type="hidden" name="incident_report_id" value="<%= ir.id %>">            <div class="mb-3">              <label class="form-label">Findings <small class="text-muted">(Site HR's assessment of the incident)</small></label>              <textarea name="findings" class="form-control" rows="5" required placeholder="Describe the findings based on the incident report..."></textarea>            </div>            <div class="mb-3">              <label class="form-label">Recommended Action <small class="text-muted">(Proposed disciplinary action)</small></label>              <select name="recommended_action" class="form-select">                <option value="">-- Select Recommended Action --</option>                <option value="Written Reprimand">Written Reprimand</option>                <option value="Final Written Warning">Final Written Warning</option>                <option value="Suspension">Suspension</option>                <option value="Termination">Termination</option>                <option value="Fine / Deduction">Fine / Deduction</option>                <option value="Other">Other</option>              </select>            </div>            <div class="mt-4">              <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Create NoV as Draft</button>              <a href="/incidents/view/<%= ir.id %>" class="btn btn-outline-secondary">Cancel</a>            </div>          </form>        </div>      </div>    </div>  </div></div>
