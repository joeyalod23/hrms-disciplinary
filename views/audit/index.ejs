<div class="container-fluid px-4 py-4">  <div class="d-flex justify-content-between align-items-center mb-4">    <h4 class="fw-bold"><i class="bi bi-journal-text"></i> Audit Trail</h4>    <% if (user.role === 'admin') { %>      <a href="/audit/clear" class="btn btn-outline-danger" onclick="return confirm('Clear all audit logs older than 90 days?')"><i class="bi bi-trash"></i> Clear Old Logs (>90 days)</a>    <% } %>  </div>  <div class="card border-0 shadow-sm">    <div class="card-body">      <form method="GET" class="row g-2 mb-3">        <div class="col-md-3">          <select name="module" class="form-select">            <option value="">All Modules</option>            <% modules.forEach(m => { %>              <option value="<%= m %>" <%= module === m ? 'selected' : '' %>><%= m %></option>            <% }) %>          </select>        </div>        <div class="col-md-4">          <input type="text" name="search" class="form-control" placeholder="Search by username, action, or details..." value="<%= search %>">        </div>        <div class="col-md-1">          <button type="submit" class="btn btn-outline-primary w-100"><i class="bi bi-search"></i></button>        </div>      </form>      <div class="table-responsive">        <table class="table table-hover table-sm">          <thead class="table-dark">            <tr><th>Timestamp</th><th>Username</th><th>Action</th><th>Module</th><th>Reference ID</th><th>Details</th><th>IP Address</th></tr>          </thead>          <tbody>            <% if (logs.length === 0) { %>              <tr><td colspan="7" class="text-center text-muted py-4">No audit logs found</td></tr>            <% } else { %>              <% logs.forEach(log => { %>              <tr>                <td><small><%= new Date(log.created_at).toLocaleString() %></small></td>                <td><%= log.username || 'N/A' %></td>                <td><%= log.action %></td>                <td><span class="badge bg-secondary"><%= log.module %></span></td>                <td><%= log.reference_id || '—' %></td>                <td><small class="text-muted"><%= log.details || '' %></small></td>                <td><small class="text-muted"><%= log.ip_address || '—' %></small></td>              </tr>              <% }) %>            <% } %>          </tbody>        </table>      </div>      <% if (pages > 1) { %>      <nav><ul class="pagination pagination-sm justify-content-center">        <% for (var i = 1; i <= pages; i++) { %>          <li class="page-item <%= i === page ? 'active' : '' %>">            <a class="page-link" href="?page=<%= i %><%= module ? '&module=' + module : '' %><%= search ? '&search=' + search : '' %>"><%= i %></a>          </li>        <% } %>      </ul></nav>      <% } %>      <small class="text-muted">Showing page <%= page %> of <%= pages %> (<%= total %> total entries)</small>    </div>  </div></div>