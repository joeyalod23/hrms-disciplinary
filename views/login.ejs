<!DOCTYPE html><html lang="en"><head>  <meta charset="UTF-8">  <meta name="viewport" content="width=device-width, initial-scale=1.0">  <title>HRMS - Login</title>  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css" rel="stylesheet">  <style>    body { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); min-height: 100vh; display: flex; align-items: center; }    .card { border: none; border-radius: 1rem; box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.3); }    .card-header { background: #0b1a3a; color: white; border-radius: 1rem 1rem 0 0 !important; padding: 0; text-align: center; overflow: hidden; }    .login-logo { width: 100%; display: block; }    .card-body { padding: 2rem; }    .btn-primary { background: #0f3460; border: none; padding: 0.6rem; }    .btn-primary:hover { background: #1a1a2e; }    .form-control:focus { border-color: #0f3460; box-shadow: 0 0 0 0.2rem rgba(15,52,96,0.25); }    .badge-site { position: absolute; top: -8px; right: -8px; font-size: 0.6rem; }  </style></head><body>  <div class="container">    <div class="row justify-content-center">      <div class="col-md-5">        <div class="card position-relative">          <span class="badge bg-danger badge-site">v2.0</span>          <div class="card-header p-0">            <img src="/images/lv-logo.svg" alt="L.V. Ledesma Construction, Inc." class="login-logo img-fluid">          </div>          <div class="card-body">            <% if (typeof error !== 'undefined' && error) { %>              <div class="alert alert-danger"><i class="bi bi-exclamation-triangle"></i> <%= error %></div>            <% } %>            <form method="POST" action="/login">              <div class="mb-3">                <label class="form-label"><i class="bi bi-person"></i> Username</label>                <input type="text" name="username" class="form-control" required autofocus>              </div>              <div class="mb-3">                <label class="form-label"><i class="bi bi-lock"></i> Password</label>                <input type="password" name="password" class="form-control" required>              </div>              <button type="submit" class="btn btn-primary w-100">Sign In</button>            </form>          </div>        </div>      </div>    </div>  </div></body></html>