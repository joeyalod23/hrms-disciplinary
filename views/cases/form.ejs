<div class="container-fluid px-4 py-4">  <div class="d-flex justify-content-between align-items-center mb-4">    <h4 class="fw-bold"><i class="bi bi-<%= caseData ? 'pencil' : 'plus' %>-square"></i> <%= caseData ? 'Edit Case' : 'New Disciplinary Case' %></h4>    <a href="/cases" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>  </div>  <div class="card border-0 shadow-sm">    <div class="card-body">      <form method="POST" action="<%= caseData ? '/cases/edit/' + caseData.id : '/cases/add' %>">        <div class="row g-3">          <div class="col-12"><h6 class="fw-bold text-primary border-bottom pb-2"><i class="bi bi-file-earmark-text"></i> Case Information (Main Office)</h6></div>          <div class="col-md-3">            <label class="form-label">Memo No. *</label>            <input type="text" name="memo_number" class="form-control" value="<%= caseData ? caseData.memo_number : '' %>" placeholder="From Main Office" required>          </div>          <div class="col-md-3">            <label class="form-label">Linked Incident Report</label>            <select name="incident_report_id" class="form-select">              <option value="">-- None --</option>              <% (incidentReports || []).forEach(ir => { %>                <option value="<%= ir.id %>" <%= caseData && caseData.incident_report_id === ir.id ? 'selected' : '' %>><%= ir.report_number %> - <%= ir.alleged_violator_name %></option>              <% }) %>            </select>          </div>                    <div class="col-md-3">
            <label class="form-label">Employee *</label>
            <% if (caseData) { %>
              <input type="hidden" name="employee_id" value="<%= caseData.employee_id %>">
              <input type="text" class="form-control" value="<%= caseData.employee_name || '' %>" readonly>
            <% } else { %>
              <div style="position:relative;">
                <input type="text" class="form-control" id="employeeSearch" placeholder="Type employee name or ID..." autocomplete="off" required>
                <input type="hidden" name="employee_id" id="employeeId">
                <input type="hidden" name="employee_name" id="employeeName">
                <div id="employeeResults" style="position:absolute;top:100%;left:0;right:0;z-index:1000;max-height:250px;overflow-y:auto;background:#fff;border:1px solid #ccc;border-radius:4px;display:none;box-shadow:0 4px 8px rgba(0,0,0,.1);"></div>
              </div>
            <% } %>
          </div>          <div class="col-md-3">            <label class="form-label">Offense Category</label>            <select name="offense_category_id" class="form-select">              <option value="">-- Select --</option>              <% offenses.forEach(o => { %>                <option value="<%= o.id %>" <%= caseData && caseData.offense_category_id === o.id ? 'selected' : '' %>><%= o.name %> (<%= o.severity %>)</option>              <% }) %>            </select>          </div>          <div class="col-12"><h6 class="fw-bold text-primary border-bottom pb-2 mt-2"><i class="bi bi-exclamation-triangle"></i> Violation Details</h6></div>          <div class="col-md-4">            <label class="form-label">Violation Classification</label>            <select name="violation_classification" class="form-select">              <option value="">-- Select --</option>              <option value="Smoking Violation" <%= caseData && caseData.violation_classification === 'Smoking Violation' ? 'selected' : '' %>>Smoking Violation</option>              <option value="Insubordination" <%= caseData && caseData.violation_classification === 'Insubordination' ? 'selected' : '' %>>Insubordination</option>              <option value="AWOL" <%= caseData && caseData.violation_classification === 'AWOL' ? 'selected' : '' %>>AWOL</option>              <option value="Dishonesty" <%= caseData && caseData.violation_classification === 'Dishonesty' ? 'selected' : '' %>>Dishonesty</option>              <option value="Property Damage/Misuse" <%= caseData && caseData.violation_classification === 'Property Damage/Misuse' ? 'selected' : '' %>>Property Damage/Misuse</option>              <option value="Negligence of Duty" <%= caseData && caseData.violation_classification === 'Negligence of Duty' ? 'selected' : '' %>>Negligence of Duty</option>              <option value="Inappropriate Behavior" <%= caseData && caseData.violation_classification === 'Inappropriate Behavior' ? 'selected' : '' %>>Inappropriate Behavior</option>              <option value="Physical Harm" <%= caseData && caseData.violation_classification === 'Physical Harm' ? 'selected' : '' %>>Physical Harm</option>              <option value="Other" <%= caseData && caseData.violation_classification === 'Other' ? 'selected' : '' %>>Other</option>            </select>          </div>          <div class="col-md-2">            <label class="form-label">Incident Date *</label>            <input type="date" name="incident_date" class="form-control" value="<%= caseData ? caseData.incident_date : '' %>" required>          </div>          <div class="col-md-2">            <label class="form-label">Report Date *</label>            <input type="date" name="report_date" class="form-control" value="<%= caseData ? caseData.report_date : '' %>" required>          </div>          <div class="col-md-4">            <label class="form-label">Status</label>            <select name="status" class="form-select" <%= caseData ? '' : 'disabled' %>>              <option value="Open" <%= caseData && caseData.status === 'Open' ? 'selected' : '' %>>Open</option>              <option value="Under Investigation" <%= caseData && caseData.status === 'Under Investigation' ? 'selected' : '' %>>Under Investigation</option>              <option value="For Hearing" <%= caseData && caseData.status === 'For Hearing' ? 'selected' : '' %>>For Hearing</option>              <option value="Resolved" <%= caseData && caseData.status === 'Resolved' ? 'selected' : '' %>>Resolved</option>              <option value="Dismissed" <%= caseData && caseData.status === 'Dismissed' ? 'selected' : '' %>>Dismissed</option>              <option value="Closed" <%= caseData && caseData.status === 'Closed' ? 'selected' : '' %>>Closed</option>            </select>          </div>          <div class="col-12">            <label class="form-label">Violation Details <small class="text-muted">(describe what violation from Main Office memo)</small></label>            <textarea name="violation_details" class="form-control" rows="3"><%= caseData ? caseData.violation_details : '' %></textarea>          </div>          <div class="col-12">            <label class="form-label">Description of Case <small class="text-muted">(narrative / context)</small></label>            <textarea name="description" class="form-control" rows="3" required><%= caseData ? caseData.description : '' %></textarea>          </div>          <% if (caseData) { %>          <div class="col-12"><h6 class="fw-bold text-primary border-bottom pb-2 mt-2"><i class="bi bi-file-earmark"></i> Notice of Violation with NTE Document</h6></div>          <div class="col-md-6">            <label class="form-label">Upload NoV+NTE Scanned Document</label>            <div class="input-group input-group-sm">              <input type="file" name="nov_nte_document" class="form-control" formaction="/cases/upload-nov/<%= caseData.id %>" onchange="this.form.action='/cases/upload-nov/<%= caseData.id %>'; this.form.submit()">            </div>            <% if (caseData.nov_nte_document) { %>              <small class="text-success"><i class="bi bi-check-circle"></i> <a href="<%= caseData.nov_nte_document %>" target="_blank">View uploaded document</a></small>            <% } %>          </div>          <div class="col-12"><h6 class="fw-bold text-primary border-bottom pb-2 mt-2"><i class="bi bi-send"></i> Serve Notice to Employee</h6></div>          <div class="col-md-3">            <label class="form-label">Date Served</label>            <input type="date" name="notice_served_date" class="form-control" value="<%= caseData.notice_served_date || '' %>">          </div>          <div class="col-md-3">            <label class="form-label">Received By</label>            <input type="text" name="notice_received_by" class="form-control" value="<%= caseData.notice_received_by || '' %>" placeholder="Employee name">          </div>          <div class="col-md-3">            <label class="form-label">Date Received</label>            <input type="date" name="notice_received_date" class="form-control" value="<%= caseData.notice_received_date || '' %>">          </div>          <div class="col-12"><h6 class="fw-bold text-primary border-bottom pb-2 mt-2"><i class="bi bi-gavel"></i> Verdict Signatories</h6></div>          <div class="col-md-3">            <label class="form-label">Decided By <small>(Main Office authority)</small></label>            <input type="text" name="verdict_decided_by" class="form-control" value="<%= caseData.verdict_decided_by || '' %>">          </div>          <div class="col-md-3">            <label class="form-label">Served By <small>(at site)</small></label>            <input type="text" name="verdict_served_by" class="form-control" value="<%= caseData.verdict_served_by || '' %>">          </div>          <div class="col-md-3">            <label class="form-label">Received By <small>(accused)</small></label>            <input type="text" name="verdict_received_by" class="form-control" value="<%= caseData.verdict_received_by || '' %>">          </div>          <div class="col-md-3">            <label class="form-label">Date Received</label>            <input type="date" name="verdict_received_date" class="form-control" value="<%= caseData.verdict_received_date || '' %>">          </div>          <div class="col-md-4">            <label class="form-label">Penalty</label>            <input type="text" name="penalty" class="form-control" value="<%= caseData.penalty || '' %>" placeholder="e.g. 3 days suspension">          </div>          <div class="col-md-3">            <label class="form-label">Resolution Date</label>            <input type="date" name="resolution_date" class="form-control" value="<%= caseData.resolution_date || '' %>">          </div>          <div class="col-md-3">            <label class="form-label">Closed Date</label>            <input type="date" name="closed_date" class="form-control" value="<%= caseData.closed_date || '' %>">          </div>          <% } %>        </div>        <div class="mt-4">          <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> <%= caseData ? 'Update Case' : 'Create Case' %></button>          <a href="/cases" class="btn btn-outline-secondary">Cancel</a>        </div>      </form>    </div>  </div></div><% if (!caseData) { %><script>  const employees = <%- JSON.stringify(employees || []) %>;  const empSearch = document.getElementById('employeeSearch');  const empId = document.getElementById('employeeId');  const empName = document.getElementById('employeeName');  const empResults = document.getElementById('employeeResults');  empSearch.addEventListener('input', function() {    const q = this.value.toLowerCase();    if (!q) { empResults.style.display = 'none'; empId.value = ''; empName.value = ''; return; }    const matches = employees.filter(e => e.full_name.toLowerCase().includes(q) || e.employee_id.includes(q)).slice(0, 20);    if (matches.length === 0) { empResults.style.display = 'none'; return; }    empResults.innerHTML = matches.map(e =>      '<div class="emp-item" data-id="' + e.id + '" data-name="' + e.full_name + '" data-position="' + (e.position || '') + '" data-dept="' + (e.department || '') + '" style="padding:8px 12px;cursor:pointer;border-bottom:1px solid #eee;font-size:14px;">' +        '<strong>' + e.employee_id + '</strong> - ' + e.full_name + ' <span style="color:#666;font-size:12px;">(' + e.department + ')</span>' +      '</div>'    ).join('');    empResults.style.display = 'block';  });  empResults.addEventListener('click', function(e) {    const item = e.target.closest('.emp-item');    if (!item) return;    empId.value = item.dataset.id;    empName.value = item.dataset.name;    empSearch.value = item.dataset.name;    empResults.style.display = 'none';  });  document.addEventListener('click', function(e) {    if (!e.target.closest('#employeeSearch') && !e.target.closest('#employeeResults')) empResults.style.display = 'none';  });</script><% } %>
