<div class="container-fluid px-4 py-4">  <div class="d-flex justify-content-between align-items-center mb-4">    <h4 class="fw-bold"><i class="bi bi-folder2-open"></i> Disciplinary Cases</h4>    <a href="/cases/add" class="btn btn-primary"><i class="bi bi-plus-lg"></i> New Case</a>  </div>  <div class="card border-0 shadow-sm">    <div class="card-body">      <form method="GET" class="row g-2 mb-3">        <div class="col-md-3">          <input type="text" name="search" class="form-control" placeholder="Search employee, case #, or memo #..." value="<%= search %>">        </div>        <div class="col-md-2">          <select name="status" class="form-select">            <option value="">All Status</option>            <option value="Open" <%= status === 'Open' ? 'selected' : '' %>>Open</option>            <option value="Under Investigation" <%= status === 'Under Investigation' ? 'selected' : '' %>>Under Investigation</option>            <option value="For Hearing" <%= status === 'For Hearing' ? 'selected' : '' %>>For Hearing</option>            <option value="Resolved" <%= status === 'Resolved' ? 'selected' : '' %>>Resolved</option>            <option value="Dismissed" <%= status === 'Dismissed' ? 'selected' : '' %>>Dismissed</option>            <option value="Closed" <%= status === 'Closed' ? 'selected' : '' %>>Closed</option>
            <option value="Appealed" <%= status === 'Appealed' ? 'selected' : '' %>>Appealed</option>          </select>        </div>        <div class="col-md-1">          <button type="submit" class="btn btn-outline-primary w-100"><i class="bi bi-search"></i></button>        </div>      </form>      <div class="table-responsive">        <table class="table table-hover">          <thead class="table-dark">            <tr><th>Case #</th><th>Memo No.</th><th>Employee</th><th>Violation</th><th>Status</th><th>Incident Date</th><th>Actions</th></tr>          </thead>          <tbody>            <% if (cases.length === 0) { %>              <tr><td colspan="7" class="text-center text-muted py-4">No cases found</td></tr>            <% } else { %>              <% cases.forEach(c => { %>              <tr>                <td><a href="/cases/view/<%= c.id %>" class="text-decoration-none fw-medium"><%= c.case_number %></a></td>                <td><small><%= c.memo_number || '--' %></small></td>                <td><%= c.employee_name %> <small class="text-muted">(<%= c.emp_id %>)</small></td>                <td><%= c.violation_classification || c.offense_name || 'N/A' %></td>                <td><span class="badge bg-<%= c.status === 'Resolved' ? 'success' : c.status === 'Closed' ? 'dark' : c.status === 'Dismissed' ? 'secondary' : c.status === 'For Hearing' ? 'info' : c.status === 'Under Investigation' ? 'warning' : 'primary' %>"><%= c.status %></span></td>                <td><%= new Date(c.incident_date).toLocaleDateString() %></td>                <td>                  <a href="/cases/view/<%= c.id %>" class="btn btn-sm btn-outline-info" title="View"><i class="bi bi-eye"></i></a>                  <a href="/cases/edit/<%= c.id %>" class="btn btn-sm btn-outline-warning" title="Edit"><i class="bi bi-pencil"></i></a>                </td>              </tr>              <% }) %>            <% } %>          </tbody>        </table>      </div>      <% if (pages > 1) { %>      <nav><ul class="pagination pagination-sm justify-content-center">        <% for (var i = 1; i <= pages; i++) { %>          <li class="page-item <%= i === page ? 'active' : '' %>">            <a class="page-link" href="?page=<%= i %><%= status ? '&status=' + status : '' %><%= search ? '&search=' + search : '' %>"><%= i %></a>          </li>        <% } %>      </ul></nav>      <% } %>    </div>  </div></div>
