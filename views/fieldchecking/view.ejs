<div class="container-fluid py-3">  <nav aria-label="breadcrumb">    <ol class="breadcrumb">      <li class="breadcrumb-item"><a href="/fieldchecking">Field Checking</a></li>      <li class="breadcrumb-item active">Inspection Detail</li>    </ol>  </nav>  <div class="row">    <div class="col-lg-8">      <div class="card shadow-sm mb-3">        <div class="card-header bg-primary text-white d-flex align-items-center">          <i class="bi bi-clipboard-data me-2"></i>          <h5 class="mb-0">Inspection Information</h5>        </div>        <div class="card-body">          <div class="row mb-2">            <div class="col-sm-3 fw-bold">Date:</div>            <div class="col-sm-9"><%= check.inspectionDate instanceof Date ? check.inspectionDate.toLocaleDateString() : check.inspectionDate %></div>          </div>          <div class="row mb-2">            <div class="col-sm-3 fw-bold">Time:</div>            <div class="col-sm-9"><%= check.inspectionTime || 'N/A' %></div>          </div>          <div class="row mb-2">            <div class="col-sm-3 fw-bold">Project Site:</div>            <div class="col-sm-9"><%= check.projectSite %></div>          </div>          <div class="row mb-2">            <div class="col-sm-3 fw-bold">Inspector:</div>            <div class="col-sm-9"><%= check.inspector %></div>          </div>          <% if (check.foreman) { %>          <div class="row mb-2">            <div class="col-sm-3 fw-bold">Foreman:</div>            <div class="col-sm-9"><%= check.foreman %></div>          </div>          <% } %>          <% if (check.leadman) { %>          <div class="row mb-2">            <div class="col-sm-3 fw-bold">Leadman:</div>            <div class="col-sm-9"><%= check.leadman %></div>          </div>          <% } %>          <% if (check.summary) { %>          <div class="row mb-2">            <div class="col-sm-3 fw-bold">Summary:</div>            <div class="col-sm-9"><%= check.summary %></div>          </div>          <% } %>          <div class="row mb-0">            <div class="col-sm-3 fw-bold">Status:</div>            <div class="col-sm-9">              <span class="badge bg-<%= check.status === 'Resolved' ? 'success' : check.status === 'Pending' ? 'warning' : 'secondary' %>">                <%= check.status || 'Open' %>              </span>            </div>          </div>        </div>      </div>      <div class="card shadow-sm">        <div class="card-header bg-danger text-white d-flex align-items-center">          <i class="bi bi-exclamation-triangle me-2"></i>          <h5 class="mb-0">Violations (<%= violations.length %>)</h5>        </div>        <div class="card-body p-0">          <div class="table-responsive">            <table class="table table-striped table-hover mb-0">              <thead class="table-light">                <tr>                  <th>Employee</th>                  <th>Designation</th>                  <th>Violation</th>                  <th>Action Taken</th>                </tr>              </thead>              <tbody>                <% if (violations && violations.length) { %>                  <% violations.forEach(function(v) { %>                    <tr>                      <td><%= v.employeeName %></td>                      <td><%= v.designation || '-' %></td>                      <td><%= v.violation %></td>                      <td><%= v.actionTaken || '-' %></td>                    </tr>                  <% }) %>                <% } else { %>                  <tr><td colspan="4" class="text-center text-muted">No violations recorded.</td></tr>                <% } %>              </tbody>            </table>          </div>        </div>      </div>    </div>    <div class="col-lg-4">      <div class="card shadow-sm">        <div class="card-header bg-secondary text-white">          <i class="bi bi-pencil-square me-1"></i> Update Status        </div>        <div class="card-body">          <form action="/fieldchecking/<%= check._id %>/status?_method=PUT" method="POST">            <div class="mb-3">              <label for="status" class="form-label">Status</label>              <select class="form-select" id="status" name="status">                <option value="Open" <%= check.status === 'Open' ? 'selected' : '' %>>Open</option>                <option value="Pending" <%= check.status === 'Pending' ? 'selected' : '' %>>Pending</option>                <option value="Resolved" <%= check.status === 'Resolved' ? 'selected' : '' %>>Resolved</option>              </select>            </div>            <button type="submit" class="btn btn-primary w-100"><i class="bi bi-check-circle me-1"></i> Update</button>          </form>        </div>        <div class="card-footer d-flex justify-content-between">          <a href="/fieldchecking" class="btn btn-sm btn-outline-secondary">Back</a>          <a href="/fieldchecking/<%= check._id %>/edit" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i> Edit</a>        </div>      </div>    </div>  </div></div>