<div class="container-fluid py-3">  <nav aria-label="breadcrumb">    <ol class="breadcrumb">      <li class="breadcrumb-item"><a href="/fieldchecking">Field Checking</a></li>      <li class="breadcrumb-item active"><%= check && check._id ? 'Edit' : 'New' %> Inspection</li>    </ol>  </nav>  <div class="card shadow-sm">    <div class="card-header bg-primary text-white d-flex align-items-center">      <i class="bi bi-clipboard-check me-2"></i>      <h5 class="mb-0"><%= check && check._id ? 'Edit Field Check' : 'New Field Check' %></h5>    </div>    <div class="card-body">      <form action="/fieldchecking<%= check && check._id ? '/' + check._id + '?_method=PUT' : '' %>" method="POST">        <div class="row g-3 mb-3">          <div class="col-md-3">            <label for="inspectionDate" class="form-label">Inspection Date</label>            <input type="date" class="form-control" id="inspectionDate" name="inspectionDate"                   value="<%= check ? (check.inspectionDate instanceof Date ? check.inspectionDate.toISOString().split('T')[0] : check.inspectionDate) : today %>" required>          </div>          <div class="col-md-3">            <label for="inspectionTime" class="form-label">Inspection Time</label>            <input type="time" class="form-control" id="inspectionTime" name="inspectionTime"                   value="<%= check ? check.inspectionTime : now %>" required>          </div>          <div class="col-md-6">            <label for="projectSite" class="form-label">Project Site</label>            <input type="text" class="form-control" id="projectSite" name="projectSite"                   value="<%= check ? check.projectSite : '' %>" placeholder="e.g. Main Building - Floor 3" required>          </div>        </div>        <div class="row g-3 mb-3">          <div class="col-md-4">            <label for="inspector" class="form-label">Inspector</label>            <input type="text" class="form-control" id="inspector" name="inspector"                   value="<%= check ? check.inspector : '' %>" required>          </div>          <div class="col-md-4">            <label for="foreman" class="form-label">Foreman</label>            <input type="text" class="form-control" id="foreman" name="foreman"                   value="<%= check ? check.foreman : '' %>">          </div>          <div class="col-md-4">            <label for="leadman" class="form-label">Leadman</label>            <input type="text" class="form-control" id="leadman" name="leadman"                   value="<%= check ? check.leadman : '' %>">          </div>        </div>        <div class="mb-3">          <label for="summary" class="form-label">Summary</label>          <textarea class="form-control" id="summary" name="summary" rows="3"><%= check ? check.summary : '' %></textarea>        </div>        <hr>        <div class="d-flex justify-content-between align-items-center mb-2">          <h6 class="mb-0"><i class="bi bi-exclamation-triangle me-1"></i> Violations</h6>          <button type="button" class="btn btn-sm btn-outline-danger" id="addViolationBtn">            <i class="bi bi-plus-circle"></i> Add Violation          </button>        </div>        <div class="table-responsive" id="violationsContainer">          <table class="table table-bordered table-sm" id="violationsTable">            <thead class="table-light">              <tr>                <th style="width:22%">Employee Name</th>                <th style="width:18%">Designation</th>                <th style="width:35%">Violation</th>                <th style="width:20%">Action Taken</th>                <th style="width:5%"></th>              </tr>            </thead>            <tbody>              <% if (check && check.violations && check.violations.length) { %>                <% check.violations.forEach(function(v, i) { %>                  <tr class="violation-row">                    <td><input type="text" class="form-control form-control-sm" name="violations[<%= i %>][employeeName]" value="<%= v.employeeName %>" required></td>                    <td><input type="text" class="form-control form-control-sm" name="violations[<%= i %>][designation]" value="<%= v.designation %>"></td>                    <td><input type="text" class="form-control form-control-sm" name="violations[<%= i %>][violation]" value="<%= v.violation %>" required></td>                    <td><input type="text" class="form-control form-control-sm" name="violations[<%= i %>][actionTaken]" value="<%= v.actionTaken %>"></td>                    <td class="text-center"><button type="button" class="btn btn-sm btn-outline-danger remove-violation"><i class="bi bi-x"></i></button></td>                  </tr>                <% }) %>              <% } %>            </tbody>          </table>        </div>        <div class="d-flex justify-content-end mt-3">          <a href="/fieldchecking" class="btn btn-secondary me-2">Cancel</a>          <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i> Save</button>        </div>      </form>    </div>  </div></div><script>let violationIndex = <%= (check && check.violations) ? check.violations.length : 0 %>;document.getElementById('addViolationBtn').addEventListener('click', function() {  const tbody = document.querySelector('#violationsTable tbody');  const row = document.createElement('tr');  row.className = 'violation-row';  row.innerHTML = `    <td><input type="text" class="form-control form-control-sm" name="violations[${violationIndex}][employeeName]" required></td>    <td><input type="text" class="form-control form-control-sm" name="violations[${violationIndex}][designation]"></td>    <td><input type="text" class="form-control form-control-sm" name="violations[${violationIndex}][violation]" required></td>    <td><input type="text" class="form-control form-control-sm" name="violations[${violationIndex}][actionTaken]"></td>    <td class="text-center"><button type="button" class="btn btn-sm btn-outline-danger remove-violation"><i class="bi bi-x"></i></button></td>  `;  tbody.appendChild(row);  violationIndex++;});document.querySelector('#violationsTable tbody').addEventListener('click', function(e) {  if (e.target.closest('.remove-violation')) {    e.target.closest('tr').remove();  }});</script>