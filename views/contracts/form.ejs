<div class="container-fluid px-4 py-4">  <div class="d-flex justify-content-between align-items-center mb-4">    <h4 class="fw-bold"><i class="bi bi-<%= contract ? 'pencil' : 'plus' %>-square"></i> <%= contract ? 'Edit Contract' : 'New Contract' %></h4>    <a href="/contracts" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>  </div>  <div class="card border-0 shadow-sm">    <div class="card-body">      <form method="POST" action="<%= contract ? '/contracts/edit/' + contract.id : '/contracts/add' %>">        <div class="row g-3">          <div class="col-md-6">            <label class="form-label">Employee *</label>            <% if (contract) { %>              <input type="text" class="form-control" value="<%= contract.employee_name %> (<%= contract.employee_id %>)" readonly>              <input type="hidden" name="employee_id" value="<%= contract.employee_id %>">            <% } else { %>              <select name="employee_id" class="form-select" id="employeeSelect" required>                <option value="">-- Select Employee --</option>                <% employees.forEach(e => { %>                  <option value="<%= e.id %>" <%= preselect && preselect == e.id ? 'selected' : '' %>><%= e.employee_id %> - <%= e.full_name %></option>                <% }) %>              </select>            <% } %>          </div>          <div class="col-md-3">            <label class="form-label">Contract Type *</label>            <input type="text" name="contract_type" class="form-control" value="<%= contract ? contract.contract_type : '' %>" placeholder="e.g. Project-Based" required>          </div>          <div class="col-md-3">            <label class="form-label">Project Site</label>            <input type="text" name="project_site" class="form-control" value="<%= contract ? contract.project_site : '' %>" placeholder="e.g. Site A">          </div>          <div class="col-md-3">            <label class="form-label">Daily Rate (₱)</label>            <input type="number" name="daily_rate" class="form-control" step="0.01" value="<%= contract ? contract.daily_rate : '' %>">          </div>          <div class="col-md-3">            <label class="form-label">Monthly Rate (₱)</label>            <input type="number" name="monthly_rate" class="form-control" step="0.01" value="<%= contract ? contract.monthly_rate : '' %>">          </div>          <div class="col-md-3">            <label class="form-label">Start Date *</label>            <input type="date" name="start_date" class="form-control" value="<%= contract ? contract.start_date : today %>" required>          </div>          <div class="col-md-3">            <label class="form-label">End Date *</label>            <input type="date" name="end_date" class="form-control" value="<%= contract ? contract.end_date : '' %>" required>          </div>          <% if (contract) { %>          <div class="col-md-3">            <label class="form-label">Status</label>            <select name="status" class="form-select">              <option value="Active" <%= contract.status === 'Active' ? 'selected' : '' %>>Active</option>              <option value="Expired" <%= contract.status === 'Expired' ? 'selected' : '' %>>Expired</option>              <option value="Terminated" <%= contract.status === 'Terminated' ? 'selected' : '' %>>Terminated</option>              <option value="Completed" <%= contract.status === 'Completed' ? 'selected' : '' %>>Completed</option>            </select>          </div>          <% } %>          <div class="col-12">            <label class="form-label">Remarks</label>            <textarea name="remarks" class="form-control" rows="3"><%= contract ? contract.remarks : '' %></textarea>          </div>        </div>        <div class="mt-4">          <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> <%= contract ? 'Update Contract' : 'Create Contract' %></button>          <a href="/contracts" class="btn btn-outline-secondary">Cancel</a>        </div>      </form>    </div>  </div></div>