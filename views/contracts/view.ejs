<div class="container-fluid px-4 py-4">  <div class="d-flex justify-content-between align-items-center mb-4">    <h4 class="fw-bold"><i class="bi bi-file-earmark-text"></i> Contract Details</h4>    <div>      <a href="/contracts/edit/<%= contract.id %>" class="btn btn-outline-warning"><i class="bi bi-pencil"></i> Edit</a>      <a href="/contracts" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>    </div>  </div>  <div class="row g-3">    <div class="col-md-6">      <div class="card border-0 shadow-sm mb-3">        <div class="card-header bg-white py-3">          <h6 class="mb-0 fw-bold"><i class="bi bi-person-badge"></i> Employee Information</h6>        </div>        <div class="card-body">          <div class="row g-3">            <div class="col-md-6">              <p class="mb-1 text-muted small">Full Name</p>              <p class="fw-medium"><%= contract.employee_name %></p>            </div>            <div class="col-md-3">              <p class="mb-1 text-muted small">Employee ID</p>              <p class="fw-medium"><%= contract.employee_id %></p>            </div>            <div class="col-md-3">              <p class="mb-1 text-muted small">Position</p>              <p class="fw-medium"><%= contract.position || '--' %></p>            </div>            <div class="col-md-6">              <p class="mb-1 text-muted small">Trade</p>              <p class="fw-medium"><%= contract.trade || '--' %></p>            </div>            <div class="col-md-6">              <p class="mb-1 text-muted small">Department</p>              <p class="fw-medium"><%= contract.department || '--' %></p>            </div>          </div>        </div>      </div>      <div class="card border-0 shadow-sm">        <div class="card-header bg-white py-3">          <h6 class="mb-0 fw-bold"><i class="bi bi-file-text"></i> Extension History</h6>        </div>        <div class="card-body p-0">          <div class="table-responsive">            <table class="table table-hover mb-0">              <thead class="table-light">                <tr><th>Date From</th><th>Date To</th><th>Reason</th><th>Memo #</th></tr>              </thead>              <tbody>                <% if (extensions.length === 0) { %>                  <tr><td colspan="4" class="text-center text-muted py-4">No extensions recorded</td></tr>                <% } else { %>                  <% extensions.forEach(ex => { %>                  <tr>                    <td><%= new Date(ex.date_from).toLocaleDateString() %></td>                    <td><%= new Date(ex.date_to).toLocaleDateString() %></td>                    <td><%= ex.reason || '--' %></td>                    <td><%= ex.memo_number || '--' %></td>                  </tr>                  <% }) %>                <% } %>              </tbody>            </table>          </div>        </div>      </div>    </div>    <div class="col-md-6">      <div class="card border-0 shadow-sm mb-3">        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">          <h6 class="mb-0 fw-bold"><i class="bi bi-info-circle"></i> Contract Details</h6>          <span class="badge bg-<%= contract.status === 'Active' ? 'success' : contract.status === 'Expired' ? 'secondary' : contract.status === 'Terminated' ? 'danger' : 'info' %> fs-6"><%= contract.status %></span>        </div>        <div class="card-body">          <div class="row g-3">            <div class="col-md-6">              <p class="mb-1 text-muted small">Contract Type</p>              <p class="fw-medium"><%= contract.contract_type %></p>            </div>            <div class="col-md-6">              <p class="mb-1 text-muted small">Project Site</p>              <p class="fw-medium"><%= contract.project_site || '--' %></p>            </div>            <div class="col-md-4">              <p class="mb-1 text-muted small">Daily Rate</p>              <p class="fw-medium"><%= contract.daily_rate ? '₱' + Number(contract.daily_rate).toLocaleString() : '--' %></p>            </div>            <div class="col-md-4">              <p class="mb-1 text-muted small">Monthly Rate</p>              <p class="fw-medium"><%= contract.monthly_rate ? '₱' + Number(contract.monthly_rate).toLocaleString() : '--' %></p>            </div>            <div class="col-md-4">              <p class="mb-1 text-muted small">Duration</p>              <p class="fw-medium">                <%= new Date(contract.start_date).toLocaleDateString() %> &ndash;                <%= new Date(contract.end_date).toLocaleDateString() %>              </p>            </div>            <% if (contract.remarks) { %>            <div class="col-12">              <p class="mb-1 text-muted small">Remarks</p>              <p><%= contract.remarks %></p>            </div>            <% } %>          </div>        </div>      </div>      <div class="card border-0 shadow-sm">        <div class="card-header bg-white py-3">          <h6 class="mb-0 fw-bold"><i class="bi bi-plus-circle"></i> Extend Contract</h6>        </div>        <div class="card-body">          <form method="POST" action="/contracts/extend/<%= contract.id %>">            <div class="row g-2">              <div class="col-md-6">                <label class="form-label">Date From *</label>                <input type="date" name="date_from" class="form-control" required>              </div>              <div class="col-md-6">                <label class="form-label">Date To *</label>                <input type="date" name="date_to" class="form-control" required>              </div>              <div class="col-md-6">                <label class="form-label">Reason</label>                <input type="text" name="reason" class="form-control" placeholder="Extension reason">              </div>              <div class="col-md-6">                <label class="form-label">Memo #</label>                <input type="text" name="memo_number" class="form-control" placeholder="Memo reference">              </div>              <div class="col-12 mt-3">                <button type="submit" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Extend Contract</button>              </div>            </div>          </form>        </div>      </div>    </div>  </div></div>