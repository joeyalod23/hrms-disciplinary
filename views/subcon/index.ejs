<div class="container-fluid px-4 py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold"><i class="bi bi-people"></i> Subcontractor Employees</h4>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addModal"><i class="bi bi-plus-lg"></i> Add Employee</button>
  </div>

  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
      <form method="GET" class="row g-2">
        <div class="col-md-3">
          <input type="text" name="search" class="form-control" placeholder="Search employee..." value="<%= search %>">
        </div>
        <div class="col-md-2">
          <select name="company" class="form-select">
            <option value="">All Companies</option>
            <% companies.forEach(c => { %>
              <option value="<%= c.company_name %>" <%= company === c.company_name ? 'selected' : '' %>><%= c.company_name %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-2">
          <select name="status" class="form-select">
            <option value="">All Status</option>
            <option value="active" <%= status === 'active' ? 'selected' : '' %>>Active</option>
            <option value="inactive" <%= status === 'inactive' ? 'selected' : '' %>>Inactive</option>
          </select>
        </div>
        <div class="col-md-1">
          <button type="submit" class="btn btn-outline-primary w-100"><i class="bi bi-search"></i></button>
        </div>
        <div class="col-md-1">
          <a href="/subcon" class="btn btn-outline-secondary w-100"><i class="bi bi-x-circle"></i></a>
        </div>
      </form>
    </div>
  </div>

  <div class="card border-0 shadow-sm">
    <div class="card-body">
      <div class="table-responsive">
        <table class="table table-hover">
          <thead class="table-dark">
            <tr><th>#</th><th>Employee Name</th><th>Company</th><th>Status</th><th>Date Added</th><th>Actions</th></tr>
          </thead>
          <tbody>
            <% if (rows.length === 0) { %>
              <tr><td colspan="6" class="text-center text-muted py-4">No subcontractor employees found</td></tr>
            <% } else { %>
              <% rows.forEach((r, i) => { %>
              <tr class="<%= r.is_active ? '' : 'table-secondary' %>">
                <td><%= offset + i + 1 %></td>
                <td><%= r.employee_name %></td>
                <td><%= r.company_name %></td>
                <td>
                  <span class="badge bg-<%= r.is_active ? 'success' : 'secondary' %>">
                    <%= r.is_active ? 'Active' : 'Inactive' %>
                  </span>
                </td>
                <td><%= new Date(r.created_at).toLocaleDateString() %></td>
                <td>
                  <form method="POST" action="/subcon/toggle/<%= r.id %>" style="display:inline">
                    <button type="submit" class="btn btn-sm btn-outline-<%= r.is_active ? 'secondary' : 'success' %>" title="<%= r.is_active ? 'Deactivate' : 'Activate' %>">
                      <i class="bi bi-<%= r.is_active ? 'pause-circle' : 'play-circle' %>"></i>
                    </button>
                  </form>
                  <a href="/subcon/edit/<%= r.id %>" class="btn btn-sm btn-outline-warning" title="Edit"><i class="bi bi-pencil"></i></a>
                  <form method="POST" action="/subcon/delete/<%= r.id %>" style="display:inline" onsubmit="return confirm('Delete this record?')">
                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></button>
                  </form>
                </td>
              </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
      <% if (pages > 1) { %>
      <nav><ul class="pagination pagination-sm justify-content-center mt-3">
        <% for (var i = 1; i <= pages; i++) { %>
          <li class="page-item <%= i === page ? 'active' : '' %>">
            <a class="page-link" href="?page=<%= i %><%= company ? '&company=' + company : '' %><%= search ? '&search=' + search : '' %><%= status ? '&status=' + status : '' %>"><%= i %></a>
          </li>
        <% } %>
      </ul></nav>
      <% } %>
      <small class="text-muted">Total: <%= total %> record(s)</small>
    </div>
  </div>
</div>

<!-- Add Modal -->
<div class="modal fade" id="addModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <form method="POST" action="/subcon/add">
        <div class="modal-header"><h5 class="modal-title">Add Subcon Employee</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label">Employee Name</label>
            <input type="text" name="employee_name" class="form-control" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Company Name</label>
            <input type="text" name="company_name" class="form-control" list="companyList" required>
            <datalist id="companyList">
              <% companies.forEach(c => { %>
                <option value="<%= c.company_name %>">
              <% }) %>
            </datalist>
          </div>
          <div class="mb-3">
            <label class="form-label">Status</label>
            <select name="is_active" class="form-select">
              <option value="1">Active</option>
              <option value="0">Inactive</option>
            </select>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Save</button>
        </div>
      </form>
    </div>
  </div>
</div>
