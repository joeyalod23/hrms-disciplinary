<div class="container-fluid px-4 py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold"><i class="bi bi-chat-left-dots"></i> Corrective Disciplinary Action (F-HRD-049)</h4>
    <a href="/cdaf/add" class="btn btn-primary"><i class="bi bi-plus-lg"></i> New CDAF</a>
  </div>
  <div class="alert alert-info py-2 small">
    <i class="bi bi-info-circle"></i> For <strong>Light (Minor)</strong> offenses only — 1st Offense = Verbal Reprimand, 2nd Offense = Written Reprimand. For 3rd minor or higher severity, use Incident Report.
  </div>
  <div class="card border-0 shadow-sm">
    <div class="card-body">
      <form method="GET" class="row g-2 mb-3">
        <div class="col-md-3">
          <input type="text" name="search" class="form-control" placeholder="Search employee or CDAF #..." value="<%= search %>">
        </div>
        <div class="col-md-2">
          <select name="status" class="form-select">
            <option value="">All Status</option>
            <option value="Open" <%= status === 'Open' ? 'selected' : '' %>>Open</option>
            <option value="Acknowledged" <%= status === 'Acknowledged' ? 'selected' : '' %>>Acknowledged</option>
            <option value="Closed" <%= status === 'Closed' ? 'selected' : '' %>>Closed</option>
          </select>
        </div>
        <div class="col-md-1">
          <button type="submit" class="btn btn-outline-primary w-100"><i class="bi bi-search"></i></button>
        </div>
      </form>
      <div class="table-responsive">
        <table class="table table-hover">
          <thead class="table-dark">
            <tr><th>CDAF #</th><th>Employee</th><th>Offense #</th><th>Action</th><th>Violation</th><th>Status</th><th>Date</th><th>Actions</th></tr>
          </thead>
          <tbody>
            <% if (records.length === 0) { %>
              <tr><td colspan="8" class="text-center text-muted py-4">No CDAF records found</td></tr>
            <% } else { %>
              <% records.forEach(r => { %>
                <tr>
                  <td><%= r.cdaf_number %></td>
                  <td><%= r.employee_name %> (<%= r.emp_id %>)</td>
                  <td><span class="badge bg-secondary"><%= r.offense_number %><%= r.offense_number === 1 ? 'st' : r.offense_number === 2 ? 'nd' : 'rd' %></span></td>
                  <td><span class="badge bg-<%= r.action_type === 'Verbal Reprimand' ? 'warning text-dark' : 'danger' %>"><%= r.action_type %></span></td>
                  <td><%= r.offense_name || 'N/A' %></td>
                  <td><span class="badge bg-<%= r.status === 'Open' ? 'primary' : r.status === 'Acknowledged' ? 'info' : 'secondary' %>"><%= r.status %></span></td>
                  <td><%= new Date(r.incident_date).toLocaleDateString() %></td>
                  <td><a href="/cdaf/view/<%= r.id %>" class="btn btn-sm btn-outline-primary"><i class="bi bi-eye"></i></a></td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
      <% if (pages > 1) { %>
        <nav><ul class="pagination pagination-sm">
          <% for (let i = 1; i <= pages; i++) { %>
            <li class="page-item <%= i === page ? 'active' : '' %>">
              <a class="page-link" href="?page=<%= i %><%= status ? '&status=' + status : '' %><%= search ? '&search=' + search : '' %>"><%= i %></a>
            </li>
          <% } %>
        </ul></nav>
      <% } %>
    </div>
  </div>
</div>
