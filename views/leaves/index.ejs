<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css" rel="stylesheet">
<style>
  .leave-card { transition: all .2s; }
  .leave-card:hover { transform: translateY(-2px); box-shadow: 0 4px 12px rgba(0,0,0,.08); }
  .status-pending { background: #fef3cd; color: #856404; }
  .status-approved { background: #d4edda; color: #155724; }
  .status-denied { background: #f8d7da; color: #721c24; }
  .status-cancelled { background: #e2e3e5; color: #383d41; }
  .awol-alert { border-left: 4px solid #dc3545; }
</style>
<div class="container-fluid px-4 py-4">
<div class="d-flex justify-content-between align-items-center mb-4">
<div>
<h2 class="fw-bold mb-1"><i class="bi bi-calendar-check me-2"></i>Leave & SIL Monitoring</h2>
<p class="text-muted mb-0">Manage leave applications, Service Incentive Leave, and attendance exceptions</p>
</div>
<div class="d-flex gap-2">
<button class="btn btn-outline-info" onclick="runAwolDetection()"><i class="bi bi-exclamation-triangle me-1"></i> Detect AWOL</button>
<button class="btn btn-outline-success" onclick="runSilAccrual()"><i class="bi bi-gift me-1"></i> Process SIL</button>
<button class="btn btn-primary" onclick="openApplyModal()"><i class="bi bi-plus-lg me-1"></i> Apply Leave</button>
</div>
</div>

<div class="row g-3 mb-4" id="leaveStats"></div>

<% if (typeof awolAlerts !== 'undefined' && awolAlerts && awolAlerts.length > 0) { %>
<div class="alert alert-danger d-flex align-items-center gap-2 mb-4" role="alert">
<i class="bi bi-exclamation-triangle-fill fs-4"></i>
<div>
<strong><%= awolAlerts.length %> attendance exception(s)</strong> require HR review.
<a href="#awolSection" class="alert-link">View details</a>
</div>
</div>
<% } %>

<ul class="nav nav-tabs mb-4" id="leaveTabs" role="tablist">
  <li class="nav-item" role="presentation">
    <button class="nav-link active" id="applications-tab" data-bs-toggle="tab" data-bs-target="#applications" type="button" role="tab">Leave Applications</button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link" id="sil-tab" data-bs-toggle="tab" data-bs-target="#sil" type="button" role="tab">SIL Monitoring</button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link" id="awol-tab" data-bs-toggle="tab" data-bs-target="#awol" type="button" role="tab">
      AWOL Exceptions
      <% if (awolAlerts && awolAlerts.length > 0) { %><span class="badge bg-danger ms-1"><%= awolAlerts.length %></span><% } %>
    </button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link" id="balances-tab" data-bs-toggle="tab" data-bs-target="#balances" type="button" role="tab">Leave Balances</button>
  </li>
</ul>

<div class="tab-content">
<div class="tab-pane fade show active" id="applications" role="tabpanel">
<div class="card border-0 shadow-sm">
<div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
<h6 class="mb-0 fw-bold"><i class="bi bi-list me-2"></i>Leave Applications</h6>
<div class="d-flex gap-2">
<select class="form-select form-select-sm" style="width:auto" onchange="filterStatus(this.value)">
<option value="">All Status</option>
<option value="Pending">Pending</option>
<option value="Approved">Approved</option>
<option value="Denied">Denied</option>
</select>
</div>
</div>
<div class="card-body p-0">
<div class="table-responsive">
<table class="table table-hover mb-0">
<thead class="table-light">
<tr><th class="py-3">Employee</th><th class="py-3">Type</th><th class="py-3">From</th><th class="py-3">To</th><th class="py-3">Days</th><th class="py-3">Status</th><th class="py-3">Attachment</th><th class="py-3">Filed</th><th class="py-3"></th></tr>
</thead>
<tbody id="leaveTableBody"></tbody>
</table>
</div>
</div>
</div>
</div>

<div class="tab-pane fade" id="sil" role="tabpanel">
<div class="row g-3 mb-4">
<div class="col-md-4">
<div class="card border-0 shadow-sm">
<div class="card-body text-center py-4">
<h3 class="fw-bold text-success mb-1"><%= typeof silStats !== 'undefined' && silStats ? silStats.credited : 0 %></h3>
<small class="text-muted">Employees SIL Credited</small>
</div>
</div>
</div>
<div class="col-md-4">
<div class="card border-0 shadow-sm">
<div class="card-body text-center py-4">
<h3 class="fw-bold text-primary mb-1"><%= typeof silStats !== 'undefined' && silStats ? silStats.total_active - silStats.credited : 0 %></h3>
<small class="text-muted">SIL Due (Active, >1yr)</small>
</div>
</div>
</div>
<div class="col-md-4">
<div class="card border-0 shadow-sm">
<div class="card-body text-center py-4">
<h3 class="fw-bold text-info mb-1"><%= typeof silStats !== 'undefined' && silStats ? silStats.total_active : 0 %></h3>
<small class="text-muted">Total Active Employees</small>
</div>
</div>
</div>
</div>
<div class="card border-0 shadow-sm">
<div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
<h6 class="mb-0 fw-bold"><i class="bi bi-search me-2"></i>Check SIL Eligibility</h6>
<div class="d-flex gap-2">
<select id="silEmployeeSelect" class="form-select form-select-sm" style="width:250px">
<option value="">-- Select Employee --</option>
<% employees.forEach(e => { %><option value="<%= e.id %>"><%= e.full_name %> (<%= e.employee_id %>)</option><% }) %>
</select>
<button class="btn btn-sm btn-outline-success" onclick="checkSilStatus()">Check</button>
<button class="btn btn-sm btn-success" onclick="grantSil()"><i class="bi bi-gift me-1"></i> Grant SIL</button>
</div>
</div>
<div class="card-body" id="silStatusResult">
<p class="text-muted mb-0">Select an employee and click "Check" to view SIL eligibility.</p>
</div>
</div>
</div>

<div class="tab-pane fade" id="awol" role="tabpanel">
<div class="card border-0 shadow-sm">
<div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
<h6 class="mb-0 fw-bold"><i class="bi bi-exclamation-triangle me-2"></i>Attendance Exceptions</h6>
<button class="btn btn-sm btn-outline-danger" onclick="runAwolDetection()"><i class="bi bi-arrow-repeat me-1"></i> Run Detection</button>
<button class="btn btn-sm btn-outline-success" onclick="resolveAllAwol()"><i class="bi bi-check2-all me-1"></i> Resolve All Open</button>
</div>
<div class="card-body p-0">
<div class="table-responsive">
<table class="table table-hover mb-0">
<thead class="table-light">
<tr><th class="py-3">Employee</th><th class="py-3">Type</th><th class="py-3">Period</th><th class="py-3">Days</th><th class="py-3">Status</th><th class="py-3">Flagged</th><th class="py-3"></th></tr>
</thead>
<tbody id="awolTableBody"></tbody>
</table>
</div>
</div>
</div>
</div>
</div>
</div>

<div id="applyModal" class="modal fade" tabindex="-1">
<div class="modal-dialog">
<div class="modal-content">
<div class="modal-header"><h5 class="modal-title">Apply for Leave</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
<form onsubmit="submitLeave(event)">
<div class="modal-body">
<div class="mb-3">
<label class="form-label">Employee</label>
<select id="leaveEmployee" class="form-select" required>
<option value="">-- Select Employee --</option>
<% employees.forEach(e => { %><option value="<%= e.id %>"><%= e.full_name %> (<%= e.employee_id %>)</option><% }) %>
</select>
</div>
<div class="mb-3">
<label class="form-label">Leave Type</label>
<select id="leaveType" class="form-select" required>
<option value="">-- Select --</option>
<% types.forEach(t => { %><option value="<%= t.id %>"><%= t.name %> (<%= t.code %>)</option><% }) %>
</select>
</div>
<div class="mb-3"><small id="balanceHint" class="text-muted"></small></div>
<div class="row g-2 mb-3">
<div class="col-6"><label class="form-label">From</label><input type="date" id="leaveFrom" class="form-control" required onchange="calcDays()"></div>
<div class="col-6"><label class="form-label">To</label><input type="date" id="leaveTo" class="form-control" required onchange="calcDays()"></div>
</div>
<div class="mb-3">
<label class="form-label">Days</label>
<input type="number" id="leaveDays" class="form-control" required min="0.5" step="0.5" readonly>
</div>
<div class="mb-3">
<label class="form-label">Reason</label>
<textarea id="leaveReason" class="form-control" rows="3" required></textarea>
</div>
<div class="mb-3">
<label class="form-label">Attachment (medical certificate, etc.)</label>
<input type="file" id="leaveAttachment" class="form-control" accept=".pdf,.jpg,.jpeg,.png,.webp">
</div>
</div>
<div class="modal-footer">
<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
<button type="submit" class="btn btn-primary">Submit</button>
</div>
</form>
</div>
</div>
</div>

<div class="tab-pane fade" id="balances" role="tabpanel">
<div class="card border-0 shadow-sm">
<div class="card-header bg-white py-3">
<h6 class="mb-0 fw-bold"><i class="bi bi-pie-chart me-2"></i>Leave Balances</h6>
</div>
<div class="card-body">
<div class="row g-2 mb-3">
<div class="col-md-4">
<select id="balEmployee" class="form-select" onchange="loadBalances()">
<option value="">-- Select Employee --</option>
<% employees.forEach(e => { %><option value="<%= e.id %>"><%= e.full_name %> (<%= e.employee_id %>)</option><% }) %>
</select>
</div>
</div>
<div id="balancesBody" class="table-responsive">
<p class="text-muted text-center py-4">Select an employee to view leave balances</p>
</div>
</div>
</div>
</div>

<div id="balanceModal" class="modal fade" tabindex="-1">
<div class="modal-dialog">
<div class="modal-content">
<div class="modal-header"><h5 class="modal-title">Leave Balances</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
<div class="modal-body" id="balanceBody"></div>
</div>
</div>
</div>

<script>
let leaves = <%- JSON.stringify(leaves) %>;
function $(id) { return document.getElementById(id); }

$(document).ready && $(document).ready(renderLeaveStats);

function calcDays() {
  const from = new Date($('leaveFrom').value);
  const to = new Date($('leaveTo').value);
  if (from && to && to >= from) {
    const diff = Math.ceil((to - from) / 86400000) + 1;
    $('leaveDays').value = diff;
  }
  checkBalance();
}

async function checkBalance() {
  const eid = $('leaveEmployee').value;
  const ltid = $('leaveType').value;
  const hint = $('balanceHint');
  if (!eid || !ltid) return (hint.textContent = '');
  try {
    const r = await fetch(`/leaves/api/balances/${eid}/${ltid}`);
    const bal = await r.json();
    hint.innerHTML = `<i class="bi bi-info-circle me-1"></i>Available balance: <strong>${bal.available}</strong> day(s) (Total: ${bal.total_days}, Used: ${bal.used_days}, Pending: ${bal.pending_days})`;
  } catch { hint.textContent = ''; }
}

function statusBadge(s) {
  const m = { Pending: 'warning', Approved: 'success', Denied: 'danger', Cancelled: 'secondary' };
  return `<span class="badge bg-${m[s] || 'secondary'}">${s}</span>`;
}

function render() {
  const tbody = $('leaveTableBody');
  const sel = document.querySelector('.form-select');
  const filter = sel ? sel.value : '';
  const filtered = filter ? leaves.filter(l => l.status === filter) : leaves;
  tbody.innerHTML = filtered.map(l => `<tr>
    <td class="py-2 fw-medium">${esc(l.employee_name)}<br><small class="text-muted">${l.employee_id}</small></td>
    <td class="py-2"><span class="badge bg-info">${esc(l.leave_type_code)}</span> ${esc(l.leave_type_name)}</td>
    <td class="py-2">${l.date_from}</td>
    <td class="py-2">${l.date_to}</td>
    <td class="py-2 fw-bold">${l.days}</td>
    <td class="py-2">${statusBadge(l.status)}</td>
    <td class="py-2">${l.attachment_url ? `<a href="${l.attachment_url}" target="_blank" class="btn btn-sm btn-outline-secondary"><i class="bi bi-paperclip"></i></a>` : '<span class="text-muted">&mdash;</span>'}</td>
    <td class="py-2 text-muted small">${new Date(l.created_at).toLocaleDateString()}</td>
    <td class="py-2 text-end">${l.status === 'Pending' && (<%= user.role === 'admin' || user.role === 'hrd' %>) ? `<button class="btn btn-sm btn-success me-1" onclick="updateStatus(${l.id},'Approved')"><i class="bi bi-check-lg"></i></button><button class="btn btn-sm btn-danger" onclick="updateStatus(${l.id},'Denied')"><i class="bi bi-x-lg"></i></button>` : ''}</td>
  </tr>`).join('');
}

function renderLeaveStats() {
  const el = $('leaveStats');
  const pending = leaves.filter(l => l.status === 'Pending').length;
  const approved = leaves.filter(l => l.status === 'Approved').length;
  el.innerHTML = `
    <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body text-center py-3"><h5 class="fw-bold text-warning mb-0">${pending}</h5><small class="text-muted">Pending</small></div></div></div>
    <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body text-center py-3"><h5 class="fw-bold text-success mb-0">${approved}</h5><small class="text-muted">Approved</small></div></div></div>
    <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body text-center py-3"><h5 class="fw-bold text-info mb-0">${leaves.length}</h5><small class="text-muted">Total</small></div></div></div>
    <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body text-center py-3"><h5 class="fw-bold text-danger mb-0"><%= typeof awolAlerts !== 'undefined' && awolAlerts ? awolAlerts.length : 0 %></h5><small class="text-muted">AWOL Alerts</small></div></div></div>
  `;
}

function esc(s) { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

async function submitLeave(e) {
  e.preventDefault();
  const payload = {
    employee_id: Number($('leaveEmployee').value),
    leave_type_id: Number($('leaveType').value),
    date_from: $('leaveFrom').value,
    date_to: $('leaveTo').value,
    days: Number($('leaveDays').value),
    reason: $('leaveReason').value,
  };
  const file = $('leaveAttachment').files[0];
  try {
    let res;
    if (file) {
      const fd = new FormData();
      Object.entries(payload).forEach(([k, v]) => fd.append(k, v));
      fd.append('attachment', file);
      res = await fetch('/leaves/api/apply-with-attachment', { method: 'POST', body: fd });
    } else {
      res = await fetch('/leaves/api/apply', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
    }
    if (!res.ok) throw new Error((await res.json()).error);
    showToast('Leave applied', 'success');
    bootstrap.Modal.getInstance($('applyModal')).hide();
    location.reload();
  } catch (e) { showToast(e.message, 'error'); }
}

async function updateStatus(id, status) {
  const reason = status === 'Denied' ? prompt('Reason for denial:') : '';
  if (status === 'Denied' && !reason) return showToast('Reason is required for denial', 'error');
  try {
    const res = await fetch(`/leaves/api/${id}/status`, {
      method: 'PATCH', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ status, denied_reason: reason }),
    });
    if (!res.ok) {
      const data = await res.json();
      throw new Error(data.error || 'Failed to update status');
    }
    location.reload();
  } catch (e) { showToast(e.message, 'error'); }
}

function openApplyModal() { new bootstrap.Modal($('applyModal')).show(); }

async function loadBalances() {
  const eid = $('balEmployee').value;
  const body = $('balancesBody');
  if (!eid) return body.innerHTML = '<p class="text-muted text-center py-4">Select an employee to view leave balances</p>';
  try {
    const r = await fetch(`/leaves/api/balances/${eid}`);
    const bals = await r.json();
    if (bals.length === 0) return body.innerHTML = '<p class="text-muted text-center py-4">No leave balances set up yet. Apply for leave to auto-initialize, or use "Set Balance" below.</p>';
    body.innerHTML = `<table class="table table-sm table-hover mb-0"><thead class="table-light"><tr><th>Leave Type</th><th>Code</th><th>Total Days</th><th>Used</th><th>Pending</th><th>Available</th><th></th></tr></thead><tbody>${
      bals.map(b => `<tr>
        <td>${esc(b.name)}</td>
        <td><span class="badge bg-info">${b.code}</span></td>
        <td><input type="number" class="form-control form-control-sm" style="width:70px" value="${b.total_days}" id="balTotal_${b.leave_type_id}" min="0"></td>
        <td>${b.used_days}</td>
        <td>${b.pending_days}</td>
        <td><strong class="text-${b.available > 0 ? 'success' : 'danger'}">${b.available}</strong></td>
        <td><button class="btn btn-sm btn-outline-primary" onclick="updateBalance(${eid},${b.leave_type_id})"><i class="bi bi-save"></i></button></td>
      </tr>`).join('')
    }</tbody></table>`;
  } catch { body.innerHTML = '<p class="text-danger text-center py-4">Failed to load balances</p>'; }
}

async function updateBalance(eid, ltid) {
  const total = document.getElementById('balTotal_' + ltid).value;
  if (!confirm('Set total days to ' + total + '?')) return;
  try {
    const r = await fetch('/leaves/api/balances/update', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ employee_id: eid, leave_type_id: ltid, total_days: Number(total) }),
    });
    if (!r.ok) throw new Error('Failed');
    showToast('Balance updated', 'success');
    loadBalances();
  } catch (e) { showToast(e.message, 'error'); }
}

async function checkSilStatus() {
  const eid = $('silEmployeeSelect').value;
  const result = $('silStatusResult');
  if (!eid) return result.innerHTML = '<p class="text-muted mb-0">Select an employee and click "Check".</p>';
  try {
    const r = await fetch(`/leaves/api/employees/${eid}/sil-status`);
    const data = await r.json();
    result.innerHTML = `
      <div class="d-flex align-items-center gap-3 mb-3">
        <div class="flex-grow-1">
          <h6 class="fw-bold mb-1">${esc(data.full_name)} (${esc(data.employee_id)})</h6>
          <small class="text-muted">Date Hired: ${data.date_hired || 'N/A'} &middot; SIL Credited: ${data.sil_credited ? 'Yes' : 'No'}</small>
        </div>
        <span class="badge ${data.sil_credited ? 'bg-success' : 'bg-warning'} fs-6 px-3 py-2">${data.sil_credited ? 'Credited' : 'Not Credited'}</span>
      </div>
      ${data.sil_balance ? `
      <div class="row g-2">
        <div class="col-3"><div class="border rounded p-2 text-center"><small class="d-block text-muted">Total</small><strong>${data.sil_balance.total}</strong></div></div>
        <div class="col-3"><div class="border rounded p-2 text-center"><small class="d-block text-muted">Used</small><strong>${data.sil_balance.used}</strong></div></div>
        <div class="col-3"><div class="border rounded p-2 text-center"><small class="d-block text-muted">Pending</small><strong>${data.sil_balance.pending}</strong></div></div>
        <div class="col-3"><div class="border rounded p-2 text-center bg-light"><small class="d-block text-muted">Available</small><strong class="text-success">${data.sil_balance.available}</strong></div></div>
      </div>` : '<p class="text-muted mb-0">No SIL balance record yet.</p>'}
    `;
  } catch (e) { result.innerHTML = `<p class="text-danger mb-0">Error: ${e.message}</p>`; }
}

async function grantSil() {
  const eid = $('silEmployeeSelect').value;
  if (!eid) return showToast('Select an employee first', 'error');
  if (!confirm('Grant 5 days SIL to this employee?')) return;
  try {
    const r = await fetch(`/leaves/api/sil/grant/${eid}`, { method: 'POST' });
    const data = await r.json();
    showToast(data.granted ? `SIL granted: ${data.days} days` : data.reason, data.granted ? 'success' : 'error');
    if (data.granted) checkSilStatus();
  } catch (e) { showToast(e.message, 'error'); }
}

async function runSilAccrual() {
  if (!confirm('Process SIL accrual for all eligible employees?')) return;
  try {
    const r = await fetch('/leaves/api/sil/process-all', { method: 'POST' });
    const data = await r.json();
    showToast(`${data.granted} employee(s) granted SIL out of ${data.processed} eligible`, 'success');
    location.reload();
  } catch (e) { showToast(e.message, 'error'); }
}

async function resolveAllAwol() {
  if (!confirm('Resolve all open AWOL exceptions? This will clear all flags.')) return;
  try {
    const r = await fetch('/leaves/api/awol-exceptions/resolve-all', { method: 'POST' });
    const data = await r.json();
    showToast(`${data.resolved} exception(s) resolved`, 'success');
    renderAwolTable();
  } catch (e) { showToast(e.message, 'error'); }
}

async function runAwolDetection() {
  try {
    const r = await fetch('/leaves/api/detect-absenteeism', { method: 'POST' });
    const data = await r.json();
    showToast(`${data.flagged} employee(s) flagged for AWOL`, data.flagged > 0 ? 'warning' : 'success');
    if (data.flagged > 0) renderAwolTable();
  } catch (e) { showToast(e.message, 'error'); }
}

async function renderAwolTable() {
  try {
    const r = await fetch('/leaves/api/awol-exceptions');
    const exceptions = await r.json();
    const tbody = $('awolTableBody');
    if (!tbody) return;
    tbody.innerHTML = exceptions.map(ex => `
      <tr class="${ex.status === 'Open' ? 'awol-alert' : ''}">
        <td class="py-2 fw-medium">${esc(ex.employee_name)}<br><small class="text-muted">${ex.employee_id}</small></td>
        <td class="py-2"><span class="badge bg-danger">${ex.exception_type}</span></td>
        <td class="py-2">${ex.start_date} to ${ex.end_date}</td>
        <td class="py-2 fw-bold">${ex.days_missed}</td>
        <td class="py-2">${statusBadge(ex.status)}</td>
        <td class="py-2 text-muted small">${new Date(ex.created_at).toLocaleDateString()}</td>
        <td class="py-2 text-end">${ex.status === 'Open' && (<%= user.role === 'admin' || user.role === 'hrd' %>) ? `<button class="btn btn-sm btn-outline-success" onclick="resolveAwol(${ex.id})"><i class="bi bi-check2-circle"></i> Resolve</button>` : ''}</td>
      </tr>
    `).join('');
  } catch {}
}

async function resolveAwol(id) {
  const resolution = prompt('Resolution notes (optional):');
  try {
    await fetch(`/leaves/api/awol-exceptions/${id}/resolve`, {
      method: 'PATCH', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ resolution }),
    });
    renderAwolTable();
    location.reload();
  } catch (e) { showToast(e.message, 'error'); }
}

function filterStatus(val) { render(); }

render();
renderLeaveStats();
renderAwolTable();
</script>
