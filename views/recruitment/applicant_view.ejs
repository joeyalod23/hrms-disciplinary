<div class="container-fluid px-4 py-4">  <div class="d-flex justify-content-between align-items-center mb-4">    <h4 class="fw-bold"><i class="bi bi-person-badge"></i> Applicant Details</h4>    <div>      <a href="/recruitment/applicants/edit/<%= applicant.id %>" class="btn btn-outline-warning"><i class="bi bi-pencil"></i> Edit</a>      <a href="/recruitment" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>    </div>  </div>  <div class="card border-0 shadow-sm mb-3">    <div class="card-body">      <div class="row g-3">        <div class="col-md-6">          <label class="form-label text-muted small mb-0">Full Name</label>          <p class="fw-bold fs-5"><%= applicant.full_name %></p>        </div>        <div class="col-md-6">          <label class="form-label text-muted small mb-0">Status</label>          <p><span class="badge bg-<%= applicant.status === 'For Screening' ? 'primary' : applicant.status === 'For Interview' ? 'info' : applicant.status === 'For Medical' ? 'warning' : applicant.status === 'For Orientation' ? 'secondary' : applicant.status === 'For Job Offer' ? 'primary' : applicant.status === 'Hired' ? 'success' : applicant.status === 'Rejected' ? 'danger' : 'dark' %> fs-6"><%= applicant.status %></span></p>        </div>        <div class="col-md-4">          <label class="form-label text-muted small mb-0">Position</label>          <p><%= applicant.position || '--' %></p>        </div>        <div class="col-md-4">          <label class="form-label text-muted small mb-0">Trade</label>          <p><%= applicant.trade || '--' %></p>        </div>        <div class="col-md-4">          <label class="form-label text-muted small mb-0">Classification</label>          <p><%= applicant.classification || '--' %></p>        </div>        <div class="col-md-4">          <label class="form-label text-muted small mb-0">PRF Number</label>          <p><%= applicant.prf_number || '--' %></p>        </div>        <div class="col-md-4">          <label class="form-label text-muted small mb-0">Date Applied</label>          <p><%= new Date(applicant.date_applied).toLocaleDateString() %></p>        </div>        <div class="col-md-4">          <label class="form-label text-muted small mb-0">Date Hired</label>          <p><%= applicant.date_hired ? new Date(applicant.date_hired).toLocaleDateString() : '--' %></p>        </div>        <div class="col-md-4">          <label class="form-label text-muted small mb-0">Medical Status</label>          <p><%= applicant.medical_status || '--' %></p>        </div>        <div class="col-md-4">          <label class="form-label text-muted small mb-0">Documents Complete</label>          <p><% if (applicant.status === 'Hired') { %><%- applicant.documents_complete ? '<i class="bi bi-check-circle-fill text-success"></i> Complete' : '<i class="bi bi-x-circle-fill text-danger"></i> Incomplete' %><% } else { %><i class="bi bi-hourglass-split text-warning"></i> Partial<% } %></p>        </div>        <div class="col-12">          <label class="form-label text-muted small mb-0">Remarks</label>          <p><%= applicant.remarks || '--' %></p>        </div>      </div>    </div>  </div>  <div class="card border-0 shadow-sm">    <div class="card-header bg-white"><h6 class="fw-bold mb-0"><i class="bi bi-clock-history"></i> Status History</h6></div>    <div class="card-body p-0">      <div class="table-responsive">        <table class="table table-hover mb-0">          <thead class="table-light">            <tr><th>#</th><th>Old Status</th><th>New Status</th><th>Changed By</th><th>Date & Time</th></tr>          </thead>          <tbody>            <% if (history.length === 0) { %>              <tr><td colspan="5" class="text-center text-muted py-4">No status changes recorded</td></tr>            <% } else { %>              <% history.forEach(function(h, i) { %>              <tr>                <td><%= i+1 %></td>                <td><span class="badge bg-secondary"><%= h.old_status || '--' %></span></td>                <td><span class="badge bg-<%= h.new_status === 'Hired' ? 'success' : h.new_status === 'Rejected' ? 'danger' : 'primary' %>"><%= h.new_status %></span></td>                <td><%= h.changed_by_name || 'System' %></td>                <td><%= new Date(h.changed_at).toLocaleString() %></td>              </tr>              <% }) %>            <% } %>          </tbody>        </table>      </div>    </div>  </div></div>