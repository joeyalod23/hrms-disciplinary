<div class="container-fluid px-4 py-4">  <div class="d-flex justify-content-between align-items-center mb-4">    <h4 class="fw-bold"><i class="bi bi-<%= request ? 'pencil' : 'plus' %>-square"></i> <%= request ? 'Edit PRF' : 'New Personnel Request Form' %></h4>    <a href="/recruitment" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>  </div>  <div class="card border-0 shadow-sm">    <div class="card-body">      <form method="POST" action="<%= request ? '/recruitment/edit/' + request.id : '/recruitment/add' %>">        <div class="row g-3">          <div class="col-md-3">            <label class="form-label">PRF# *</label>            <input type="text" name="prf_number" class="form-control" value="<%= request ? request.prf_number : '' %>" <%= request ? 'readonly' : 'required' %>>          </div>          <div class="col-md-5">            <label class="form-label">Department *</label>            <input type="text" name="department" class="form-control" value="<%= request ? request.department : '' %>" required>          </div>          <div class="col-md-4">            <label class="form-label">Position *</label>            <input type="text" name="position" class="form-control" value="<%= request ? request.position : '' %>" required>          </div>          <div class="col-md-3">            <label class="form-label">Trade</label>            <input type="text" name="trade" class="form-control" value="<%= request ? request.trade : '' %>">          </div>          <div class="col-md-3">            <label class="form-label">Skilled Required</label>            <input type="number" name="skilled_required" class="form-control" id="skilledInput" value="<%= request ? request.skilled_required : 0 %>" min="0" oninput="calcTotal()">          </div>          <div class="col-md-3">            <label class="form-label">Non-Skilled Required</label>            <input type="number" name="non_skilled_required" class="form-control" id="nonSkilledInput" value="<%= request ? request.non_skilled_required : 0 %>" min="0" oninput="calcTotal()">          </div>          <div class="col-md-3">            <label class="form-label">Total Required</label>            <input type="text" class="form-control" id="totalDisplay" value="<%= (request ? (request.skilled_required || 0) + (request.non_skilled_required || 0) : 0) %>" readonly>          </div>          <div class="col-md-4">            <label class="form-label">Project Site</label>            <input type="text" name="project_site" class="form-control" value="<%= request ? request.project_site : '' %>">          </div>          <div class="col-md-3">            <label class="form-label">Date Requested *</label>            <input type="date" name="date_requested" class="form-control" value="<%= request ? request.date_requested : new Date().toISOString().split('T')[0] %>" required>          </div>          <div class="col-md-4">            <label class="form-label">Prepared By</label>            <input type="text" name="prepared_by" class="form-control" value="<%= request ? request.prepared_by : '' %>">          </div>          <div class="col-md-4">            <label class="form-label">Noted By</label>            <input type="text" name="noted_by" class="form-control" value="<%= request ? request.noted_by : '' %>">          </div>          <% if (request) { %>          <div class="col-md-3">            <label class="form-label">Status</label>            <select name="status" class="form-select">              <option value="Pending" <%= request.status === 'Pending' ? 'selected' : '' %>>Pending</option>              <option value="Approved" <%= request.status === 'Approved' ? 'selected' : '' %>>Approved</option>              <option value="For Recruitment" <%= request.status === 'For Recruitment' ? 'selected' : '' %>>For Recruitment</option>              <option value="Filled" <%= request.status === 'Filled' ? 'selected' : '' %>>Filled</option>              <option value="Cancelled" <%= request.status === 'Cancelled' ? 'selected' : '' %>>Cancelled</option>            </select>          </div>          <% } %>        </div>        <div class="mt-4">          <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> <%= request ? 'Update PRF' : 'Submit PRF' %></button>          <a href="/recruitment" class="btn btn-outline-secondary">Cancel</a>        </div>      </form>    </div>  </div></div><script>function calcTotal() {  const skilled = parseInt(document.getElementById('skilledInput').value) || 0;  const nonSkilled = parseInt(document.getElementById('nonSkilledInput').value) || 0;  document.getElementById('totalDisplay').value = skilled + nonSkilled;}</script>