<div class="container-fluid px-4 py-4">  <div class="d-flex justify-content-between align-items-center mb-4">    <h4 class="fw-bold"><i class="bi bi-<%= applicant ? 'pencil' : 'plus' %>-square"></i> <%= applicant ? 'Edit Applicant' : 'Add Applicant' %></h4>    <a href="/recruitment" class=\"btn btn-outline-secondary\"><i class=\"bi bi-arrow-left\"></i> Back to PRF List</a>  </div>  <div class="card border-0 shadow-sm">    <div class="card-body">      <% if (typeof error !== 'undefined' && error) { %><div class="alert alert-danger"><%= error %></div><% } %>      <form method="POST" action="<%= applicant ? '/recruitment/applicants/edit/' + applicant.id : '/recruitment/applicants/add' %>">        <div class="row g-3">          <div class="col-md-6">            <label class="form-label">PRF Request <small class="text-muted">(optional)</small></label>            <select name="request_id" class="form-select">              <option value="">-- None --</option>              <% requests.forEach(r => { %>                <option value="<%= r.id %>" <%= applicant && applicant.request_id == r.id ? 'selected' : '' %>><%= r.prf_number %> - <%= r.position %></option>              <% }) %>            </select>          </div>          <div class="col-md-6">            <label class="form-label">Full Name *</label>            <input type="text" name="full_name" class="form-control" value="<%= applicant ? applicant.full_name : '' %>" required>          </div>          <div class="col-md-4">            <label class="form-label">Position</label>            <input type="text" name="position" class="form-control" value="<%= applicant ? applicant.position : '' %>">          </div>          <div class="col-md-4">            <label class="form-label">Trade</label>            <input type="text" name="trade" class="form-control" value="<%= applicant ? applicant.trade : '' %>">          </div>          <div class="col-md-4">            <label class="form-label">Classification</label>            <select name="classification" class="form-select">              <option value="">-- Select --</option>              <option value="Skilled" <%= applicant && applicant.classification === 'Skilled' ? 'selected' : '' %>>Skilled</option>              <option value="Non-Skilled" <%= applicant && applicant.classification === 'Non-Skilled' ? 'selected' : '' %>>Non-Skilled</option>            </select>          </div>          <div class="col-md-4">            <label class="form-label">Status *</label>            <select name="status" class="form-select" required>              <option value="For Screening" <%= applicant && applicant.status === 'For Screening' ? 'selected' : '' %>>For Screening</option>              <option value="For Interview" <%= applicant && applicant.status === 'For Interview' ? 'selected' : '' %>>For Interview</option>              <option value="For Medical" <%= applicant && applicant.status === 'For Medical' ? 'selected' : '' %>>For Medical</option>              <option value="For Orientation" <%= applicant && applicant.status === 'For Orientation' ? 'selected' : '' %>>For Orientation</option>              <option value="For Job Offer" <%= applicant && applicant.status === 'For Job Offer' ? 'selected' : '' %>>For Job Offer</option>              <option value="Hired" <%= applicant && applicant.status === 'Hired' ? 'selected' : '' %>>Hired</option>              <option value="Rejected" <%= applicant && applicant.status === 'Rejected' ? 'selected' : '' %>>Rejected</option>              <option value="No Response" <%= applicant && applicant.status === 'No Response' ? 'selected' : '' %>>No Response</option>            </select>          </div>          <div class="col-md-4">            <label class="form-label">Date Applied *</label>            <input type="date" name="date_applied" class="form-control" value="<%= applicant ? new Date(applicant.date_applied).toISOString().split('T')[0] : today %>" required>          </div>          <div class="col-md-4" id="dateHiredGroup" style="<%= applicant && applicant.status === 'Hired' ? '' : 'display:none' %>">            <label class="form-label">Date Hired</label>            <input type="date" name="date_hired" class="form-control" value="<%= applicant && applicant.date_hired ? new Date(applicant.date_hired).toISOString().split('T')[0] : '' %>">          </div>          <div class="col-md-4">            <label class="form-label">Medical Status</label>            <input type="text" name="medical_status" class="form-control" value="<%= applicant ? applicant.medical_status : '' %>" placeholder="e.g. Fit, Pending, Unfit">          </div>          <div class="col-md-4 d-flex align-items-end">            <div class="form-check mb-2">              <input type="hidden" name="documents_complete" value="0">              <input type="checkbox" name="documents_complete" class="form-check-input" value="1" id="docComplete" <%= applicant && applicant.documents_complete ? 'checked' : '' %>>              <label class="form-check-label" for="docComplete">Documents Complete</label>            </div>          </div>          <div class="col-12">            <label class="form-label">Remarks</label>            <textarea name="remarks" class="form-control" rows="3"><%= applicant ? applicant.remarks : '' %></textarea>          </div>        </div>        <div class="mt-4">          <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> <%= applicant ? 'Update' : 'Save' %></button>          <a href="/recruitment" class="btn btn-outline-secondary">Cancel</a>        </div>      </form>    </div>  </div></div><% scripts = '<script>' +  'document.querySelector(\'[name="status"]\').addEventListener(\'change\', function() {' +    'document.getElementById(\'dateHiredGroup\').style.display = this.value === \'Hired\' ? \'\' : \'none\';' +  '});' +'</script>' %>