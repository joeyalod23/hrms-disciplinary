<div class="container-fluid px-4 py-4">  <div class="d-flex justify-content-between align-items-center mb-4">    <h4 class="fw-bold"><i class="bi bi-clipboard-check"></i> Personnel Request Forms (PRF)</h4>    <a href="/recruitment/add" class="btn btn-primary"><i class="bi bi-plus-lg"></i> New PRF</a>  </div>  <div class="card border-0 shadow-sm">    <div class="card-body">      <form method="GET" class="row g-2 mb-3">        <div class="col-md-4">          <input type="text" name="search" class="form-control" placeholder="Search by PRF#, position, or department..." value="<%= search %>">        </div>        <div class="col-md-2">          <select name="status" class="form-select">            <option value="">All Status</option>            <option value="Pending" <%= status === 'Pending' ? 'selected' : '' %>>Pending</option>            <option value="Approved" <%= status === 'Approved' ? 'selected' : '' %>>Approved</option>            <option value="For Recruitment" <%= status === 'For Recruitment' ? 'selected' : '' %>>For Recruitment</option>            <option value="Filled" <%= status === 'Filled' ? 'selected' : '' %>>Filled</option>            <option value="Cancelled" <%= status === 'Cancelled' ? 'selected' : '' %>>Cancelled</option>          </select>        </div>        <div class="col-md-1">          <button type="submit" class="btn btn-outline-primary w-100"><i class="bi bi-search"></i></button>        </div>      </form>      <div class="table-responsive">        <table class="table table-hover">          <thead class="table-dark">            <tr><th>PRF#</th><th>Department</th><th>Position</th><th>Skilled</th><th>Non-Skilled</th><th>Total</th><th>Hired</th><th>Project Site</th><th>Status</th><th>Date</th></tr>          </thead>          <tbody>            <% if (requests.length === 0) { %>              <tr><td colspan="10" class="text-center text-muted py-4">No PRF requests found</td></tr>            <% } else { %>              <% requests.forEach(r => { %>              <tr>                <td><span class="fw-medium"><%= r.prf_number %></span></td>                <td><%= r.department %></td>                <td><%= r.position %></td>                <td><%= r.skilled_required %></td>                <td><%= r.non_skilled_required %></td>                <td><strong><%= (r.skilled_required || 0) + (r.non_skilled_required || 0) %></strong></td>                <td><%= r.hired || 0 %></td>                <td><%= r.project_site || '--' %></td>                <td>                  <span class="badge bg-<%= r.status === 'Filled' ? 'success' : r.status === 'Approved' ? 'primary' : r.status === 'For Recruitment' ? 'info' : r.status === 'Cancelled' ? 'secondary' : 'warning' %>"><%= r.status %></span>                </td>                <td><%= new Date(r.created_at).toLocaleDateString() %></td>              </tr>              <% }) %>            <% } %>          </tbody>        </table>      </div>      <% if (pages > 1) { %>      <nav><ul class="pagination pagination-sm justify-content-center">        <% for (var i = 1; i <= pages; i++) { %>          <li class="page-item <%= i === page ? 'active' : '' %>">            <a class="page-link" href="?page=<%= i %><%= search ? '&search=' + search : '' %><%= status ? '&status=' + status : '' %>"><%= i %></a>          </li>        <% } %>      </ul></nav>      <% } %>    </div>  </div></div>